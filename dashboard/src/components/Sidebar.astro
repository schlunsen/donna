---
// Donna - Continuous AI Pentesting Platform
//
// This program is free software: you can redistribute it and/or modify
// it under the terms of the GNU Affero General Public License version 3
// as published by the Free Software Foundation.

interface Props {
  activePage?: string;
  runningCount?: number;
  failedCount?: number;
}

const { activePage = 'workflows', runningCount = 0, failedCount = 0 } = Astro.props;
---

<div class="sidebar-backdrop" id="sidebarBackdrop"></div>
<aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
        <div class="sidebar-brand-icon"><img src="/donna-icon.png" alt="Donna" width="32" height="32" style="border-radius: 6px;" /></div>
        <span class="sidebar-brand-text">Donna</span>
        <span class="sidebar-brand-badge">local</span>
    </div>

    <nav class="sidebar-nav">
        <!-- Main Navigation -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Navigation</div>
            <a href="/" class:list={["sidebar-link", { active: activePage === 'workflows' }]}>
                <span class="sidebar-link-icon">⚡</span>
                Workflows
            </a>
            <a href="/schedules" class:list={["sidebar-link", { active: activePage === 'schedules' }]}>
                <span class="sidebar-link-icon">📅</span>
                Schedules
            </a>
            <a href="/archive" class:list={["sidebar-link", { active: activePage === 'archive' }]}>
                <span class="sidebar-link-icon">📦</span>
                Archive
            </a>
        </div>

        <!-- Views -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Saved Views</div>
            <a href="/?view=all" class:list={["sidebar-link", { active: activePage === 'all' }]}>
                <span class="sidebar-link-icon">◎</span>
                All Workflows
            </a>
            {runningCount > 0 && (
                <a href="/?status=running" class:list={["sidebar-link", { active: activePage === 'running' }]}>
                    <span class="sidebar-link-icon">◉</span>
                    Running
                    <span class="sidebar-link-badge info">{runningCount}</span>
                </a>
            )}
            {failedCount > 0 && (
                <a href="/?status=failed" class:list={["sidebar-link", { active: activePage === 'failed' }]}>
                    <span class="sidebar-link-icon">✗</span>
                    Failed
                    <span class="sidebar-link-badge error">{failedCount}</span>
                </a>
            )}
            <a href="/?period=today" class:list={["sidebar-link", { active: activePage === 'today' }]}>
                <span class="sidebar-link-icon">◔</span>
                Today
            </a>
            <a href="/?period=hour" class:list={["sidebar-link", { active: activePage === 'hour' }]}>
                <span class="sidebar-link-icon">◕</span>
                Last Hour
            </a>
        </div>

        <!-- Resources -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Resources</div>
            <a href="/docs" class="sidebar-link">
                <span class="sidebar-link-icon">📄</span>
                Docs
            </a>
            <a href="/presentation" class:list={["sidebar-link", { active: activePage === 'presentation' }]}>
                <span class="sidebar-link-icon">🎬</span>
                Presentation
            </a>
            <a href="http://localhost:8233" class="sidebar-link" target="_blank">
                <span class="sidebar-link-icon">🔗</span>
                Temporal UI
            </a>
        </div>

        <!-- Account -->
        <div class="sidebar-section">
            <div class="sidebar-section-label">Account</div>
            <a href="/settings" class:list={["sidebar-link", { active: activePage === 'settings' }]}>
                <span class="sidebar-link-icon">⚙</span>
                Settings
            </a>
        </div>
    </nav>

    <div class="sidebar-footer">
        <button class="theme-toggle" id="themeToggle" type="button" title="Toggle light/dark theme">
            <span class="theme-toggle-icon" id="themeIcon">🌙</span>
            <span id="themeLabel">Dark</span>
        </button>
        <form method="POST" action="/api/auth/sign-out-action" style="display: contents;">
            <button type="submit" class="sidebar-footer-link" style="text-decoration: none; border: none; background: none; cursor: pointer; width: 100%; text-align: left;">
                <span class="sidebar-link-icon">🚪</span>
                <span>Sign Out</span>
            </button>
        </form>
    </div>
</aside>

<script is:inline>
    // ── Theme toggle ──
    (function() {
        var btn = document.getElementById('themeToggle');
        var icon = document.getElementById('themeIcon');
        var label = document.getElementById('themeLabel');

        function update() {
            var theme = document.documentElement.getAttribute('data-theme') || 'dark';
            if (icon) icon.textContent = theme === 'dark' ? '🌙' : '☀️';
            if (label) label.textContent = theme === 'dark' ? 'Dark' : 'Light';
        }

        update();

        if (btn) {
            btn.addEventListener('click', function() {
                var current = document.documentElement.getAttribute('data-theme') || 'dark';
                var next = current === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', next);
                localStorage.setItem('donna-theme', next);
                update();
            });
        }
    })();
</script>
