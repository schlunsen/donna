import '../styles/global.css';

// If already logged in, redirect to home
import { auth } from '../lib/auth';
const session = await auth.api.getSession({ headers: Astro.request.headers });
if (session) {
  return Astro.redirect('/');
}

const returnTo = Astro.url.searchParams.get('returnTo') || '/';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sign In — Donna</title>
    <script is:inline>
        (function() {
            var t = localStorage.getItem('donna-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', t);
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">
            <!-- Brand -->
            <div class="login-brand">
                <div class="login-brand-icon"><img src="/donna-icon.png" alt="Donna" width="48" height="48" style="border-radius: 10px;" /></div>
                <h1 class="login-title">Donna</h1>
                <p class="login-subtitle">AI Pentesting Platform</p>
            </div>

            <!-- Error message -->
            <div class="login-error" id="loginError" style="display: none;"></div>

            <!-- Google OAuth only -->
            <button class="btn btn-primary login-btn login-google" id="googleBtn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                    <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
                    <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                    <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18A10.96 10.96 0 0 0 1 12c0 1.77.42 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
                    <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
                Sign in with Google
            </button>

            <p class="login-hint">Access restricted to authorized accounts only.</p>
        </div>

        <!-- Subtle background glow -->
        <div class="login-bg-glow"></div>
    </div>

    <script is:inline define:vars={{ returnTo }}>
        const errorEl = document.getElementById('loginError');

        function showError(msg) {
            errorEl.textContent = msg;
            errorEl.style.display = 'block';
        }

        // Google OAuth — POST to get the redirect URL, then navigate
        document.getElementById('googleBtn').addEventListener('click', async () => {
            try {
                const res = await fetch('/api/auth/sign-in/social', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        provider: 'google',
                        callbackURL: returnTo || '/',
                    }),
                });
                const data = await res.json();
                if (data.url) {
                    window.location.href = data.url;
                } else {
                    showError('Failed to start Google sign-in');
                }
            } catch (err) {
                showError('Failed to start Google sign-in');
            }
        });
    </script>
</body>
</html>

<style>
    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .login-card {
        width: 400px;
        max-width: 90vw;
        background: var(--bg-surface);
        border: 1px solid var(--border-hover);
        border-radius: var(--radius-xl);
        padding: 2.5rem;
        position: relative;
        z-index: 1;
        box-shadow: 0 16px 64px rgba(0, 0, 0, 0.4);
        text-align: center;
    }

    .login-brand {
        margin-bottom: 2rem;
    }

    .login-brand-icon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--purple), var(--purple-dark));
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        box-shadow: 0 4px 24px var(--purple-glow);
        margin-bottom: 1rem;
    }

    .login-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--white);
        letter-spacing: -0.03em;
    }

    .login-subtitle {
        font-size: 0.8rem;
        color: var(--text-dim);
        margin-top: 0.25rem;
    }

    .login-btn {
        width: 100%;
        justify-content: center;
        padding: 0.7rem 1.25rem;
        font-size: 0.85rem;
    }

    .login-google {
        gap: 0.75rem;
        display: flex;
        align-items: center;
    }

    .login-hint {
        font-size: 0.72rem;
        color: var(--text-faint);
        margin-top: 1.25rem;
    }

    .login-error {
        background: var(--error-bg);
        border: 1px solid var(--error-border);
        color: var(--error);
        font-size: 0.8rem;
        padding: 0.6rem 0.85rem;
        border-radius: var(--radius);
        margin-bottom: 1rem;
        text-align: left;
    }

    .login-bg-glow {
        position: fixed;
        top: 30%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(123, 45, 142, 0.15), transparent 70%);
        pointer-events: none;
        z-index: 0;
    }
</style>
