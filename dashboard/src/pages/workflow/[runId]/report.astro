import Base from '../../../layouts/Base.astro';
import { getVersion } from '../../../lib/version';
import { getTemporalClient, getWorkflowProgress, type PipelineProgress } from '../../../lib/temporal.js';
import { getSessionByWorkflowId, getFullFindings, getComprehensiveReport, computeFindingSummaryFromFiles, getDetailedFindings } from '../../../lib/audit-logs.js';
import type { SessionData, FullFinding, ComprehensiveReport, DetailedFinding } from '../../../lib/audit-logs.js';
import { marked } from 'marked';

const donnaVersion = getVersion();
const { runId } = Astro.params;

// ── Data Fetching ──────────────────────────────────────────────────────────────

let workflowId: string | null = null;
let wfStatus = '';
let wfType = '';
let wfStartTime = '';
let wfCloseTime: string | null = null;
let wfInput: any = null;
let progress: PipelineProgress | null = null;
let sessionData: SessionData | null = null;
let findings: FullFinding[] = [];
let comprehensiveReport: ComprehensiveReport | null = null;
let loadError: string | null = null;

try {
    const client = await getTemporalClient();

    // Find workflow by runId
    for await (const w of client.workflow.list({ query: `RunId = "${runId}"` })) {
        workflowId = w.workflowId;
        break;
    }

    if (workflowId) {
        const handle = client.workflow.getHandle(workflowId, runId);
        const desc = await handle.describe();

        wfStatus = desc.status.name.toLowerCase();
        wfType = desc.type;
        wfStartTime = desc.startTime?.toISOString() || '';
        wfCloseTime = desc.closeTime?.toISOString() || null;

        // Extract input from history
        try {
            const history = await handle.fetchHistory();
            for (const ev of history?.events || []) {
                const attrs = (ev as any).workflowExecutionStartedEventAttributes;
                if (attrs?.input?.payloads?.[0]?.data) {
                    try {
                        wfInput = JSON.parse(Buffer.from(attrs.input.payloads[0].data).toString('utf-8'));
                    } catch {}
                    break;
                }
            }
        } catch {}

        // Get progress/result
        if (wfStatus === 'running') {
            try { progress = await handle.query<PipelineProgress>('getProgress'); } catch {}
        } else if (wfStatus === 'completed') {
            try {
                const result = await handle.result() as PipelineProgress;
                if (result) {
                    if (!result.findingSummary) {
                        const backfilled = await computeFindingSummaryFromFiles(workflowId);
                        if (backfilled) result.findingSummary = backfilled;
                    }
                    progress = { ...result, workflowId, elapsedMs: 0 };
                }
            } catch {}
        }

        // Fetch session data, findings, and comprehensive report in parallel
        const [sd, ff, cr] = await Promise.all([
            getSessionByWorkflowId(workflowId).catch(() => null),
            getFullFindings(workflowId).catch(() => []),
            getComprehensiveReport(workflowId).catch(() => null),
        ]);
        sessionData = sd;
        findings = ff;
        comprehensiveReport = cr;
    }
} catch (err) {
    loadError = err instanceof Error ? err.message : 'Failed to load workflow data';
}

// ── Parent Run Comparison ────────────────────────────────────────────────────
// If this workflow was started from a parent, fetch parent findings for comparison

let parentFindings: DetailedFinding[] = [];
let parentWorkflowId: string | null = null;
let parentRunIdValue: string | null = wfInput?.parentRunId || null;
let hasParentComparison = false;

// Build comparison data structures
type ComparisonStatus = 'fixed' | 'still-present' | 'new';
let findingComparison: Map<string, ComparisonStatus> = new Map();
let fixedFindings: DetailedFinding[] = [];

if (parentRunIdValue) {
    try {
        const client = await getTemporalClient();
        // Find parent workflow by runId
        for await (const w of client.workflow.list({ query: `RunId = "${parentRunIdValue}"` })) {
            parentWorkflowId = w.workflowId;
            break;
        }
        if (parentWorkflowId) {
            parentFindings = await getDetailedFindings(parentWorkflowId);
            hasParentComparison = parentFindings.length > 0;

            if (hasParentComparison) {
                // Build a key for each finding: category + normalized title + location
                const makeKey = (f: DetailedFinding) =>
                    `${f.category}::${f.title.toLowerCase().trim()}::${f.location.toLowerCase().trim()}`;

                const parentKeys = new Set(parentFindings.map(makeKey));
                const currentKeys = new Set(findings.map(makeKey));

                // Current findings: mark as 'still-present' or 'new'
                for (const f of findings) {
                    const key = makeKey(f);
                    findingComparison.set(f.id, parentKeys.has(key) ? 'still-present' : 'new');
                }

                // Parent findings not in current = fixed
                fixedFindings = parentFindings.filter(f => !currentKeys.has(makeKey(f)));
            }
        }
    } catch {
        // Parent comparison is best-effort, don't block the report
    }
}

const comparisonCounts = hasParentComparison ? {
    fixed: fixedFindings.length,
    stillPresent: [...findingComparison.values()].filter(s => s === 'still-present').length,
    new: [...findingComparison.values()].filter(s => s === 'new').length,
} : null;

// ── Helpers ────────────────────────────────────────────────────────────────────

function formatDate(iso: string | null) {
    if (!iso) return 'N/A';
    return new Date(iso).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}

function formatDateTime(iso: string | null) {
    if (!iso) return 'N/A';
    return new Date(iso).toLocaleString('en-US', {
        month: 'short', day: 'numeric', year: 'numeric',
        hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false,
    });
}

function getElapsed(start: string, end: string | null) {
    const s = new Date(start).getTime();
    const e = end ? new Date(end).getTime() : Date.now();
    const ms = e - s;
    const seconds = Math.floor(ms / 1000);
    const minutes = Math.floor(seconds / 60);
    const hours = Math.floor(minutes / 60);
    if (hours > 0) return `${hours}h ${minutes % 60}m ${seconds % 60}s`;
    if (minutes > 0) return `${minutes}m ${seconds % 60}s`;
    return `${seconds}s`;
}

// Configure marked for safe rendering
marked.setOptions({ breaks: true, gfm: true });

function renderMarkdown(md: string): string {
    if (!md) return '';
    return marked.parse(md) as string;
}

// Computed data
const targetUrl = wfInput?.webUrl || sessionData?.session?.webUrl || 'Unknown Target';
const scanDate = formatDate(wfStartTime);
const totalCost = progress?.summary?.totalCostUsd ?? sessionData?.metrics?.total_cost_usd ?? 0;
const totalDurationMs = progress?.summary?.totalDurationMs ?? sessionData?.metrics?.total_duration_ms ?? 0;

const findingCounts = {
    critical: findings.filter(f => f.severity === 'Critical').length,
    high: findings.filter(f => f.severity === 'High').length,
    medium: findings.filter(f => f.severity === 'Medium').length,
    low: findings.filter(f => f.severity === 'Low').length,
    informational: findings.filter(f => f.severity === 'Informational').length,
};
const totalFindings = findings.length;

// Risk level
const overallRisk = findingCounts.critical > 0 ? 'Critical' :
                    findingCounts.high > 0 ? 'High' :
                    findingCounts.medium > 0 ? 'Medium' :
                    findingCounts.low > 0 ? 'Low' : 'Informational';

const riskClass = overallRisk.toLowerCase();

// Phase data
const phases = sessionData?.metrics?.phases || {};
const phaseEntries = Object.entries(phases).map(([name, data]) => ({
    name: name.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase()),
    durationMs: data.duration_ms,
    durationMin: Math.round(data.duration_ms / 60000),
    costUsd: data.cost_usd,
    agentCount: data.agent_count,
    pct: data.duration_percentage,
}));

// Agent data
const agents = Object.entries(sessionData?.metrics?.agents || {}).map(([name, data]) => ({
    name,
    model: data.model || 'unknown',
    status: data.status,
    costUsd: data.total_cost_usd,
    durationMs: data.final_duration_ms,
}));

// Category labels for display
const categoryLabels: Record<string, string> = {
    auth: 'Authentication',
    xss: 'Cross-Site Scripting',
    ssrf: 'Server-Side Request Forgery',
    authz: 'Authorization',
    injection: 'Injection',
};

// Group findings by category
const findingsByCategory = findings.reduce((acc, f) => {
    if (!acc[f.category]) acc[f.category] = [];
    acc[f.category].push(f);
    return acc;
}, {} as Record<string, FullFinding[]>);

// Pre-compute priority findings for template
const priorityFindings = findings.filter(f => f.severity === 'Critical' || f.severity === 'High').slice(0, 5);

// Pre-compute category badge counts
const categoryBadgeCounts = Object.entries(findingsByCategory).map(([cat, catFindings]) => ({
    cat,
    name: categoryLabels[cat] || cat,
    total: catFindings.length,
    critical: catFindings.filter(f => f.severity === 'Critical').length,
    high: catFindings.filter(f => f.severity === 'High').length,
    medium: catFindings.filter(f => f.severity === 'Medium').length,
    low: catFindings.filter(f => f.severity === 'Low').length,
}));

// Helper to create anchor-safe IDs
function anchorId(id: string): string {
    return id.replace(/\s+/g, '-').replace(/[^a-zA-Z0-9-]/g, '');
}

// Pre-computed verdict HTML
const verdictHtml = findingCounts.critical > 0
    ? `<div class="exec-verdict"><p class="verdict-critical"><strong>${findingCounts.critical} critical</strong> vulnerabilities discovered requiring <strong>immediate remediation</strong>.</p></div>`
    : findingCounts.high > 0
    ? `<div class="exec-verdict"><p class="verdict-high"><strong>${findingCounts.high} high-severity</strong> vulnerabilities discovered. Prompt remediation is recommended.</p></div>`
    : totalFindings > 0
    ? `<div class="exec-verdict"><p class="verdict-moderate">No critical or high-severity vulnerabilities were found.</p></div>`
    : `<div class="exec-verdict"><p class="verdict-clean">No vulnerabilities were identified during this assessment.</p></div>`;

// Pre-format currency values to avoid $ + { conflicts in Astro templates
const totalCostFormatted = '$' + totalCost.toFixed(2);
const totalDurationFormatted = Math.round(totalDurationMs / 60000) + 'm';
function formatCost(usd: number): string { return '$' + usd.toFixed(2); }

// Pre-computed strings for the template
const vulnWord = totalFindings === 1 ? 'vulnerability' : 'vulnerabilities';
const dedupNote = comprehensiveReport?.deduplicatedCount
    ? ` (after merging ${comprehensiveReport.deduplicatedCount} duplicate findings)`
    : '';

// TOC category entries
const tocCategories = Object.entries(findingsByCategory).map(([cat, catFindings]) => ({
    cat,
    label: (categoryLabels[cat] || cat) + ' (' + catFindings.length + ')',
}));
---

<Base title={`Security Report — ${targetUrl}`}>
    {/* Floating navigation bar (hidden in print) */}
    <div class="report-nav">
        <a href={`/workflow/${runId}`} class="report-nav-back">
            Back to Dashboard
        </a>
        <div class="report-nav-right">
            <span class="version-badge">v{donnaVersion}</span>
            <button class="btn btn-primary" id="printBtn">
                Export PDF
            </button>
        </div>
    </div>

    <div class="report-page">
        {loadError && (
            <div class="banner banner-error" style="margin: 2rem auto; max-width: 800px;">
                Failed to load report: {loadError}
            </div>
        )}

        {!workflowId ? (
            <div class="report-empty">
                <h2>Report Not Available</h2>
                <p>No workflow found for run ID <code>{runId}</code></p>
                <a href="/" class="btn btn-secondary">Back to Workflows</a>
            </div>
        ) : (
            <div>
                {/* ═══════════════════════════════════════════════════════════
                    SECTION 1: Report Cover / Header
                    ═══════════════════════════════════════════════════════════ */}
                <header class="report-cover">
                    <div class="report-cover-badge">DONNA</div>
                    <h1 class="report-cover-title">Security Assessment Report</h1>
                    <div class="report-cover-target">{targetUrl}</div>
                    <div class="report-cover-date">{scanDate}</div>

                    <div class={`report-risk-indicator ${riskClass}`}>
                        <div class="risk-label">Overall Risk</div>
                        <div class="risk-value">{overallRisk}</div>
                    </div>

                    <div class="report-cover-meta">
                        <div class="cover-meta-item">
                            <span class="cover-meta-label">Duration</span>
                            <span class="cover-meta-value">{getElapsed(wfStartTime, wfCloseTime)}</span>
                        </div>
                        <div class="cover-meta-item">
                            <span class="cover-meta-label">Cost</span>
                            <span class="cover-meta-value">{totalCostFormatted}</span>
                        </div>
                        <div class="cover-meta-item">
                            <span class="cover-meta-label">Findings</span>
                            <span class="cover-meta-value">{totalFindings}</span>
                        </div>
                        <div class="cover-meta-item">
                            <span class="cover-meta-label">Agents</span>
                            <span class="cover-meta-value">{agents.length}</span>
                        </div>
                    </div>
                </header>

                {/* ═══════════════════════════════════════════════════════════
                    SECTION 2: Table of Contents
                    ═══════════════════════════════════════════════════════════ */}
                <nav class="report-toc" id="toc">
                    <h2 class="report-section-title">Table of Contents</h2>
                    <ol class="toc-list">
                        <li><a href="#executive-summary">Executive Summary</a></li>
                        <li><a href="#severity-breakdown">Severity Breakdown</a></li>
                        {hasParentComparison && (
                            <li><a href="#comparison">Comparison with Previous Run</a></li>
                        )}
                        {comprehensiveReport && comprehensiveReport.rootCauses.length > 0 && (
                            <li><a href="#root-cause">Root-Cause Correlation</a></li>
                        )}
                        <li>
                            <a href="#findings">Detailed Findings</a>
                            <ol class="toc-sublist">
                                {tocCategories.map(tc => (
                                    <li>
                                        <a href={`#cat-${tc.cat}`}>{tc.label}</a>
                                    </li>
                                ))}
                            </ol>
                        </li>
                        {phaseEntries.length > 0 && (
                            <li><a href="#methodology">Methodology & Phase Breakdown</a></li>
                        )}
                        <li><a href="#appendix">Appendix</a></li>
                    </ol>
                </nav>

                {/* ═══════════════════════════════════════════════════════════
                    SECTION 3: Executive Summary
                    ═══════════════════════════════════════════════════════════ */}
                <section class="report-section" id="executive-summary">
                    <h2 class="report-section-title">Executive Summary</h2>

                    <div class="exec-summary-card">
                        <p class="exec-summary-text">
                            An automated security assessment of <strong>{targetUrl}</strong> was conducted
                            on {scanDate} using {"Donna's"} AI-powered penetration testing pipeline.
                            The assessment identified <strong>{totalFindings} unique {vulnWord}</strong>{dedupNote}.
                        </p>

                        <Fragment set:html={verdictHtml} />

                        {/* Top findings preview */}
                        {priorityFindings.length > 0 && (
                            <div class="exec-top-findings">
                                <h4>Priority Findings</h4>
                                <ul class="top-findings-list">
                                    {priorityFindings.map(f => (
                                        <li>
                                            <span class={`sev-tag ${f.severity.toLowerCase()}`}>{f.severity}</span>
                                            <a href={`#finding-${anchorId(f.id)}`}>{f.id}: {f.title}</a>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )}
                    </div>
                </section>

                {/* ═══════════════════════════════════════════════════════════
                    SECTION 4: Severity Breakdown
                    ═══════════════════════════════════════════════════════════ */}
                <section class="report-section" id="severity-breakdown">
                    <h2 class="report-section-title">Severity Breakdown</h2>

                    <div class="severity-chart">
                        {[
                            { label: 'Critical', count: findingCounts.critical, cls: 'critical' },
                            { label: 'High', count: findingCounts.high, cls: 'high' },
                            { label: 'Medium', count: findingCounts.medium, cls: 'medium' },
                            { label: 'Low', count: findingCounts.low, cls: 'low' },
                            { label: 'Informational', count: findingCounts.informational, cls: 'info' },
                        ].map(sev => (
                            <div class="severity-row">
                                <span class={`severity-row-label ${sev.cls}`}>{sev.label}</span>
                                <div class="severity-bar-track">
                                    <div class={`severity-bar-fill ${sev.cls}`}
                                         style={`width: ${totalFindings > 0 ? (sev.count / totalFindings) * 100 : 0}%`}>
                                    </div>
                                </div>
                                <span class={`severity-row-count ${sev.cls}`}>{sev.count}</span>
                            </div>
                        ))}
                    </div>

                    {/* Category distribution */}
                    <div class="category-grid">
                        {categoryBadgeCounts.map(cc => (
                            <div class="category-card">
                                <div class="category-card-header">
                                    <span class="category-card-name">{cc.name}</span>
                                    <span class="category-card-count">{cc.total}</span>
                                </div>
                                <div class="category-card-badges">
                                    {cc.critical > 0 && <span class="finding-badge critical">{cc.critical}C</span>}
                                    {cc.high > 0 && <span class="finding-badge high">{cc.high}H</span>}
                                    {cc.medium > 0 && <span class="finding-badge medium">{cc.medium}M</span>}
                                    {cc.low > 0 && <span class="finding-badge low">{cc.low}L</span>}
                                </div>
                            </div>
                        ))}
                    </div>
                </section>

                {/* ═══════════════════════════════════════════════════════════
                    SECTION 4b: Comparison with Previous Run
                    ═══════════════════════════════════════════════════════════ */}
                {hasParentComparison && comparisonCounts && (
                    <section class="report-section" id="comparison">
                        <h2 class="report-section-title">Comparison with Previous Run</h2>
                        <p class="section-intro">
                            This scan was started from a previous run
                            (<a href={`/workflow/${parentRunIdValue}`}><code>{parentRunIdValue?.substring(0, 8)}...</code></a>).
                            Below is a comparison of findings between the two runs.
                        </p>

                        <div class="comparison-summary">
                            <div class="comparison-stat fixed">
                                <div class="comparison-stat-count">{comparisonCounts.fixed}</div>
                                <div class="comparison-stat-label">Fixed</div>
                                <div class="comparison-stat-desc">No longer detected</div>
                            </div>
                            <div class="comparison-stat still-present">
                                <div class="comparison-stat-count">{comparisonCounts.stillPresent}</div>
                                <div class="comparison-stat-label">Still Present</div>
                                <div class="comparison-stat-desc">Found in both runs</div>
                            </div>
                            <div class="comparison-stat new">
                                <div class="comparison-stat-count">{comparisonCounts.new}</div>
                                <div class="comparison-stat-label">New</div>
                                <div class="comparison-stat-desc">Not in previous run</div>
                            </div>
                        </div>

                        {fixedFindings.length > 0 && (
                            <div class="comparison-fixed-list">
                                <h4>Resolved Findings</h4>
                                <p class="section-intro">These findings from the previous run were not detected in this scan.</p>
                                <table class="comparison-table">
                                    <thead>
                                        <tr>
                                            <th>Status</th>
                                            <th>Severity</th>
                                            <th>ID</th>
                                            <th>Finding</th>
                                            <th>Location</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {fixedFindings.map(f => (
                                            <tr>
                                                <td><span class="comparison-badge fixed">Fixed</span></td>
                                                <td><span class={`sev-tag ${f.severity.toLowerCase()}`}>{f.severity}</span></td>
                                                <td><code>{f.id}</code></td>
                                                <td>{f.title}</td>
                                                <td><code>{f.location.length > 40 ? f.location.substring(0, 40) + '...' : f.location}</code></td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                            </div>
                        )}
                    </section>
                )}

                {/* ═══════════════════════════════════════════════════════════
                    SECTION 5: Root-Cause Correlation
                    ═══════════════════════════════════════════════════════════ */}
                {comprehensiveReport && comprehensiveReport.rootCauses.length > 0 && (
                    <section class="report-section" id="root-cause">
                        <h2 class="report-section-title">Root-Cause Correlation</h2>
                        <p class="section-intro">
                            Multiple findings were identified independently by different agents but share the same underlying root cause.
                            Addressing these root causes will resolve multiple vulnerabilities simultaneously.
                        </p>
                        <div class="root-cause-list">
                            {comprehensiveReport.rootCauses.map(rc => (
                                <div class="root-cause-card">
                                    <div class="root-cause-header">
                                        <span class={`sev-tag ${rc.severity.toLowerCase()}`}>{rc.severity}</span>
                                        <span class="root-cause-name">{rc.rootCause}</span>
                                    </div>
                                    <div class="root-cause-endpoint">
                                        <code>{rc.endpoint}</code>
                                    </div>
                                    <div class="root-cause-meta">
                                        <span class="root-cause-merged">
                                            Merged: {rc.mergedIds.join(', ')}
                                        </span>
                                        <span class="root-cause-sources">
                                            Sources: {rc.sources.join(', ')}
                                        </span>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </section>
                )}

                {/* ═══════════════════════════════════════════════════════════
                    SECTION 6: Detailed Findings
                    ═══════════════════════════════════════════════════════════ */}
                <section class="report-section" id="findings">
                    <h2 class="report-section-title">Detailed Findings</h2>

                    {Object.entries(findingsByCategory).map(([cat, catFindings]) => (
                        <div class="finding-category-section" id={`cat-${cat}`}>
                            <h3 class="finding-category-heading">
                                <span class="finding-category-icon">
                                    {cat === 'auth' ? '🔐' : cat === 'xss' ? '💉' : cat === 'ssrf' ? '🌐' : cat === 'authz' ? '🛡' : '💊'}
                                </span>
                                {categoryLabels[cat] || cat}
                                <span class="finding-category-count">{catFindings.length} finding{catFindings.length !== 1 ? 's' : ''}</span>
                            </h3>

                            {catFindings.map((f) => (
                                <article class="finding-card" id={`finding-${anchorId(f.id)}`}>
                                    <div class="finding-card-header">
                                        <div class="finding-card-header-left">
                                            <span class={`sev-badge ${f.severity.toLowerCase()}`}>{f.severity}</span>
                                            <span class="finding-card-id">{f.id}</span>
                                            {hasParentComparison && findingComparison.get(f.id) === 'still-present' && (
                                                <span class="comparison-badge still-present" title="Also found in previous run">Still Present</span>
                                            )}
                                            {hasParentComparison && findingComparison.get(f.id) === 'new' && (
                                                <span class="comparison-badge new" title="Not found in previous run">New</span>
                                            )}
                                        </div>
                                        <a href="#toc" class="finding-toc-link">Table of Contents</a>
                                    </div>
                                    <h4 class="finding-card-title">{f.title}</h4>

                                    {/* Key metadata */}
                                    <div class="finding-meta-grid">
                                        {f.location && (
                                            <div class="finding-meta-item">
                                                <span class="finding-meta-label">Location</span>
                                                <code class="finding-meta-value">{f.location}</code>
                                            </div>
                                        )}
                                        {f.impact && (
                                            <div class="finding-meta-item">
                                                <span class="finding-meta-label">Impact</span>
                                                <span class="finding-meta-value">{f.impact}</span>
                                            </div>
                                        )}
                                    </div>

                                    {/* Full evidence rendered from markdown */}
                                    <div class="finding-evidence" set:html={renderMarkdown(f.fullEvidence)} />

                                    {f.remediation && (
                                        <div class="finding-remediation">
                                            <h5>Remediation</h5>
                                            <div set:html={renderMarkdown(f.remediation)} />
                                        </div>
                                    )}
                                </article>
                            ))}
                        </div>
                    ))}

                    {findings.length === 0 && (
                        <div class="report-empty-findings">
                            <p>No exploitable vulnerabilities were identified during this assessment.</p>
                        </div>
                    )}
                </section>

                {/* ═══════════════════════════════════════════════════════════
                    SECTION 7: Methodology & Phase Breakdown
                    ═══════════════════════════════════════════════════════════ */}
                {phaseEntries.length > 0 && (
                    <section class="report-section" id="methodology">
                        <h2 class="report-section-title">Methodology & Phase Breakdown</h2>
                        <p class="section-intro">
                            The assessment followed {"Donna's"} automated penetration testing pipeline,
                            which progresses through distinct phases — each powered by specialized AI agents.
                        </p>

                        {/* Phase timeline bar */}
                        <div class="phase-timeline">
                            {phaseEntries.map((p, i) => (
                                <div class={`phase-segment phase-color-${i}`}
                                     style={`flex: ${p.pct || 1}`}
                                     title={p.name + ': ' + p.durationMin + 'min, ' + formatCost(p.costUsd)}>
                                </div>
                            ))}
                        </div>

                        <div class="phase-table-container">
                            <table class="phase-table">
                                <thead>
                                    <tr>
                                        <th>Phase</th>
                                        <th>Duration</th>
                                        <th>Cost</th>
                                        <th>Agents</th>
                                        <th>Share</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {phaseEntries.map((p) => (
                                        <tr>
                                            <td class="phase-name">{p.name}</td>
                                            <td class="phase-duration">{p.durationMin}m</td>
                                            <td class="phase-cost">{formatCost(p.costUsd)}</td>
                                            <td class="phase-agents">{p.agentCount}</td>
                                            <td class="phase-pct">{Math.round(p.pct)}%</td>
                                        </tr>
                                    ))}
                                </tbody>
                                <tfoot>
                                    <tr class="phase-total-row">
                                        <td class="phase-name">Total</td>
                                        <td class="phase-duration">{totalDurationFormatted}</td>
                                        <td class="phase-cost">{totalCostFormatted}</td>
                                        <td class="phase-agents">{agents.length}</td>
                                        <td class="phase-pct">100%</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </section>
                )}

                {/* ═══════════════════════════════════════════════════════════
                    SECTION 8: Appendix
                    ═══════════════════════════════════════════════════════════ */}
                <section class="report-section" id="appendix">
                    <h2 class="report-section-title">Appendix</h2>

                    <div class="appendix-grid">
                        <div class="appendix-card">
                            <h4>Assessment Details</h4>
                            <table class="appendix-table">
                                <tbody>
                                    <tr>
                                        <td class="appendix-label">Target</td>
                                        <td>{targetUrl}</td>
                                    </tr>
                                    <tr>
                                        <td class="appendix-label">Workflow ID</td>
                                        <td><code>{workflowId}</code></td>
                                    </tr>
                                    <tr>
                                        <td class="appendix-label">Run ID</td>
                                        <td><code>{runId}</code></td>
                                    </tr>
                                    <tr>
                                        <td class="appendix-label">Start Time</td>
                                        <td>{formatDateTime(wfStartTime)}</td>
                                    </tr>
                                    <tr>
                                        <td class="appendix-label">End Time</td>
                                        <td>{formatDateTime(wfCloseTime)}</td>
                                    </tr>
                                    <tr>
                                        <td class="appendix-label">Duration</td>
                                        <td>{getElapsed(wfStartTime, wfCloseTime)}</td>
                                    </tr>
                                    <tr>
                                        <td class="appendix-label">Total Cost</td>
                                        <td>{totalCostFormatted}</td>
                                    </tr>
                                    <tr>
                                        <td class="appendix-label">Status</td>
                                        <td>{wfStatus}</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        {agents.length > 0 && (
                            <div class="appendix-card">
                                <h4>Agent Breakdown</h4>
                                <table class="appendix-table">
                                    <thead>
                                        <tr>
                                            <th>Agent</th>
                                            <th>Model</th>
                                            <th>Cost</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {agents.map(a => (
                                            <tr>
                                                <td>{a.name}</td>
                                                <td><code>{a.model}</code></td>
                                                <td>{formatCost(a.costUsd)}</td>
                                                <td>
                                                    <span class={a.status === 'success' ? 'text-success' : 'text-error'}>
                                                        {a.status}
                                                    </span>
                                                </td>
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                            </div>
                        )}
                    </div>
                </section>

                {/* Footer */}
                <footer class="report-footer">
                    <div class="report-footer-line"></div>
                    <p>
                        Generated by <strong>Donna</strong> v{donnaVersion} {"—"}
                        AI-Powered Continuous Security Assessment
                    </p>
                    <p class="report-footer-date">{formatDateTime(new Date().toISOString())}</p>
                </footer>
            </div>
        )}
    </div>

    <script is:inline>
        document.getElementById('printBtn')?.addEventListener('click', () => {
            window.print();
        });
    </script>
</Base>

