import Base from '../../../layouts/Base.astro';
import Sidebar from '../../../components/Sidebar.astro';
import { getVersion } from '../../../lib/version';
import { getTemporalClient, getWorkflowProgress, type PipelineProgress } from '../../../lib/temporal.js';

const donnaVersion = getVersion();
import { resolveEventTypeName, getEventCategory, extractEventDetails } from '../../../lib/event-types.js';
import { getSessionByWorkflowId, getDetailedFindings } from '../../../lib/audit-logs.js';
import type { SessionData, DetailedFinding } from '../../../lib/audit-logs.js';

const { runId } = Astro.params;

// Validate runId format to prevent Temporal query injection (INJ-VULN-01/02 fix)
const RUN_ID_PATTERN = /^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i;
const isValidRunId = runId && RUN_ID_PATTERN.test(runId);

interface WorkflowDetail {
    workflowId: string;
    runId: string;
    status: string;
    type: string;
    taskQueue: string;
    startTime: string;
    closeTime: string | null;
    executionTime: string | null;
    historyLength: number;
    historySize: number;
    memo: Record<string, unknown>;
    searchAttributes: Record<string, unknown>;
    parentExecution: { workflowId: string; runId: string } | null;
    input: unknown;
    result: unknown;
    pendingActivities: number;
}

interface HistoryEvent {
    eventId: number;
    eventType: string;
    eventTime: string | null;
    details: Record<string, string>;
    category: string;
}

let wf: WorkflowDetail | null = null;
let progress: PipelineProgress | null = null;
let events: HistoryEvent[] = [];
let loadError: string | null = null;
let sessionData: SessionData | null = null;
let findings: DetailedFinding[] = [];

try {
    if (!isValidRunId) {
        throw new Error('Invalid runId format');
    }
    const client = await getTemporalClient();

    // Find workflow by runId (safe — validated as UUID above)
    let workflowId: string | null = null;
    for await (const w of client.workflow.list({ query: `RunId = "${runId}"` })) {
        workflowId = w.workflowId;
        break;
    }

    if (workflowId) {
        const handle = client.workflow.getHandle(workflowId, runId);
        const desc = await handle.describe();

        // Extract search attributes
        const searchAttrs: Record<string, unknown> = {};
        if (desc.searchAttributes) {
            const sa = desc.searchAttributes as any;
            if (sa.indexed) {
                for (const [key, val] of Object.entries(sa.indexed)) {
                    searchAttrs[key] = val;
                }
            }
        }

        wf = {
            workflowId: desc.workflowId,
            runId: desc.runId,
            status: desc.status.name.toLowerCase(),
            type: desc.type,
            taskQueue: desc.taskQueue,
            startTime: desc.startTime?.toISOString() || '',
            closeTime: desc.closeTime?.toISOString() || null,
            executionTime: desc.executionTime?.toISOString() || null,
            historyLength: desc.historyLength,
            historySize: 0,
            memo: (desc.memo as Record<string, unknown>) || {},
            searchAttributes: searchAttrs,
            parentExecution: desc.parentExecution || null,
            input: null,
            result: null,
            pendingActivities: 0,
        };

        // Get progress for running workflows
        if (wf.status === 'running') {
            try {
                progress = await handle.query<PipelineProgress>('getProgress');
            } catch { /* query unavailable */ }
        }

        // Fetch result for completed workflows
        if (wf.status === 'completed') {
            try {
                wf.result = await handle.result();
            } catch { /* no result */ }
        }

        // Fetch history events
        try {
            const history = await handle.fetchHistory();
            const rawEvents = history?.events || [];
            wf.historySize = rawEvents.length;

            // Count pending activities
            const scheduledActivities = new Set<string>();
            const completedActivities = new Set<string>();

            for (const ev of rawEvents) {
                const typeName = resolveEventTypeName(ev.eventType);
                const details = extractEventDetails(ev);
                const category = getEventCategory(typeName);

                // Track pending activities
                const typeStr = String(ev.eventType);
                if (typeStr.includes('ACTIVITY_TASK_SCHEDULED') || typeName.toLowerCase().includes('activity task scheduled')) {
                    scheduledActivities.add(String(ev.eventId));
                }
                if (typeStr.includes('ACTIVITY_TASK_COMPLETED') || typeStr.includes('ACTIVITY_TASK_FAILED') ||
                    typeName.toLowerCase().includes('activity task completed') || typeName.toLowerCase().includes('activity task failed')) {
                    const schedId = details['Scheduled Event']?.replace('#', '');
                    if (schedId) completedActivities.add(schedId);
                }

                // Extract input from WorkflowExecutionStarted
                if (typeName.toLowerCase().includes('workflow execution started')) {
                    const attrs = ev.workflowExecutionStartedEventAttributes;
                    if (attrs?.input?.payloads) {
                        try {
                            const payload = attrs.input.payloads[0];
                            if (payload?.data) {
                                const decoded = Buffer.from(payload.data).toString('utf-8');
                                wf.input = JSON.parse(decoded);
                            }
                        } catch { /* can't decode */ }
                    }
                }

                events.push({
                    eventId: Number(ev.eventId || 0),
                    eventType: typeName,
                    eventTime: ev.eventTime
                        ? new Date(Number(ev.eventTime.seconds) * 1000 + Number(ev.eventTime.nanos || 0) / 1e6).toISOString()
                        : null,
                    details,
                    category,
                });
            }

            // Calculate pending activities
            for (const id of scheduledActivities) {
                if (!completedActivities.has(id)) {
                    wf.pendingActivities++;
                }
            }
        } catch { /* history unavailable */ }

        // Load audit-log session data for richer failure details
        try {
            sessionData = await getSessionByWorkflowId(wf.workflowId);
        } catch { /* audit logs unavailable */ }

        // Load detailed findings from evidence files
        try {
            findings = await getDetailedFindings(wf.workflowId);
        } catch { /* findings unavailable */ }
    }
} catch (err) {
    loadError = err instanceof Error ? err.message : 'Failed to load workflow';
}

// ── Parent Run Comparison (for detail page badges) ───────────────────────────
let parentRunIdValue: string | null = (wf?.input as any)?.parentRunId || null;
let hasParentComparison = false;
let findingComparisonMap: Map<string, 'fixed' | 'still-present' | 'new'> = new Map();
let fixedFindingsCount = 0;

if (parentRunIdValue && RUN_ID_PATTERN.test(parentRunIdValue) && findings.length > 0) {
    try {
        const client = await getTemporalClient();
        let parentWorkflowId: string | null = null;
        for await (const w of client.workflow.list({ query: `RunId = "${parentRunIdValue}"` })) {
            parentWorkflowId = w.workflowId;
            break;
        }
        if (parentWorkflowId) {
            const parentFindings = await getDetailedFindings(parentWorkflowId);
            if (parentFindings.length > 0) {
                hasParentComparison = true;
                const makeKey = (f: DetailedFinding) =>
                    `${f.category}::${f.title.toLowerCase().trim()}::${f.location.toLowerCase().trim()}`;
                const parentKeys = new Set(parentFindings.map(makeKey));
                const currentKeys = new Set(findings.map(makeKey));
                for (const f of findings) {
                    findingComparisonMap.set(f.id, parentKeys.has(makeKey(f)) ? 'still-present' : 'new');
                }
                fixedFindingsCount = parentFindings.filter(f => !currentKeys.has(makeKey(f))).length;
            }
        }
    } catch { /* comparison is best-effort */ }
}

// Helpers
function formatDateTime(iso: string | null) {
    if (!iso) return '—';
    return new Date(iso).toLocaleString('en-US', {
        month: 'short', day: 'numeric', year: 'numeric',
        hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false,
    });
}

function getElapsed(start: string, end: string | null) {
    const s = new Date(start).getTime();
    const e = end ? new Date(end).getTime() : Date.now();
    const ms = e - s;
    const seconds = Math.floor(ms / 1000);
    const minutes = Math.floor(seconds / 60);
    const hours = Math.floor(minutes / 60);
    if (hours > 0) return `${hours}h ${minutes % 60}m ${seconds % 60}s`;
    if (minutes > 0) return `${minutes}m ${seconds % 60}s`;
    return `${seconds}s`;
}

function formatEventTime(iso: string | null) {
    if (!iso) return '';
    return new Date(iso).toLocaleTimeString('en-US', {
        hour: '2-digit', minute: '2-digit', second: '2-digit',
        fractionalSecondDigits: 2, hour12: false,
    });
}

// Build agents list from progress + audit-log data
const sessionAgents: Record<string, any> = sessionData?.metrics?.agents || {};

function buildAgents() {
    const raw = progress?.agentMetrics
        ? Object.entries(progress.agentMetrics).map(([name, m]) => {
            const sa = sessionAgents[name];
            return {
                agentName: name,
                model: m.model || sa?.model || '—',
                durationMs: m.durationMs,
                costUsd: m.costUsd ?? sa?.total_cost_usd ?? 0,
                turns: m.numTurns ?? 0,
                success: progress!.completedAgents?.includes(name) ?? false,
                error: progress!.failedAgent === name ? progress!.error : undefined,
                attempts: (sa?.attempts || []) as any[],
            };
        })
        : Object.entries(sessionAgents).map(([name, sa]) => ({
            agentName: name,
            model: sa.model || '—',
            durationMs: sa.final_duration_ms || 0,
            costUsd: sa.total_cost_usd ?? 0,
            turns: 0,
            success: sa.status === 'success',
            error: sa.attempts?.find((a: any) => !a.success)?.error,
            attempts: (sa.attempts || []) as any[],
        }));

    return raw.map(a => {
        const failedAttempts = a.attempts.filter((att: any) => !att.success);
        const lastErr = a.error || (failedAttempts.length > 0 ? failedAttempts[failedAttempts.length - 1]?.error : null) || null;
        return {
            ...a,
            lastError: lastErr,
            attemptCount: a.attempts.length,
            failedAttemptCount: failedAttempts.length,
            hasFailed: !a.success && (a.durationMs > 0 || a.attempts.length > 0),
            statusLabel: a.success ? 'Done' : (a.durationMs > 0 || a.attempts.length > 0) ? 'Failed' : 'Pending',
            statusClass: a.success ? 'completed' : (a.durationMs > 0 || a.attempts.length > 0) ? 'failed' : 'running',
            errorPreview: lastErr ? (lastErr.length > 60 ? lastErr.slice(0, 60) + '...' : lastErr) : null,
        };
    });
}

const agents = buildAgents();

// Failure analysis data
function buildFailedAgents() {
    return agents
        .filter(a => !a.success && (a.error || a.attempts.some((att: any) => !att.success)))
        .map(a => {
            const failed = a.attempts.filter((att: any) => !att.success);
            return {
                agentName: a.agentName,
                model: a.model,
                costUsd: a.costUsd,
                lastError: a.lastError,
                failedAttempts: failed.map((att: any) => ({
                    attempt_number: att.attempt_number,
                    error: att.error,
                    formattedTime: formatEventTime(att.timestamp),
                    durationSec: Math.round(att.duration_ms / 1000),
                })),
            };
        });
}

const failedAgents = buildFailedAgents();

const sessionPhases = sessionData?.metrics?.phases || {};
const phaseEntries = Object.entries(sessionPhases).map(([name, data]) => ({
    name,
    durationMin: Math.round(data.duration_ms / 60000),
    costFormatted: '$' + data.cost_usd.toFixed(2),
    agentCount: data.agent_count,
    pct: data.duration_percentage,
    title: name + ': ' + Math.round(data.duration_ms / 60000) + 'min, $' + data.cost_usd.toFixed(2) + ', ' + data.agent_count + ' agents',
}));

// Findings summary
const findingCounts = {
    critical: findings.filter(f => f.severity === 'Critical').length,
    high: findings.filter(f => f.severity === 'High').length,
    medium: findings.filter(f => f.severity === 'Medium').length,
    low: findings.filter(f => f.severity === 'Low').length,
    informational: findings.filter(f => f.severity === 'Informational').length,
};

// Build copy-for-agent text: structured markdown of all findings
function buildAgentClipboardText(): string {
    if (findings.length === 0) return '';
    const targetUrl = (wf?.input as any)?.webUrl || (wf?.input as any)?.repoPath || 'Unknown target';
    let text = `# Security Findings from Donna Pentest\n\n`;
    text += `**Target:** ${targetUrl}\n`;
    text += `**Scan Date:** ${wf?.startTime ? new Date(wf.startTime).toISOString().split('T')[0] : 'Unknown'}\n`;
    text += `**Total Findings:** ${findings.length} (${findingCounts.critical}C ${findingCounts.high}H ${findingCounts.medium}M ${findingCounts.low}L)\n\n`;
    text += `---\n\n`;

    for (const f of findings) {
        text += `## [${f.severity.toUpperCase()}] ${f.id}: ${f.title}\n\n`;
        if (f.location) text += `**Location:** ${f.location}\n`;
        text += `**Category:** ${f.category}\n`;
        if (f.summary) text += `**Summary:** ${f.summary}\n`;
        text += `\n`;
        if (f.evidenceSnippet) {
            text += `${f.evidenceSnippet}\n\n`;
        }
        text += `---\n\n`;
    }

    text += `\nPlease fix these vulnerabilities. Start with Critical and High severity issues.\n`;
    return text;
}

const agentClipboardText = buildAgentClipboardText();

const isFailed = wf?.status === 'failed' || sessionData?.session?.status === 'failed';
const completedCount = progress?.completedAgents?.length || agents.filter(a => a.success).length;
const totalCost = '$' + (progress?.summary?.totalCostUsd ?? sessionData?.metrics?.total_cost_usd ?? 0).toFixed(2);
const totalDurationSec = Math.round((progress?.summary?.totalDurationMs ?? sessionData?.metrics?.total_duration_ms ?? 0) / 1000);
---

<Base title={`${wf?.workflowId || 'Workflow'} — Donna`}>
    <div class="app-shell">
        <Sidebar activePage="workflows" />

        <header class="topbar">
            <div class="topbar-left">
                <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Open menu">☰</button>
                <div class="topbar-breadcrumb">
                    <a href="/">Workflows</a>
                    <span class="topbar-breadcrumb-sep">/</span>
                    <span style="color: var(--white); font-weight: 600; font-family: var(--font-mono); font-size: 0.8rem;">
                        {wf?.workflowId || runId?.slice(0, 12) + '…'}
                    </span>
                </div>
            </div>
            <div class="topbar-right">
                <span class="version-badge">v{donnaVersion}</span>
                <button class="btn-icon" title="Refresh" onclick="location.reload()">↻</button>
            </div>
        </header>

        <main class="main-content">
            <div class="wf-detail-container">
                {loadError && (
                    <div class="banner banner-error">⚠ {loadError}</div>
                )}

                {!wf ? (
                    <div class="table-container" style="margin: 2rem;">
                        <div class="empty-state">
                            <div class="empty-state-icon">🔍</div>
                            <h3>Workflow not found</h3>
                            <p>No workflow with run ID <code>{runId}</code></p>
                            <a href="/" class="btn btn-secondary" style="margin-top: 1rem;">← Back</a>
                        </div>
                    </div>
                ) : (
                    <div>
                        {/* ── Workflow Header ─────────────────────────── */}
                        <div class="wf-header">
                            <div class="wf-header-top">
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <a href="/" class="wf-back">← Back to Workflows</a>
                                </div>
                                <div class="wf-header-actions">
                                    {findings.length > 0 && (
                                        <a href={`/workflow/${runId}/report`} class="btn btn-primary" target="_blank">
                                            View Report
                                        </a>
                                    )}
                                    {wf.status === 'running' && (
                                        <button class="btn btn-danger" id="cancelBtn"
                                            data-workflow-id={wf.workflowId}
                                            data-run-id={wf.runId}>
                                            Request Cancellation
                                        </button>
                                    )}
                                    <div class="dropdown" id="moreActionsDropdown">
                                        <button class="btn btn-secondary" id="moreActionsBtn">
                                            More Actions ▾
                                        </button>
                                        <div class="dropdown-menu" id="moreActionsMenu">
                                            <button class="dropdown-item" data-action="start-new"
                                                data-workflow-id={wf.workflowId} data-run-id={wf.runId}>
                                                <span class="dropdown-item-icon">🚀</span>
                                                Start New
                                            </button>
                                            <button class="dropdown-item" data-action="restart"
                                                data-workflow-id={wf.workflowId} data-run-id={wf.runId}>
                                                <span class="dropdown-item-icon">🔄</span>
                                                Restart
                                            </button>
                                            <button class="dropdown-item" data-action="terminate"
                                                data-workflow-id={wf.workflowId} data-run-id={wf.runId}>
                                                <span class="dropdown-item-icon">⛔</span>
                                                Terminate
                                            </button>
                                            <button class="dropdown-item" data-action="signal"
                                                data-workflow-id={wf.workflowId} data-run-id={wf.runId}>
                                                <span class="dropdown-item-icon">📡</span>
                                                Send Signal
                                            </button>
                                            <div class="dropdown-divider"></div>
                                            <a class="dropdown-item" href={`http://localhost:8233/namespaces/default/workflows/${encodeURIComponent(wf.workflowId)}/${wf.runId}/history`} target="_blank">
                                                <span class="dropdown-item-icon">🔗</span>
                                                Open in Temporal UI
                                            </a>
                                            <button class="dropdown-item" data-action="copy-id"
                                                data-copy-value={wf.workflowId}>
                                                <span class="dropdown-item-icon">📋</span>
                                                Copy Workflow ID
                                            </button>
                                            <button class="dropdown-item" data-action="copy-runid"
                                                data-copy-value={wf.runId}>
                                                <span class="dropdown-item-icon">📋</span>
                                                Copy Run ID
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="wf-header-title">
                                <span class={`status-pill ${wf.status}`}>
                                    <span class={`status-dot ${wf.status === 'running' ? 'pulse' : ''}`}></span>
                                    {wf.status.charAt(0).toUpperCase() + wf.status.slice(1)}
                                </span>
                                <h1>{wf.workflowId}</h1>
                            </div>

                            {/* Info row like Temporal */}
                            <div class="wf-info-row">
                                {(wf.input as any)?.webUrl && (
                                    <div class="wf-info-item">
                                        <span class="wf-info-label">Target</span>
                                        <span class="wf-info-value">
                                            <a href={(wf.input as any).webUrl} target="_blank" rel="noopener noreferrer" class="target-link">
                                                {(wf.input as any).webUrl}
                                                <span class="target-link-icon">↗</span>
                                            </a>
                                        </span>
                                    </div>
                                )}
                                {(wf.input as any)?.modelProfile && (
                                    <div class="wf-info-item">
                                        <span class="wf-info-label">Model</span>
                                        <span class="wf-info-value">
                                            <span class={`model-badge ${(wf.input as any).modelProfile === 'claude' ? 'model-claude' : (wf.input as any).modelProfile === 'qwen-local' ? 'model-qwen' : (wf.input as any).modelProfile === 'hybrid' ? 'model-hybrid' : 'model-custom'}`}>
                                                {(wf.input as any).modelProfile}
                                            </span>
                                        </span>
                                    </div>
                                )}
                                <div class="wf-info-item">
                                    <span class="wf-info-label">Start</span>
                                    <span class="wf-info-value">{formatDateTime(wf.startTime)}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">End</span>
                                    <span class="wf-info-value">{formatDateTime(wf.closeTime)}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">Duration</span>
                                    <span class="wf-info-value">{getElapsed(wf.startTime, wf.closeTime)}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">Run ID</span>
                                    <span class="wf-info-value mono copyable" data-copy={wf.runId}>
                                        {wf.runId}
                                        <button class="copy-btn" title="Copy">📋</button>
                                    </span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">Workflow Type</span>
                                    <span class="wf-info-value link">{wf.type}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">Task Queue</span>
                                    <span class="wf-info-value link">{wf.taskQueue}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">History Events</span>
                                    <span class="wf-info-value">{wf.historySize}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">State Transitions</span>
                                    <span class="wf-info-value">{wf.historyLength}</span>
                                </div>
                                {(wf.input as any)?.parentRunId && (
                                    <div class="wf-info-item">
                                        <span class="wf-info-label">Parent Run</span>
                                        <span class="wf-info-value">
                                            <a href={`/workflow/${(wf.input as any).parentRunId}`} class="parent-run-link">
                                                {(wf.input as any).parentRunId.substring(0, 8)}…
                                                <span class="target-link-icon">↗</span>
                                            </a>
                                        </span>
                                    </div>
                                )}
                            </div>
                        </div>

                        {/* ── Failure Summary ─────────────────────────── */}
                        {isFailed && failedAgents.length > 0 && (
                            <div class="failure-summary">
                                <div class="failure-summary-header">
                                    <span class="failure-summary-icon">&#x26A0;</span>
                                    <div>
                                        <h3>Workflow Failed</h3>
                                        <p class="failure-summary-subtitle">
                                            {failedAgents.length} agent{failedAgents.length !== 1 ? 's' : ''} failed
                                            {progress?.failedAgent ? ` — pipeline stopped at ${progress.failedAgent}` : ''}
                                        </p>
                                    </div>
                                </div>

                                <div class="failure-agents">
                                    {failedAgents.map((a) => (
                                        <div class="failure-agent-card">
                                            <div class="failure-agent-header">
                                                <span class="failure-agent-name">{a.agentName}</span>
                                                <span class="failure-meta-tag">{a.model}</span>
                                            </div>
                                            {a.lastError && (
                                                <pre class="failure-error-text">{a.lastError}</pre>
                                            )}
                                            {a.failedAttempts.length > 1 && (
                                                <details class="failure-attempts-details">
                                                    <summary>View all {a.failedAttempts.length} attempts</summary>
                                                    <div class="failure-attempts-list">
                                                        {a.failedAttempts.map((att: any) => (
                                                            <div class="failure-attempt">
                                                                <div class="failure-attempt-header">
                                                                    <span>Attempt #{att.attempt_number}</span>
                                                                    <span class="failure-attempt-time">{att.formattedTime}</span>
                                                                    <span class="failure-attempt-duration">{att.durationSec}s</span>
                                                                </div>
                                                                {att.error && <pre class="failure-error-text small">{att.error}</pre>}
                                                            </div>
                                                        ))}
                                                    </div>
                                                </details>
                                            )}
                                        </div>
                                    ))}
                                </div>

                                {phaseEntries.length > 0 && (
                                    <div class="failure-phases">
                                        <h4>Phase Breakdown</h4>
                                        <div class="phase-bar-container">
                                            {phaseEntries.map((p) => (
                                                <div class="phase-bar-segment" style={`flex: ${p.pct}`} title={p.title}>
                                                    <span class="phase-bar-label">{p.name}</span>
                                                </div>
                                            ))}
                                        </div>
                                        <div class="phase-legend">
                                            {phaseEntries.map((p) => (
                                                <div class="phase-legend-item">
                                                    <span class="phase-legend-dot"></span>
                                                    <span class="phase-legend-name">{p.name}</span>
                                                    <span class="phase-legend-stats">{p.durationMin}m · {p.costFormatted}</span>
                                                </div>
                                            ))}
                                        </div>
                                    </div>
                                )}
                            </div>
                        )}

                        {/* ── Findings Panel ─────────────────────────── */}
                        {findings.length > 0 && (
                            <div class="findings-panel">
                                <div class="findings-header">
                                    <div class="findings-header-left">
                                        <h2 class="findings-title">Security Findings</h2>
                                        <div class="findings-badges">
                                            {findingCounts.critical > 0 && (
                                                <span class="finding-count-badge severity-critical">{findingCounts.critical}C</span>
                                            )}
                                            {findingCounts.high > 0 && (
                                                <span class="finding-count-badge severity-high">{findingCounts.high}H</span>
                                            )}
                                            {findingCounts.medium > 0 && (
                                                <span class="finding-count-badge severity-medium">{findingCounts.medium}M</span>
                                            )}
                                            {findingCounts.low > 0 && (
                                                <span class="finding-count-badge severity-low">{findingCounts.low}L</span>
                                            )}
                                            {findingCounts.informational > 0 && (
                                                <span class="finding-count-badge severity-info">{findingCounts.informational}I</span>
                                            )}
                                            <span class="findings-total">{findings.length} total</span>
                                            {hasParentComparison && fixedFindingsCount > 0 && (
                                                <span class="finding-count-badge comparison-fixed-badge" title="Findings fixed since parent run">{fixedFindingsCount} fixed</span>
                                            )}
                                        </div>
                                    </div>
                                    <div class="findings-actions">
                                        <div class="findings-view-toggle">
                                            <button class="btn btn-ghost btn-sm active" id="viewList" title="List view">List</button>
                                            <button class="btn btn-ghost btn-sm" id="viewGrid" title="Grid view">Grid</button>
                                        </div>
                                        <button class="btn btn-primary btn-copy-agent" id="copyForAgentBtn"
                                            data-clipboard={agentClipboardText}>
                                            Copy All for Agent
                                        </button>
                                    </div>
                                </div>

                                {/* ── List View (default, compact) ── */}
                                <div class="findings-list-view" id="findingsListView">
                                    <div class="findings-table">
                                        <div class="findings-table-header">
                                            <span class="ft-col-sev">Severity</span>
                                            <span class="ft-col-id">ID</span>
                                            <span class="ft-col-title">Finding</span>
                                            <span class="ft-col-cat">Category</span>
                                            <span class="ft-col-loc">Location</span>
                                            <span class="ft-col-act"></span>
                                        </div>
                                        {findings.map((f, idx) => (
                                            <div class="findings-table-row" data-finding-idx={idx}>
                                                <span class="ft-col-sev">
                                                    <span class={`fsev-dot ${f.severity.toLowerCase()}`}></span>
                                                    <span class={`fsev-label ${f.severity.toLowerCase()}`}>{f.severity}</span>
                                                </span>
                                                <span class="ft-col-id">
                                                    {f.id}
                                                    {hasParentComparison && findingComparisonMap.get(f.id) === 'still-present' && (
                                                        <span class="comparison-badge-sm still-present" title="Also found in previous run">Recurring</span>
                                                    )}
                                                    {hasParentComparison && findingComparisonMap.get(f.id) === 'new' && (
                                                        <span class="comparison-badge-sm new" title="New in this run">New</span>
                                                    )}
                                                </span>
                                                <span class="ft-col-title finding-row-title">{f.title}</span>
                                                <span class="ft-col-cat">
                                                    <span class="finding-category-tag">{f.category.toUpperCase()}</span>
                                                </span>
                                                <span class="ft-col-loc">
                                                    {f.location ? <code class="finding-loc-code">{f.location.length > 40 ? f.location.slice(0, 40) + '...' : f.location}</code> : <span class="text-faint">-</span>}
                                                </span>
                                                <span class="ft-col-act">
                                                    <button class="btn btn-ghost btn-xs finding-copy-btn"
                                                        data-finding-text={`## [${f.severity.toUpperCase()}] ${f.id}: ${f.title}\n\n${f.location ? `**Location:** ${f.location}\n` : ''}**Category:** ${f.category}\n${f.summary ? `**Summary:** ${f.summary}\n` : ''}\n${f.evidenceSnippet}\n`}
                                                        title="Copy this finding">
                                                        Copy
                                                    </button>
                                                </span>
                                            </div>
                                        ))}
                                    </div>
                                </div>

                                {/* ── Grid View ── */}
                                <div class="findings-grid-view" id="findingsGridView" style="display: none;">
                                    <div class="findings-grid">
                                        {findings.map((f, idx) => (
                                            <div class={`fgrid-card severity-accent-${f.severity.toLowerCase()}`}
                                                 data-finding-idx={idx}>
                                                <div class="fgrid-card-top">
                                                    <span class={`fsev-dot ${f.severity.toLowerCase()}`}></span>
                                                    <span class="fgrid-id">{f.id}</span>
                                                    <span class="finding-category-tag">{f.category.toUpperCase()}</span>
                                                </div>
                                                <div class="fgrid-title">{f.title}</div>
                                                {f.location && (
                                                    <code class="fgrid-loc">{f.location.length > 50 ? f.location.slice(0, 50) + '...' : f.location}</code>
                                                )}
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        )}

                        {/* ── Finding Detail Modal ─────────────────── */}
                        <div class="finding-modal-overlay" id="findingModal">
                            <div class="finding-modal">
                                <div class="finding-modal-header">
                                    <div class="finding-modal-header-left">
                                        <span class="finding-severity-pill" id="modalSeverity"></span>
                                        <span class="finding-modal-id" id="modalId"></span>
                                        <span class="finding-category-tag" id="modalCategory"></span>
                                    </div>
                                    <div class="finding-modal-header-right">
                                        <button class="btn btn-ghost btn-sm" id="modalCopyBtn">Copy</button>
                                        <button class="finding-modal-close" id="modalClose">&times;</button>
                                    </div>
                                </div>
                                <h2 class="finding-modal-title" id="modalTitle"></h2>
                                <div class="finding-modal-location" id="modalLocation"></div>
                                <div class="finding-modal-body">
                                    <div class="finding-modal-section" id="modalSummarySection">
                                        <h4>Summary</h4>
                                        <div class="finding-modal-summary" id="modalSummary"></div>
                                    </div>
                                    <div class="finding-modal-section" id="modalEvidenceSection">
                                        <h4>Evidence</h4>
                                        <pre class="finding-modal-evidence" id="modalEvidence"></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {/* Hidden data for modal JS */}
                        <script id="findingsData" type="application/json" set:html={JSON.stringify(findings)}></script>

                        {/* ── Tab Navigation ─────────────────────────── */}
                        <div class="wf-tabs">
                            <button class="wf-tab active" data-tab="history">
                                History <span class="wf-tab-badge">{wf.historySize}</span>
                            </button>
                            {wf.parentExecution && (
                                <button class="wf-tab" data-tab="relationships">
                                    Relationships
                                </button>
                            )}
                            {progress && (
                                <button class="wf-tab" data-tab="progress">
                                    Progress <span class="wf-tab-badge">{agents.length}</span>
                                </button>
                            )}
                            {wf.status === 'running' && (
                                <button class="wf-tab" data-tab="live-logs">
                                    Live Logs <span class="wf-tab-badge live-badge">LIVE</span>
                                </button>
                            )}
                            {wf.pendingActivities > 0 && (
                                <button class="wf-tab" data-tab="pending">
                                    Pending Activities <span class="wf-tab-badge">{wf.pendingActivities}</span>
                                </button>
                            )}
                            <button class="wf-tab" data-tab="input">Input / Result</button>
                            <button class="wf-tab" data-tab="query">Queries</button>
                            <button class="wf-tab" data-tab="search-attrs">Search Attributes</button>
                            <button class="wf-tab" data-tab="memo">Memo</button>
                            <button class="wf-tab" data-tab="visualization">
                                Visualization
                                {wf.status === 'running' && (
                                    <span class="wf-tab-badge live-badge">LIVE</span>
                                )}
                            </button>
                        </div>

                        {/* ── Tab: History ─────────────────────────── */}
                        <div class="wf-tab-content active" id="tab-history">
                            <div class="history-toolbar">
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <span style="font-size: 0.78rem; color: var(--text-dim);">
                                        {events.length} events
                                    </span>
                                    {wf.status === 'running' && (
                                        <label class="auto-refresh-toggle">
                                            <input type="checkbox" id="autoRefreshToggle" />
                                            <span class="toggle-slider"></span>
                                            <span class="toggle-label">Auto Refresh</span>
                                        </label>
                                    )}
                                </div>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <button class="btn btn-ghost btn-sm active" id="toggleCompact" data-view="compact">Compact</button>
                                    <button class="btn btn-ghost btn-sm" id="toggleTable" data-view="table">Table</button>
                                    <button class="btn btn-ghost btn-sm" id="toggleJson" data-view="json">JSON</button>
                                    <div class="toolbar-divider" style="height: 18px;"></div>
                                    <button class="btn btn-ghost btn-sm" id="sortAsc" title="Ascending">↑ Asc</button>
                                    <button class="btn btn-ghost btn-sm active" id="sortDesc" title="Descending">↓ Desc</button>
                                    <div class="toolbar-divider" style="height: 18px;"></div>
                                    <button class="btn btn-ghost btn-sm" id="downloadHistory" title="Download history">⬇ Download</button>
                                </div>
                            </div>

                            {/* Compact timeline view (default) */}
                            <div class="history-timeline" id="historyCompact">
                                {events.map((ev) => (
                                    <div class={`history-event ${ev.category}`} data-event-id={ev.eventId}>
                                        <div class="history-event-marker">
                                            <div class={`history-event-dot ${ev.category}`}></div>
                                            {ev.eventId < events.length && <div class="history-event-line"></div>}
                                        </div>
                                        <div class="history-event-content">
                                            <div class="history-event-header">
                                                <span class="history-event-id">#{ev.eventId}</span>
                                                <span class={`history-event-type ${ev.category}`}>{ev.eventType}</span>
                                                {Object.entries(ev.details).length > 0 && (
                                                    <span class="history-event-details">
                                                        {Object.entries(ev.details).map(([k, v]) => (
                                                            <span class="history-detail-tag">
                                                                <span class="detail-key">{k}:</span> {v}
                                                            </span>
                                                        ))}
                                                    </span>
                                                )}
                                                <span class="history-event-time">{formatEventTime(ev.eventTime)}</span>
                                            </div>
                                        </div>
                                    </div>
                                ))}
                            </div>

                            {/* Table view */}
                            <div class="history-table-view" id="historyTable" style="display: none;">
                                <div class="table-container">
                                  <div class="table-scroll-wrapper">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th style="width: 60px;">Event ID</th>
                                                <th>Timestamp</th>
                                                <th>Event Type</th>
                                                <th>Details</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {events.map((ev) => (
                                                <tr>
                                                    <td class="cell-duration">#{ev.eventId}</td>
                                                    <td class="cell-time">{formatEventTime(ev.eventTime)}</td>
                                                    <td>
                                                        <span class={`event-type-badge ${ev.category}`}>
                                                            {ev.eventType}
                                                        </span>
                                                    </td>
                                                    <td class="cell-type">
                                                        {Object.entries(ev.details).map(([k, v]) => (
                                                            <span class="history-detail-tag">
                                                                <span class="detail-key">{k}:</span> {v}
                                                            </span>
                                                        ))}
                                                    </td>
                                                </tr>
                                            ))}
                                        </tbody>
                                    </table>
                                  </div>
                                </div>
                            </div>

                            {/* JSON view */}
                            <div id="historyJson" style="display: none;">
                                <pre class="json-viewer"><code>{JSON.stringify(events, null, 2)}</code></pre>
                            </div>

                            {events.length === 0 && (
                                <div class="empty-state" style="padding: 3rem;">
                                    <div class="empty-state-icon">📜</div>
                                    <h3>No history events</h3>
                                    <p>History events will appear here as the workflow executes.</p>
                                </div>
                            )}
                        </div>

                        {/* ── Tab: Relationships ─────────────────────── */}
                        {wf.parentExecution && (
                            <div class="wf-tab-content" id="tab-relationships">
                                <div class="json-section">
                                    <h3>Parent Workflow</h3>
                                    <div class="relationship-card">
                                        <div class="relationship-item">
                                            <span class="wf-info-label">Workflow ID</span>
                                            <a href={`/workflow/${wf.parentExecution.runId}`} class="wf-info-value link">
                                                {wf.parentExecution.workflowId}
                                            </a>
                                        </div>
                                        <div class="relationship-item">
                                            <span class="wf-info-label">Run ID</span>
                                            <span class="wf-info-value mono">{wf.parentExecution.runId}</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        )}

                        {/* ── Tab: Progress (Agent Metrics) ─────────── */}
                        {progress && (
                            <div class="wf-tab-content" id="tab-progress">
                                {/* Progress bar */}
                                <div class="progress-card">
                                    <div class="progress-card-header">
                                        <span>Pipeline Progress</span>
                                        <span class="mono" style="color: var(--text-muted);">
                                            {progress.completedAgents?.length || 0} / 13 agents
                                        </span>
                                    </div>
                                    <div class="progress-bar" style="height: 8px; margin: 0.75rem 0;">
                                        <div class="progress-bar-fill" style={`width: ${((progress.completedAgents?.length || 0) / 13) * 100}%`}></div>
                                    </div>
                                    <div style="display: flex; gap: 1.5rem; font-size: 0.8rem;">
                                        {progress.currentPhase && (
                                            <span style="color: var(--text-dim);">
                                                Phase: <strong style="color: var(--info);">{progress.currentPhase}</strong>
                                            </span>
                                        )}
                                        {progress.currentAgent && (
                                            <span style="color: var(--text-dim);">
                                                Agent: <strong style="color: var(--info);">{progress.currentAgent}</strong>
                                            </span>
                                        )}
                                    </div>
                                </div>

                                {/* Agent table */}
                                {agents.length > 0 && (
                                    <div class="table-container" style="margin-top: 1rem;">
                                      <div class="table-scroll-wrapper">
                                        <table class="data-table">
                                            <thead>
                                                <tr>
                                                    <th>Status</th>
                                                    <th>Agent</th>
                                                    <th>Model</th>
                                                    <th>Turns</th>
                                                    <th>Cost</th>
                                                    <th>Duration</th>
                                                    <th>Attempts</th>
                                                    <th>Error</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {agents.map((a) => (
                                                    <tr class={a.hasFailed && a.lastError ? 'row-failed' : ''}>
                                                        <td>
                                                            <span class={`status-pill ${a.statusClass}`}>
                                                                <span class={`status-dot ${a.statusClass === 'running' ? 'pulse' : ''}`}></span>
                                                                {a.statusLabel}
                                                            </span>
                                                        </td>
                                                        <td style="font-weight: 600; color: var(--white);">{a.agentName}</td>
                                                        <td class="cell-type">{a.model}</td>
                                                        <td class="cell-duration">{a.turns}</td>
                                                        <td class="cell-cost">${a.costUsd.toFixed(3)}</td>
                                                        <td class="cell-duration">{a.durationMs > 0 ? Math.round(a.durationMs / 1000) + 's' : '—'}</td>
                                                        <td class="cell-duration">
                                                            {a.attemptCount > 0 ? (
                                                                <span class={a.failedAttemptCount > 0 ? 'attempts-badge has-failures' : 'attempts-badge'}>
                                                                    {a.attemptCount}
                                                                </span>
                                                            ) : '—'}
                                                        </td>
                                                        <td class="cell-error">
                                                            {a.errorPreview ? (
                                                                <details class="inline-error-details">
                                                                    <summary class="inline-error-summary">{a.errorPreview}</summary>
                                                                    <pre class="inline-error-full">{a.lastError}</pre>
                                                                </details>
                                                            ) : '—'}
                                                        </td>
                                                    </tr>
                                                ))}
                                            </tbody>
                                        </table>
                                      </div>
                                    </div>
                                )}

                                {/* Summary */}
                                {(progress.summary || sessionData?.metrics) && (
                                    <div class="summary-grid">
                                        <div class="summary-item">
                                            <span class="summary-label">Total Cost</span>
                                            <span class="summary-value">{totalCost}</span>
                                        </div>
                                        <div class="summary-item">
                                            <span class="summary-label">Total Duration</span>
                                            <span class="summary-value">{totalDurationSec}s</span>
                                        </div>
                                        {progress.summary && (
                                            <div class="summary-item">
                                                <span class="summary-label">Total Turns</span>
                                                <span class="summary-value">{progress.summary.totalTurns}</span>
                                            </div>
                                        )}
                                        <div class="summary-item">
                                            <span class="summary-label">Agent Count</span>
                                            <span class="summary-value">{progress.summary?.agentCount ?? agents.length}</span>
                                        </div>
                                    </div>
                                )}
                            </div>
                        )}

                        {/* ── Tab: Pending Activities ─────────────────── */}
                        {wf.pendingActivities > 0 && (
                            <div class="wf-tab-content" id="tab-pending">
                                <div class="table-container">
                                  <div class="table-scroll-wrapper">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>Activity Type</th>
                                                <th>Event ID</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {events
                                                .filter(ev => ev.eventType.toLowerCase().includes('activity task scheduled'))
                                                .map(ev => (
                                                    <tr>
                                                        <td style="font-weight: 500; color: var(--white);">
                                                            {ev.details['Activity Type'] || 'Unknown'}
                                                        </td>
                                                        <td class="cell-duration">#{ev.eventId}</td>
                                                        <td>
                                                            {events.some(e =>
                                                                (e.eventType.toLowerCase().includes('activity task completed') ||
                                                                 e.eventType.toLowerCase().includes('activity task failed')) &&
                                                                e.details['Scheduled Event'] === `#${ev.eventId}`
                                                            ) ? (
                                                                <span class="status-pill completed"><span class="status-dot"></span> Done</span>
                                                            ) : (
                                                                <span class="status-pill running"><span class="status-dot pulse"></span> Pending</span>
                                                            )}
                                                        </td>
                                                    </tr>
                                                ))
                                            }
                                        </tbody>
                                    </table>
                                  </div>
                                </div>
                            </div>
                        )}

                        {/* ── Tab: Live Logs ────────────────────────── */}
                        {wf.status === 'running' && (
                            <div class="wf-tab-content" id="tab-live-logs">
                                <div class="live-logs-header">
                                    <div class="live-logs-status">
                                        <span class="live-dot pulse"></span>
                                        <span class="live-label">Streaming agent turns</span>
                                        <span class="live-agent" id="liveAgent">—</span>
                                    </div>
                                    <div class="live-logs-controls">
                                        <span class="live-phase" id="livePhase"></span>
                                        <span class="live-elapsed" id="liveElapsed">—</span>
                                        <label class="auto-scroll-toggle">
                                            <input type="checkbox" id="showTimestampsToggle" />
                                            <span class="toggle-slider"></span>
                                            <span class="toggle-label">Timestamps</span>
                                        </label>
                                        <label class="auto-scroll-toggle">
                                            <input type="checkbox" id="autoScrollToggle" checked />
                                            <span class="toggle-slider"></span>
                                            <span class="toggle-label">Auto-scroll</span>
                                        </label>
                                    </div>
                                </div>
                                <!-- Pipeline progress stages -->
                                <div class="live-pipeline-progress" id="livePipelineProgress">
                                    <div class="pipeline-stage completed" data-stage="preflight"><span class="stage-dot"></span><span class="stage-label">Preflight</span></div>
                                    <div class="pipeline-connector"></div>
                                    <div class="pipeline-stage" data-stage="pre-recon"><span class="stage-dot"></span><span class="stage-label">Pre-Recon</span></div>
                                    <div class="pipeline-connector"></div>
                                    <div class="pipeline-stage" data-stage="recon"><span class="stage-dot"></span><span class="stage-label">Recon</span></div>
                                    <div class="pipeline-connector"></div>
                                    <div class="pipeline-stage" data-stage="vuln-analysis"><span class="stage-dot"></span><span class="stage-label">Vuln Analysis</span></div>
                                    <div class="pipeline-connector"></div>
                                    <div class="pipeline-stage" data-stage="exploitation"><span class="stage-dot"></span><span class="stage-label">Exploitation</span></div>
                                    <div class="pipeline-connector"></div>
                                    <div class="pipeline-stage" data-stage="report"><span class="stage-dot"></span><span class="stage-label">Report</span></div>
                                </div>
                                <!-- Live metrics bar -->
                                <div class="live-metrics-bar">
                                    <div class="live-metric">
                                        <span class="live-metric-label">Turns</span>
                                        <span class="live-metric-value" id="liveTurnCount">0</span>
                                    </div>
                                    <div class="live-metric">
                                        <span class="live-metric-label">Model</span>
                                        <span class="live-metric-value" id="liveModel">—</span>
                                    </div>
                                    <div class="live-metric">
                                        <span class="live-metric-label">Agents Done</span>
                                        <span class="live-metric-value" id="liveAgentsDone">0/?</span>
                                    </div>
                                    <div class="live-metric">
                                        <span class="live-metric-label">Attempt</span>
                                        <span class="live-metric-value" id="liveAttempt">1</span>
                                    </div>
                                </div>
                                <div class="live-logs-viewer" id="liveLogsViewer">
                                    <div class="live-logs-empty" id="liveLogsEmpty">
                                        Waiting for agent turn data...
                                    </div>
                                </div>
                            </div>
                        )}

                        {/* ── Tab: Input / Result ─────────────────────── */}
                        <div class="wf-tab-content" id="tab-input">
                            <div class="json-section">
                                <div class="json-section-header">
                                    <h3>Input</h3>
                                    {wf.input && (
                                        <button class="btn btn-ghost btn-sm copy-json-btn" data-json={JSON.stringify(wf.input, null, 2)}>
                                            📋 Copy
                                        </button>
                                    )}
                                </div>
                                <pre class="json-viewer"><code>{wf.input ? JSON.stringify(wf.input, null, 2) : '(no input captured)'}</code></pre>
                            </div>
                            <div class="json-section">
                                <div class="json-section-header">
                                    <h3>Result</h3>
                                    {wf.result && (
                                        <button class="btn btn-ghost btn-sm copy-json-btn" data-json={JSON.stringify(wf.result, null, 2)}>
                                            📋 Copy
                                        </button>
                                    )}
                                </div>
                                <pre class="json-viewer"><code>{wf.result ? JSON.stringify(wf.result, null, 2) : wf.status === 'running' ? '(workflow still running)' : '(no result)'}</code></pre>
                            </div>
                        </div>

                        {/* ── Tab: Queries ─────────────────────────── */}
                        <div class="wf-tab-content" id="tab-query">
                            <div class="query-panel">
                                <div class="query-form">
                                    <div>
                                        <label class="query-label">Query Type</label>
                                        <select class="query-select" id="queryType">
                                            <option value="getProgress">getProgress</option>
                                            <option value="__stack_trace">__stack_trace</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="query-label">Query Arg</label>
                                        <textarea class="query-input" id="queryArg" rows="3" placeholder="(only single JSON payload supported)"></textarea>
                                    </div>
                                    <button class="btn btn-primary" id="runQueryBtn" data-workflow-id={wf.workflowId} data-run-id={wf.runId}>
                                        Run Query
                                    </button>
                                </div>
                                <div class="query-result">
                                    <h3>Result</h3>
                                    <pre class="json-viewer" id="queryResult"><code>Run a query to see results</code></pre>
                                </div>
                            </div>
                        </div>

                        {/* ── Tab: Search Attributes ─────────────────── */}
                        <div class="wf-tab-content" id="tab-search-attrs">
                            <div class="json-section">
                                <h3>Search Attributes</h3>
                                <pre class="json-viewer"><code>{Object.keys(wf.searchAttributes || {}).length > 0 ? JSON.stringify(wf.searchAttributes, null, 2) : '(no search attributes set)'}</code></pre>
                            </div>
                        </div>

                        {/* ── Tab: Memo ─────────────────────────── */}
                        <div class="wf-tab-content" id="tab-memo">
                            <div class="json-section">
                                <h3>Memo</h3>
                                <pre class="json-viewer"><code>{Object.keys(wf.memo || {}).length > 0 ? JSON.stringify(wf.memo, null, 2) : '(no memo set)'}</code></pre>
                            </div>
                        </div>

                        {/* ── Tab: Visualization ─────────────────────── */}
                        <div class="wf-tab-content" id="tab-visualization">
                            <div class="viz-container" id="vizContainer">
                                <div class="viz-ripple-overlay" id="vizRippleOverlay"></div>
                                {/* Top-left info */}
                                <div class="viz-info">
                                    <div class="viz-info-title">{wf.workflowId}</div>
                                    <div class="viz-info-subtitle">{events.length} events · {agents.length} agents</div>
                                </div>
                                {/* Top-right mode toggle */}
                                {wf.status === 'running' && (
                                    <div class="viz-mode-toggle" id="vizModeToggle">
                                        <button class="viz-mode-btn active" data-mode="history">History</button>
                                        <button class="viz-mode-btn" data-mode="live">Live</button>
                                    </div>
                                )}
                                {/* Catchup progress indicator (shown during fast-forward replay) */}
                                <div class="viz-catchup-bar" id="vizCatchupBar" style="display:none;">
                                    <div class="viz-catchup-inner">
                                        <span class="viz-catchup-icon">&#9654;&#9654;</span>
                                        <span class="viz-catchup-text">Replaying recent activity...</span>
                                        <div class="viz-catchup-progress">
                                            <div class="viz-catchup-fill" id="vizCatchupFill"></div>
                                        </div>
                                    </div>
                                </div>
                                {/* Bottom: Live status panel (shown in live mode) */}
                                <div class="viz-live-panel" id="vizLivePanel" style={wf.status !== 'running' ? 'display:none' : ''}>
                                    <span class="viz-live-dot pulse" id="vizLiveDot"></span>
                                    <span class="viz-live-label">Live</span>
                                    <span class="viz-live-agent" id="vizLiveAgent">waiting...</span>
                                    <span class="viz-live-sep">·</span>
                                    <span class="viz-live-count"><span id="vizLiveCount">0</span> events</span>
                                    <span id="vizLiveStatus" class="viz-live-status"></span>
                                    <button class="viz-btn viz-btn-sm" id="vizResetBtn" title="Clear">↺ Clear</button>
                                </div>
                                {/* Bottom: History controls (shown in history mode) */}
                                <div class="viz-controls" id="vizHistoryControls">
                                    <button class="viz-btn" id="vizPlayBtn" title="Play / Pause">▶ Play</button>
                                    <button class="viz-btn" id="vizResetBtnHistory" title="Reset">↺ Reset</button>
                                    <label class="viz-speed-label">
                                        Speed
                                        <input type="range" id="vizSpeedSlider" min="1" max="20" value="5" class="viz-speed-slider" />
                                    </label>
                                </div>
                            </div>
                            <script id="vizEventsData" type="application/json" set:html={JSON.stringify(events.map(ev => ({
                                eventId: ev.eventId,
                                eventType: ev.eventType,
                                eventTime: ev.eventTime,
                                category: ev.category,
                                details: ev.details,
                            })))}></script>
                            <script id="vizAgentsData" type="application/json" set:html={JSON.stringify(agents.map(a => ({
                                agentName: a.agentName,
                                model: a.model,
                                statusLabel: a.statusLabel,
                                statusClass: a.statusClass,
                                turns: a.turns,
                                costUsd: a.costUsd,
                                durationMs: a.durationMs,
                            })))}></script>
                        </div>

                        {/* Error for failed workflows */}
                        {progress?.error && (
                            <div class="error-card">
                                <h3>Error</h3>
                                <pre class="error-pre">{progress.error}</pre>
                            </div>
                        )}
                    </div>
                )}
            </div>
        </main>
    </div>

    {/* Model Profile Picker Modal */}
    <div id="modelProfileModal" class="modal-overlay" style="display:none;">
        <div class="modal-dialog">
            <div class="modal-header">
                <h3>Start New Scan</h3>
                <button class="modal-close" id="modelProfileModalClose">&times;</button>
            </div>
            <div class="modal-body">
                <p style="margin-bottom: 1rem; color: var(--text-secondary);">
                    Choose a model profile for the new scan, or keep the original.
                </p>
                <div class="model-profile-options" id="modelProfileOptions">
                    <label class="model-option selected" data-profile="">
                        <input type="radio" name="modelProfile" value="" checked />
                        <span class="model-option-inner">
                            <span class="model-option-name">Same as original</span>
                            <span class="model-option-desc" id="originalProfileLabel">Use the same model profile as the parent workflow</span>
                        </span>
                    </label>
                    <label class="model-option" data-profile="claude">
                        <input type="radio" name="modelProfile" value="claude" />
                        <span class="model-option-inner">
                            <span class="model-option-name"><span class="model-badge model-claude">claude</span></span>
                            <span class="model-option-desc">Default Anthropic Claude models</span>
                        </span>
                    </label>
                    <label class="model-option" data-profile="qwen-local">
                        <input type="radio" name="modelProfile" value="qwen-local" />
                        <span class="model-option-inner">
                            <span class="model-option-name"><span class="model-badge model-qwen">qwen</span></span>
                            <span class="model-option-desc">Local Qwen models via vLLM (direct)</span>
                        </span>
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" id="modelProfileCancelBtn">Cancel</button>
                <button class="btn btn-primary" id="modelProfileStartBtn">Start Scan</button>
            </div>
        </div>
    </div>

    {/* Tab switching + Query runner + More Actions + History views */}
    <script is:inline>
        // ── Tab switching ──────────────────────────
        document.querySelectorAll('.wf-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.wf-tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.wf-tab-content').forEach(c => c.classList.remove('active'));
                tab.classList.add('active');
                const target = tab.dataset.tab;
                document.getElementById('tab-' + target)?.classList.add('active');
            });
        });

        // ── Copy buttons ──────────────────────────
        document.querySelectorAll('.copyable').forEach(el => {
            el.querySelector('.copy-btn')?.addEventListener('click', (e) => {
                e.stopPropagation();
                const text = el.dataset.copy || el.textContent;
                navigator.clipboard.writeText(text).then(() => {
                    const btn = el.querySelector('.copy-btn');
                    if (btn) { btn.textContent = '✓'; setTimeout(() => btn.textContent = '📋', 1500); }
                });
            });
        });

        // ── Copy JSON buttons ──────────────────────
        document.querySelectorAll('.copy-json-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const json = btn.dataset.json;
                if (json) {
                    navigator.clipboard.writeText(json).then(() => {
                        btn.textContent = '✓ Copied';
                        setTimeout(() => { btn.textContent = '📋 Copy'; }, 1500);
                    });
                }
            });
        });

        // ── Copy All for Agent ──────────────────────
        const copyAgentBtn = document.getElementById('copyForAgentBtn');
        if (copyAgentBtn) {
            copyAgentBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                const text = copyAgentBtn.dataset.clipboard;
                if (text) {
                    navigator.clipboard.writeText(text).then(() => {
                        copyAgentBtn.textContent = 'Copied!';
                        copyAgentBtn.classList.add('copied');
                        setTimeout(() => {
                            copyAgentBtn.textContent = 'Copy All for Agent';
                            copyAgentBtn.classList.remove('copied');
                        }, 2000);
                    });
                }
            });
        }

        // ── Individual finding copy (stop propagation) ──
        document.querySelectorAll('.finding-copy-btn').forEach(btn => {
            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                const text = btn.dataset.findingText;
                if (text) {
                    navigator.clipboard.writeText(text).then(() => {
                        btn.textContent = 'Copied!';
                        setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
                    });
                }
            });
        });

        // ── Findings view toggle (List / Grid) ──────────
        const viewListBtn = document.getElementById('viewList');
        const viewGridBtn = document.getElementById('viewGrid');
        const listView = document.getElementById('findingsListView');
        const gridView = document.getElementById('findingsGridView');
        if (viewListBtn && viewGridBtn && listView && gridView) {
            viewListBtn.addEventListener('click', () => {
                viewListBtn.classList.add('active');
                viewGridBtn.classList.remove('active');
                listView.style.display = '';
                gridView.style.display = 'none';
            });
            viewGridBtn.addEventListener('click', () => {
                viewGridBtn.classList.add('active');
                viewListBtn.classList.remove('active');
                gridView.style.display = '';
                listView.style.display = 'none';
            });
        }

        // ── Finding detail modal ──────────────────────
        (function initFindingModal() {
            const modal = document.getElementById('findingModal');
            const closeBtn = document.getElementById('modalClose');
            const dataEl = document.getElementById('findingsData');
            if (!modal || !dataEl) return;

            let findingsArr = [];
            try { findingsArr = JSON.parse(dataEl.textContent || '[]'); } catch {}

            function openModal(idx) {
                const f = findingsArr[idx];
                if (!f) return;

                const sevPill = document.getElementById('modalSeverity');
                sevPill.textContent = f.severity;
                sevPill.className = 'finding-severity-pill ' + f.severity.toLowerCase();

                document.getElementById('modalId').textContent = f.id;
                const catEl = document.getElementById('modalCategory');
                catEl.textContent = f.category.toUpperCase();

                document.getElementById('modalTitle').textContent = f.title;

                const locEl = document.getElementById('modalLocation');
                if (f.location) {
                    locEl.innerHTML = '<span class="finding-location-label">Location:</span> <code>' + f.location.replace(/</g, '&lt;') + '</code>';
                    locEl.style.display = '';
                } else {
                    locEl.style.display = 'none';
                }

                const summarySection = document.getElementById('modalSummarySection');
                const summaryEl = document.getElementById('modalSummary');
                if (f.summary) {
                    summaryEl.textContent = f.summary;
                    summarySection.style.display = '';
                } else {
                    summarySection.style.display = 'none';
                }

                const evidenceSection = document.getElementById('modalEvidenceSection');
                const evidenceEl = document.getElementById('modalEvidence');
                if (f.evidenceSnippet) {
                    evidenceEl.textContent = f.evidenceSnippet;
                    evidenceSection.style.display = '';
                } else {
                    evidenceSection.style.display = 'none';
                }

                // Copy button in modal
                const modalCopyBtn = document.getElementById('modalCopyBtn');
                modalCopyBtn.onclick = function(e) {
                    e.stopPropagation();
                    const text = '## [' + f.severity.toUpperCase() + '] ' + f.id + ': ' + f.title + '\n\n'
                        + (f.location ? '**Location:** ' + f.location + '\n' : '')
                        + '**Category:** ' + f.category + '\n'
                        + (f.summary ? '**Summary:** ' + f.summary + '\n' : '')
                        + '\n' + (f.evidenceSnippet || '') + '\n';
                    navigator.clipboard.writeText(text).then(() => {
                        modalCopyBtn.textContent = 'Copied!';
                        setTimeout(() => { modalCopyBtn.textContent = 'Copy'; }, 1500);
                    });
                };

                modal.classList.add('open');
                document.body.style.overflow = 'hidden';
            }

            function closeModal() {
                modal.classList.remove('open');
                document.body.style.overflow = '';
            }

            // Click handlers on rows and grid cards
            document.querySelectorAll('.findings-table-row, .fgrid-card').forEach(el => {
                el.addEventListener('click', (e) => {
                    // Don't open modal if clicking a button
                    if (e.target.closest('.finding-copy-btn')) return;
                    const idx = parseInt(el.dataset.findingIdx, 10);
                    openModal(idx);
                });
            });

            if (closeBtn) closeBtn.addEventListener('click', closeModal);
            modal.addEventListener('click', (e) => {
                if (e.target === modal) closeModal();
            });
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') closeModal();
            });
        })();

        // ── More Actions dropdown ──────────────────
        const moreBtn = document.getElementById('moreActionsBtn');
        const moreMenu = document.getElementById('moreActionsMenu');
        if (moreBtn && moreMenu) {
            moreBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                moreMenu.classList.toggle('open');
            });

            // Close on click outside
            document.addEventListener('click', () => {
                moreMenu.classList.remove('open');
            });

            moreMenu.addEventListener('click', (e) => {
                e.stopPropagation();
            });

            // Handle dropdown actions
            moreMenu.querySelectorAll('.dropdown-item').forEach(item => {
                item.addEventListener('click', async () => {
                    const action = item.dataset.action;
                    moreMenu.classList.remove('open');

                    if (action === 'copy-id' || action === 'copy-runid') {
                        const val = item.dataset.copyValue;
                        if (val) {
                            await navigator.clipboard.writeText(val);
                            const origText = item.innerHTML;
                            item.innerHTML = '<span class="dropdown-item-icon">✓</span> Copied!';
                            setTimeout(() => { item.innerHTML = origText; }, 1500);
                        }
                    } else if (action === 'start-new') {
                        // Show model profile picker modal
                        const modal = document.getElementById('modelProfileModal');
                        const startBtn = document.getElementById('modelProfileStartBtn');
                        const cancelBtn = document.getElementById('modelProfileCancelBtn');
                        const closeBtn = document.getElementById('modelProfileModalClose');
                        const originalLabel = document.getElementById('originalProfileLabel');

                        // Show the original model profile in the label
                        const wfInfoItems = document.querySelectorAll('.wf-info-item');
                        let currentProfile = '';
                        wfInfoItems.forEach(el => {
                            const label = el.querySelector('.wf-info-label');
                            if (label && label.textContent === 'Model') {
                                const badge = el.querySelector('.model-badge');
                                if (badge) currentProfile = badge.textContent.trim();
                            }
                        });
                        if (originalLabel) {
                            originalLabel.textContent = currentProfile
                                ? `Keep "${currentProfile}" from the parent workflow`
                                : 'Use default model (no profile was set)';
                        }

                        // Highlight selected option
                        document.querySelectorAll('.model-option').forEach(opt => {
                            opt.classList.remove('selected');
                            const radio = opt.querySelector('input[type="radio"]');
                            if (radio && radio.checked) opt.classList.add('selected');
                            opt.addEventListener('click', () => {
                                document.querySelectorAll('.model-option').forEach(o => o.classList.remove('selected'));
                                opt.classList.add('selected');
                                const r = opt.querySelector('input[type="radio"]');
                                if (r) r.checked = true;
                            });
                        });

                        modal.style.display = 'flex';

                        const closeModal = () => { modal.style.display = 'none'; };
                        cancelBtn.onclick = closeModal;
                        closeBtn.onclick = closeModal;
                        modal.onclick = (e) => { if (e.target === modal) closeModal(); };

                        startBtn.onclick = async () => {
                            const selected = document.querySelector('input[name="modelProfile"]:checked');
                            const selectedProfile = selected ? selected.value : '';
                            closeModal();
                            try {
                                const wfRunId = item.dataset.runId;
                                const fetchOptions = {
                                    method: 'POST',
                                    headers: { 'Content-Type': 'application/json' },
                                    body: JSON.stringify(selectedProfile ? { modelProfile: selectedProfile } : {}),
                                };
                                const res = await fetch('/api/workflow/' + wfRunId + '?action=start-new', fetchOptions);
                                const data = await res.json();
                                if (res.ok && data.newRunId) {
                                    window.location.href = '/workflow/' + data.newRunId;
                                } else {
                                    alert('Failed to start new workflow: ' + (data.error || 'Unknown error'));
                                }
                            } catch (err) {
                                alert('Error: ' + err.message);
                            }
                        };
                    } else if (action === 'restart') {
                        if (confirm('Restart this workflow with the same configuration?')) {
                            try {
                                const runId = item.dataset.runId;
                                const res = await fetch('/api/workflow/' + runId + '?action=restart', { method: 'POST' });
                                const data = await res.json();
                                if (res.ok && data.newRunId) {
                                    window.location.href = '/workflow/' + data.newRunId;
                                } else {
                                    alert('Failed to restart: ' + (data.error || 'Unknown error'));
                                }
                            } catch (err) {
                                alert('Error: ' + err.message);
                            }
                        }
                    } else if (action === 'terminate') {
                        if (confirm('Are you sure you want to terminate this workflow? This cannot be undone.')) {
                            try {
                                const runId = item.dataset.runId;
                                const res = await fetch('/api/workflow/' + runId + '?action=terminate', { method: 'POST' });
                                if (res.ok) {
                                    alert('Workflow terminated. Refreshing...');
                                    location.reload();
                                } else {
                                    alert('Failed to terminate: ' + (await res.text()));
                                }
                            } catch (err) {
                                alert('Error: ' + err.message);
                            }
                        }
                    } else if (action === 'signal') {
                        const signalName = prompt('Signal name:');
                        if (signalName) {
                            alert('Signal sending not yet implemented. Use Temporal CLI:\ntctl workflow signal --workflow-id ' + item.dataset.workflowId + ' --name ' + signalName);
                        }
                    }
                });
            });
        }

        // ── Request Cancellation button ──────────────
        const cancelBtn = document.getElementById('cancelBtn');
        if (cancelBtn) {
            cancelBtn.addEventListener('click', async () => {
                if (!confirm('Are you sure you want to cancel this workflow?')) return;
                try {
                    const runId = cancelBtn.dataset.runId;
                    const res = await fetch('/api/workflow/' + runId + '?action=cancel', { method: 'POST' });
                    if (res.ok) {
                        alert('Cancellation requested. Refreshing...');
                        location.reload();
                    } else {
                        alert('Failed to cancel: ' + (await res.text()));
                    }
                } catch (err) {
                    alert('Error: ' + err.message);
                }
            });
        }

        // ── History view switching ──────────────────
        const viewBtns = document.querySelectorAll('[data-view]');
        viewBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                viewBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const view = btn.dataset.view;
                document.getElementById('historyCompact').style.display = view === 'compact' ? '' : 'none';
                document.getElementById('historyTable').style.display = view === 'table' ? '' : 'none';
                document.getElementById('historyJson').style.display = view === 'json' ? '' : 'none';
            });
        });

        // ── Sort direction ──────────────────────────
        const sortAsc = document.getElementById('sortAsc');
        const sortDesc = document.getElementById('sortDesc');
        const timeline = document.getElementById('historyCompact');
        const tableBody = document.querySelector('#historyTable tbody');

        function reverseChildren(parent) {
            if (!parent) return;
            const children = Array.from(parent.children);
            children.reverse().forEach(c => parent.appendChild(c));
        }

        if (sortAsc && sortDesc) {
            sortAsc.addEventListener('click', () => {
                sortAsc.classList.add('active');
                sortDesc.classList.remove('active');
                reverseChildren(timeline);
                reverseChildren(tableBody);
            });
            sortDesc.addEventListener('click', () => {
                sortDesc.classList.add('active');
                sortAsc.classList.remove('active');
                reverseChildren(timeline);
                reverseChildren(tableBody);
            });
        }

        // ── Download history ──────────────────────
        document.getElementById('downloadHistory')?.addEventListener('click', () => {
            const jsonCode = document.querySelector('#historyJson code');
            if (jsonCode) {
                const blob = new Blob([jsonCode.textContent], { type: 'application/json' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'workflow-history.json';
                a.click();
                URL.revokeObjectURL(url);
            }
        });

        // ── Auto refresh ──────────────────────────
        let autoRefreshInterval = null;
        const autoRefreshToggle = document.getElementById('autoRefreshToggle');
        if (autoRefreshToggle) {
            autoRefreshToggle.addEventListener('change', () => {
                if (autoRefreshToggle.checked) {
                    autoRefreshInterval = setInterval(() => location.reload(), 5000);
                } else {
                    clearInterval(autoRefreshInterval);
                    autoRefreshInterval = null;
                }
            });
        }

        // ── Global Viz Event Bus ──────────────────────
        // Allows live logs polling to send events to the visualization tab
        window.__vizBus = {
            listeners: [],
            on: function(fn) { this.listeners.push(fn); },
            emit: function(ev) { this.listeners.forEach(function(fn) { fn(ev); }); },
        };

        // ── Live Logs Polling ──────────────────────
        (function initLiveLogs() {
            const viewer = document.getElementById('liveLogsViewer');
            const emptyMsg = document.getElementById('liveLogsEmpty');
            const agentLabel = document.getElementById('liveAgent');
            const elapsedLabel = document.getElementById('liveElapsed');
            const autoScrollToggle = document.getElementById('autoScrollToggle');
            const showTimestampsToggle = document.getElementById('showTimestampsToggle');
            const phaseLabel = document.getElementById('livePhase');

            if (!viewer) return; // Not a running workflow

            const POLL_INTERVAL = 2000;
            let pollTimer = null;
            let seenLines = new Set();

            // Toggle timestamps visibility
            if (showTimestampsToggle) {
                showTimestampsToggle.addEventListener('change', function() {
                    viewer.classList.toggle('show-timestamps', showTimestampsToggle.checked);
                });
            }
            let isPolling = false;
            let lastAgent = null;
            const turnCountEl = document.getElementById('liveTurnCount');
            const modelEl = document.getElementById('liveModel');
            const agentsDoneEl = document.getElementById('liveAgentsDone');
            const attemptEl = document.getElementById('liveAttempt');

            // Agent-to-pipeline-stage mapping
            const AGENT_STAGE_MAP = {
                'pre-recon': 'pre-recon',
                'recon': 'recon',
                'auth-vuln': 'vuln-analysis', 'authz-vuln': 'vuln-analysis',
                'xss-vuln': 'vuln-analysis', 'injection-vuln': 'vuln-analysis',
                'ssrf-vuln': 'vuln-analysis',
                'auth-exploit': 'exploitation', 'authz-exploit': 'exploitation',
                'xss-exploit': 'exploitation', 'injection-exploit': 'exploitation',
                'ssrf-exploit': 'exploitation',
                'report': 'report',
            };

            function updatePipelineProgress(currentAgent, completedAgents) {
                const stages = document.querySelectorAll('#livePipelineProgress .pipeline-stage');
                const completedStages = new Set();

                // Mark completed stages based on completed agents
                if (completedAgents && completedAgents.length > 0) {
                    for (const a of completedAgents) {
                        const stage = AGENT_STAGE_MAP[a];
                        if (stage) completedStages.add(stage);
                    }
                }

                // Determine active stage from current agent
                const activeStage = currentAgent ? AGENT_STAGE_MAP[currentAgent] : null;

                stages.forEach(function(s) {
                    const stage = s.dataset.stage;
                    s.classList.remove('completed', 'active');
                    if (completedStages.has(stage) && stage !== activeStage) {
                        s.classList.add('completed');
                    } else if (stage === activeStage) {
                        s.classList.add('active');
                    }
                    // Preflight is always completed if we're seeing any agent
                    if (stage === 'preflight' && (currentAgent || (completedAgents && completedAgents.length > 0))) {
                        s.classList.add('completed');
                    }
                });
            }

            function formatElapsed(seconds) {
                const m = Math.floor(seconds / 60);
                const s = seconds % 60;
                if (m > 0) return m + 'm ' + s + 's';
                return s + 's';
            }

            function appendLine(text) {
                if (seenLines.has(text)) return;
                seenLines.add(text);

                if (emptyMsg && emptyMsg.parentNode) {
                    emptyMsg.remove();
                }

                const line = document.createElement('div');
                line.className = 'live-log-line';

                // Extract timestamp if present: [2026-03-31T00:34:45.123Z] Turn 1 (...)
                let rawText = text;
                let timestamp = null;
                const tsMatch = text.match(/^\[(\d{4}-\d{2}-\d{2}T[\d:.]+Z?)\]\s*/);
                if (tsMatch) {
                    timestamp = tsMatch[1];
                    rawText = text.slice(tsMatch[0].length);
                }

                // Add timestamp element (hidden by default, shown via CSS toggle)
                if (timestamp) {
                    const tsSpan = document.createElement('span');
                    tsSpan.className = 'turn-timestamp';
                    // Format as HH:MM:SS
                    try {
                        const d = new Date(timestamp);
                        tsSpan.textContent = d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                    } catch(e) {
                        tsSpan.textContent = timestamp;
                    }
                    line.appendChild(tsSpan);
                }

                // Color code based on content
                if (rawText.includes('Turn ')) {
                    line.classList.add('turn-line');
                }

                // Extract turn number for styling
                const turnMatch = rawText.match(/^Turn (\d+)/);
                if (turnMatch) {
                    const num = document.createElement('span');
                    num.className = 'turn-number';
                    num.textContent = 'T' + turnMatch[1];
                    line.appendChild(num);

                    const rest = rawText.slice(rawText.indexOf('):') + 2).trim() || rawText.slice(turnMatch[0].length);
                    const agentMatch = rawText.match(/\(([^)]+)\)/);

                    if (agentMatch) {
                        const agentSpan = document.createElement('span');
                        agentSpan.className = 'turn-agent';
                        agentSpan.textContent = agentMatch[1];
                        line.appendChild(agentSpan);
                    }

                    // Parse content that may contain tool calls (🔧) and text separated by |
                    if (rest) {
                        const contentWrap = document.createElement('div');
                        contentWrap.className = 'turn-content';
                        const segments = rest.split(' | ');
                        segments.forEach(function(seg, i) {
                            if (seg.startsWith('🔧 ')) {
                                const toolSpan = document.createElement('span');
                                toolSpan.className = 'turn-tool';
                                // Split tool name from params
                                const colonIdx = seg.indexOf(': ', 2);
                                if (colonIdx > 0) {
                                    const toolName = seg.slice(2, colonIdx);
                                    const toolParam = seg.slice(colonIdx + 2);
                                    const nameSpan = document.createElement('span');
                                    nameSpan.className = 'turn-tool-name';
                                    nameSpan.textContent = toolName;
                                    toolSpan.appendChild(nameSpan);
                                    const paramSpan = document.createElement('span');
                                    paramSpan.className = 'turn-tool-param';
                                    paramSpan.textContent = ' ' + toolParam;
                                    toolSpan.appendChild(paramSpan);
                                } else {
                                    toolSpan.textContent = seg;
                                }
                                contentWrap.appendChild(toolSpan);
                            } else {
                                const textSpan = document.createElement('span');
                                textSpan.className = 'turn-text';
                                textSpan.textContent = seg;
                                contentWrap.appendChild(textSpan);
                            }
                            if (i < segments.length - 1) {
                                const sep = document.createElement('span');
                                sep.className = 'turn-sep';
                                sep.textContent = ' · ';
                                contentWrap.appendChild(sep);
                            }
                        });
                        line.appendChild(contentWrap);
                    }
                } else {
                    line.textContent = rawText;
                }

                viewer.appendChild(line);

                // Auto-scroll
                if (autoScrollToggle && autoScrollToggle.checked) {
                    viewer.scrollTop = viewer.scrollHeight;
                }
            }

            async function poll() {
                if (isPolling) return;
                isPolling = true;

                try {
                    const runId = window.location.pathname.split('/').pop();
                    const res = await fetch('/api/workflow/' + runId);
                    if (!res.ok) return;

                    const data = await res.json();

                    // Check if workflow is still running
                    if (data.status !== 'running') {
                        stopPolling();
                        const done = document.createElement('div');
                        done.className = 'live-log-line live-log-done';
                        done.textContent = '--- Workflow ' + data.status + ' ---';
                        viewer.appendChild(done);
                        // Hide the live dot
                        const dot = document.querySelector('.live-dot');
                        if (dot) dot.classList.remove('pulse');
                        // Emit workflow completion to viz
                        window.__vizBus.emit({
                            type: 'workflow-done',
                            status: data.status,
                            time: new Date().toISOString(),
                        });
                        return;
                    }

                    // Update agent and elapsed from heartbeats
                    if (data.heartbeats && data.heartbeats.length > 0) {
                        for (const hb of data.heartbeats) {
                            if (hb.agent && agentLabel) {
                                // Add agent transition marker
                                if (lastAgent && lastAgent !== hb.agent) {
                                    const marker = document.createElement('div');
                                    marker.className = 'live-log-line agent-transition';
                                    marker.innerHTML = '<span class="transition-arrow">▸</span> <span class="transition-text">Agent switched to <strong>' + hb.agent + '</strong></span>';
                                    viewer.appendChild(marker);
                                    // Emit agent transition to viz
                                    window.__vizBus.emit({
                                        type: 'agent-switch',
                                        agent: hb.agent,
                                        prevAgent: lastAgent,
                                        time: new Date().toISOString(),
                                    });
                                }
                                lastAgent = hb.agent;
                                agentLabel.textContent = hb.agent;
                            }
                            if (hb.elapsedSeconds && elapsedLabel) {
                                elapsedLabel.textContent = formatElapsed(hb.elapsedSeconds);
                            }
                            // Update metrics
                            if (hb.turnCount && turnCountEl) turnCountEl.textContent = hb.turnCount;
                            if (hb.model && modelEl) modelEl.textContent = hb.model;
                            if (hb.attempt && attemptEl) attemptEl.textContent = hb.attempt;
                            // Append turn lines
                            if (Array.isArray(hb.recentTurns)) {
                                for (const turn of hb.recentTurns) {
                                    if (!seenLines.has(turn)) {
                                        // Emit each new turn line to the viz bus
                                        window.__vizBus.emit({
                                            type: 'turn',
                                            text: turn,
                                            agent: hb.agent || lastAgent,
                                            model: hb.model,
                                            time: new Date().toISOString(),
                                        });
                                    }
                                    appendLine(turn);
                                }
                            }
                        }
                    }

                    // Also extract info from progress query
                    if (data.progress) {
                        const currentAgent = data.progress.currentAgent;
                        const completedAgents = data.progress.completedAgents || [];
                        if (currentAgent && agentLabel) {
                            agentLabel.textContent = currentAgent;
                        }
                        if (data.progress.currentPhase && phaseLabel) {
                            phaseLabel.textContent = data.progress.currentPhase;
                        }
                        // Show completed agents count
                        const done = completedAgents.length || 0;
                        const total = data.progress.summary?.agentCount || '?';
                        if (phaseLabel) {
                            phaseLabel.textContent = (data.progress.currentPhase || '') + ' (' + done + '/' + total + ' agents)';
                        }
                        if (agentsDoneEl) agentsDoneEl.textContent = done + '/' + total;

                        // Update pipeline progress
                        updatePipelineProgress(currentAgent, completedAgents);
                    }
                } catch (e) {
                    // Silently ignore poll errors
                } finally {
                    isPolling = false;
                }
            }

            function startPolling() {
                if (pollTimer) return;
                poll(); // Initial fetch
                pollTimer = setInterval(poll, POLL_INTERVAL);
            }

            function stopPolling() {
                if (pollTimer) {
                    clearInterval(pollTimer);
                    pollTimer = null;
                }
            }

            // Start polling when tab is visible
            startPolling();

            // Pause when page is hidden
            document.addEventListener('visibilitychange', function() {
                if (document.hidden) {
                    stopPolling();
                } else {
                    startPolling();
                }
            });
        })();

        // ── Visualization ──────────────────────────
        (function initVisualization() {
            const container = document.getElementById('vizContainer');
            const overlay = document.getElementById('vizRippleOverlay');
            const playBtn = document.getElementById('vizPlayBtn');
            const resetBtn = document.getElementById('vizResetBtnHistory');
            const resetBtnLive = document.getElementById('vizResetBtn');
            const speedSlider = document.getElementById('vizSpeedSlider');
            const modeToggle = document.getElementById('vizModeToggle');
            const liveDot = document.getElementById('vizLiveDot');
            const liveCountEl = document.getElementById('vizLiveCount');
            const liveAgentEl = document.getElementById('vizLiveAgent');
            const liveStatusEl = document.getElementById('vizLiveStatus');
            const catchupBar = document.getElementById('vizCatchupBar');
            const catchupFill = document.getElementById('vizCatchupFill');

            if (!container || !overlay) return;

            let vizEvents = [];
            let vizAgents = [];
            try {
                vizEvents = JSON.parse(document.getElementById('vizEventsData')?.textContent || '[]');
                vizAgents = JSON.parse(document.getElementById('vizAgentsData')?.textContent || '[]');
            } catch(e) { console.error('Failed to parse viz data', e); }

            // Color palette by event category
            const CATEGORY_COLORS = {
                'workflow':  '#8B5CF6',
                'activity':  '#22D3EE',
                'timer':     '#FBBF24',
                'signal':    '#F472B6',
                'child':     '#34D399',
                'command':   '#4ADE80',
                'marker':    '#A78BFA',
                'default':   '#6B7280',
            };

            // Agent colors
            const AGENT_COLORS = [
                '#22D3EE', '#34D399', '#FBBF24', '#F472B6',
                '#A78BFA', '#4ADE80', '#3B82F6', '#EF4444',
                '#8B5CF6', '#F59E0B', '#10B981', '#EC4899',
            ];

            const agentColorMap = {};
            let nextAgentColorIdx = 0;
            vizAgents.forEach(function(a, i) {
                agentColorMap[a.agentName] = AGENT_COLORS[i % AGENT_COLORS.length];
                nextAgentColorIdx = (i + 1) % AGENT_COLORS.length;
            });

            function getAgentColor(name) {
                if (!name) return '#22D3EE';
                if (!agentColorMap[name]) {
                    agentColorMap[name] = AGENT_COLORS[nextAgentColorIdx % AGENT_COLORS.length];
                    nextAgentColorIdx++;
                }
                return agentColorMap[name];
            }

            // ── Human-friendly event labels ──
            // Map raw Temporal event types to short, readable descriptions
            const EVENT_TYPE_LABELS = {
                'WorkflowExecutionStarted': 'Workflow started',
                'WorkflowTaskScheduled': 'Processing...',
                'WorkflowTaskStarted': 'Processing...',
                'WorkflowTaskCompleted': 'Step completed',
                'ActivityTaskScheduled': 'Scheduling agent',
                'ActivityTaskStarted': 'Agent running',
                'ActivityTaskCompleted': 'Agent finished',
                'ActivityTaskFailed': 'Agent failed',
                'ActivityTaskTimedOut': 'Agent timed out',
                'TimerStarted': 'Timer set',
                'TimerFired': 'Timer elapsed',
                'MarkerRecorded': 'Checkpoint',
                'WorkflowExecutionCompleted': 'Scan complete',
                'WorkflowExecutionFailed': 'Scan failed',
                'WorkflowExecutionTerminated': 'Scan terminated',
                'WorkflowExecutionCanceled': 'Scan cancelled',
                'StartChildWorkflowExecutionInitiated': 'Starting sub-workflow',
                'ChildWorkflowExecutionCompleted': 'Sub-workflow done',
                'SignalExternalWorkflowExecutionInitiated': 'Sending signal',
            };

            // Agent name to human-readable description
            const AGENT_DESCRIPTIONS = {
                'pre-recon': 'Mapping target surface',
                'recon': 'Deep reconnaissance',
                'auth-vuln': 'Scanning authentication',
                'auth-exploit': 'Testing auth exploits',
                'xss-vuln': 'Scanning for XSS',
                'xss-exploit': 'Testing XSS exploits',
                'ssrf-vuln': 'Scanning for SSRF',
                'ssrf-exploit': 'Testing SSRF exploits',
                'injection-vuln': 'Scanning for injections',
                'injection-exploit': 'Testing injection exploits',
                'authz-vuln': 'Scanning authorization',
                'authz-exploit': 'Testing authz exploits',
                'report': 'Generating report',
            };

            // Tool name to readable verb
            function humanizeToolName(toolName) {
                const map = {
                    'bash': 'Running command',
                    'read_file': 'Reading file',
                    'write_file': 'Writing file',
                    'glob_search': 'Searching files',
                    'grep_search': 'Searching code',
                    'list_directory': 'Listing directory',
                    'save_deliverable': 'Saving finding',
                    'generate_totp': 'Generating TOTP',
                    'Bash': 'Running command',
                    'Read': 'Reading file',
                    'Write': 'Writing file',
                    'Glob': 'Searching files',
                    'Grep': 'Searching code',
                };
                return map[toolName] || toolName;
            }

            // Zone grid for spatial distribution (4x3 LRU)
            const GRID_COLS = 4;
            const GRID_ROWS = 3;
            const TOTAL_ZONES = GRID_COLS * GRID_ROWS;
            const zoneLastUsed = new Array(TOTAL_ZONES).fill(0);
            const MAX_ACTIVE_RIPPLES = 12;
            const RIPPLE_LIFETIME_MS = 5000;
            let activeRipples = [];
            let isPlaying = false;
            let playTimer = null;
            let eventIndex = 0;

            // Mode: 'history' or 'live'
            let vizMode = 'history';
            let isLiveActive = false;
            let liveEventCount = 0;
            let isCatchingUp = false;  // true during the fast-forward replay
            let catchupTimer = null;
            let catchupQueue = [];     // queued live events during catchup

            function pickZone() {
                let lruIndex = 0;
                let lruTime = zoneLastUsed[0];
                for (let i = 1; i < TOTAL_ZONES; i++) {
                    if (zoneLastUsed[i] < lruTime) {
                        lruTime = zoneLastUsed[i];
                        lruIndex = i;
                    }
                }
                zoneLastUsed[lruIndex] = Date.now();
                const col = lruIndex % GRID_COLS;
                const row = Math.floor(lruIndex / GRID_COLS);
                const padX = 8, padY = 10;
                const spanX = 100 - padX * 2;
                const spanY = 100 - padY * 2;
                const cellW = spanX / GRID_COLS;
                const cellH = spanY / GRID_ROWS;
                const jitterX = (Math.random() - 0.5) * cellW * 0.5;
                const jitterY = (Math.random() - 0.5) * cellH * 0.5;
                const x = padX + cellW * (col + 0.5) + jitterX;
                const y = padY + cellH * (row + 0.5) + jitterY;
                return { x: x, y: y, zoneIndex: lruIndex };
            }

            function removeRipple(ripple) {
                clearTimeout(ripple.timeout);
                if (ripple.element.parentElement) ripple.element.remove();
                const idx = activeRipples.indexOf(ripple);
                if (idx !== -1) activeRipples.splice(idx, 1);
            }

            function forceRemoveOldest() {
                if (activeRipples.length === 0) return;
                const oldest = activeRipples[0];
                oldest.element.style.animation = 'none';
                oldest.element.style.transition = 'opacity 300ms ease-out, transform 300ms ease-out';
                oldest.element.style.opacity = '0';
                oldest.element.style.transform += ' scale(0.8)';
                setTimeout(function() { removeRipple(oldest); }, 300);
            }

            // ── Create ripple DOM element ──
            function createRipple(color, label, sublabel, timestamp) {
                while (activeRipples.length >= MAX_ACTIVE_RIPPLES) {
                    forceRemoveOldest();
                }

                const pos = pickZone();

                const item = document.createElement('div');
                item.className = 'viz-ripple-item';
                item.style.left = pos.x + '%';
                item.style.top = pos.y + '%';
                item.style.transform = 'translate(-50%, -50%)';

                const card = document.createElement('div');
                card.className = 'viz-ripple-card';
                card.style.textShadow = '0 0 8px ' + color + ', 0 0 16px ' + color + '40';

                const labelSpan = document.createElement('span');
                labelSpan.className = 'viz-ripple-id';
                labelSpan.style.color = color;
                labelSpan.textContent = label;
                card.appendChild(labelSpan);

                if (sublabel) {
                    const subSpan = document.createElement('span');
                    subSpan.className = 'viz-ripple-label';
                    subSpan.style.color = color + 'DD';
                    subSpan.textContent = ' ' + sublabel;
                    card.appendChild(subSpan);
                }

                if (timestamp) {
                    const tsSpan = document.createElement('span');
                    tsSpan.className = 'viz-ripple-ts';
                    try {
                        const d = new Date(timestamp);
                        tsSpan.textContent = d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
                    } catch(e) {}
                    card.appendChild(tsSpan);
                }

                item.appendChild(card);

                // Concentric ripple rings
                var ringScales = [1, 1.6, 2.2];
                var ringDelays = [0, 150, 300];
                var ringDurations = [1200, 1400, 1600];

                for (var i = 0; i < 3; i++) {
                    var ring = document.createElement('div');
                    ring.className = 'viz-ripple-ring';
                    ring.style.color = color;
                    ring.style.width = (200 * ringScales[i]) + 'px';
                    ring.style.height = (200 * ringScales[i]) + 'px';
                    ring.style.animationDuration = ringDurations[i] + 'ms';
                    ring.style.animationDelay = ringDelays[i] + 'ms';
                    ring.style.opacity = '0';
                    item.appendChild(ring);
                }

                overlay.appendChild(item);

                var timeout = setTimeout(function() {
                    removeRipple(rippleRecord);
                }, RIPPLE_LIFETIME_MS + 100);

                var rippleRecord = {
                    element: item,
                    zoneIndex: pos.zoneIndex,
                    createdAt: Date.now(),
                    timeout: timeout,
                };

                activeRipples.push(rippleRecord);
            }

            // ── Deduplicate & filter history events for meaningful display ──
            // Skip noisy internal events and collapse duplicates at the same timestamp
            function filterHistoryEvents(events) {
                var filtered = [];
                var seen = {};  // "eventType|actType|timestamp_second" -> true
                for (var i = 0; i < events.length; i++) {
                    var ev = events[i];
                    var eventType = ev.eventType || '';
                    // Skip noisy internal workflow task events
                    if (eventType === 'WorkflowTaskScheduled' || eventType === 'WorkflowTaskStarted') continue;
                    // Dedupe: same event type + activity type within the same second
                    var actType = (ev.details && ev.details['Activity Type']) || '';
                    var tsSec = '';
                    try { tsSec = new Date(ev.eventTime).toISOString().slice(0, 19); } catch(e) {}
                    var dedupeKey = eventType + '|' + actType + '|' + tsSec;
                    if (seen[dedupeKey]) continue;
                    seen[dedupeKey] = true;
                    filtered.push(ev);
                }
                return filtered;
            }

            // ── History mode: trigger from event data with friendly labels ──
            function triggerHistoryRipple(ev) {
                var actType = ev.details && ev.details['Activity Type'];
                var color;
                if (actType && agentColorMap[actType]) {
                    color = agentColorMap[actType];
                } else {
                    color = CATEGORY_COLORS[ev.category] || CATEGORY_COLORS['default'];
                }

                // Build human-friendly label
                var label = '';
                var sublabel = '';

                if (actType) {
                    // Activity event — show the agent name as primary
                    label = actType;
                    var evType = ev.eventType || '';
                    if (evType.includes('Scheduled')) {
                        sublabel = AGENT_DESCRIPTIONS[actType] || 'Starting...';
                    } else if (evType.includes('Started')) {
                        sublabel = 'Running';
                    } else if (evType.includes('Completed')) {
                        sublabel = 'Completed';
                    } else if (evType.includes('Failed')) {
                        sublabel = 'Failed';
                    } else if (evType.includes('TimedOut')) {
                        sublabel = 'Timed out';
                    }
                } else {
                    // Non-activity event
                    var readable = EVENT_TYPE_LABELS[ev.eventType] || ev.eventType || '?';
                    label = readable;
                }

                if (label.length > 35) label = label.slice(0, 32) + '...';

                createRipple(color, label, sublabel, ev.eventTime);
            }

            // ── Live mode: trigger from bus events ──
            function triggerLiveRipple(busEvent) {
                // During catchup, queue live events for later
                if (isCatchingUp) {
                    catchupQueue.push(busEvent);
                    return;
                }
                if (vizMode !== 'live') return;
                // Check viz tab is active
                var vizTab = document.getElementById('tab-visualization');
                if (!vizTab || !vizTab.classList.contains('active')) return;

                liveEventCount++;
                if (liveCountEl) liveCountEl.textContent = liveEventCount;

                if (busEvent.type === 'turn') {
                    var color = getAgentColor(busEvent.agent);
                    // Parse the turn text for display
                    var rawText = busEvent.text || '';
                    // Strip timestamp prefix
                    var tsMatch = rawText.match(/^\[(\d{4}-\d{2}-\d{2}T[\d:.]+Z?)\]\s*/);
                    if (tsMatch) rawText = rawText.slice(tsMatch[0].length);

                    // Extract turn number
                    var turnMatch = rawText.match(/^Turn (\d+)/);
                    var turnNum = turnMatch ? parseInt(turnMatch[1]) : 0;
                    var turnLabel = turnMatch ? 'Turn ' + turnMatch[1] : '';

                    // Extract agent name
                    var agentMatch = rawText.match(/\(([^)]+)\)/);
                    var agentName = agentMatch ? agentMatch[1] : (busEvent.agent || '');
                    if (liveAgentEl) liveAgentEl.textContent = agentName;

                    // Build a meaningful detail from the rest
                    var detail = '';
                    var rest = rawText.includes('):') ? rawText.slice(rawText.indexOf('):') + 2).trim() : '';
                    if (rest) {
                        var segments = rest.split(' | ');
                        // Collect tool names for a summary
                        var tools = [];
                        var textSnippet = '';
                        for (var si = 0; si < segments.length; si++) {
                            var seg = segments[si];
                            if (seg.indexOf('\uD83D\uDD27 ') === 0 || seg.indexOf('🔧 ') === 0) {
                                // Extract tool name (before the colon)
                                var toolRaw = seg.slice(2).trim();
                                var colonIdx = toolRaw.indexOf(': ');
                                var toolName = colonIdx > 0 ? toolRaw.slice(0, colonIdx) : toolRaw;
                                tools.push(humanizeToolName(toolName.trim()));
                            } else if (!textSnippet && seg.length > 2) {
                                textSnippet = seg.length > 40 ? seg.slice(0, 37) + '...' : seg;
                            }
                        }

                        if (tools.length > 0) {
                            // Show unique tools, e.g. "Reading file, Running command"
                            var unique = [];
                            for (var ti = 0; ti < tools.length; ti++) {
                                if (unique.indexOf(tools[ti]) === -1) unique.push(tools[ti]);
                            }
                            detail = unique.slice(0, 2).join(', ');
                            if (unique.length > 2) detail += ' +' + (unique.length - 2);
                        } else if (textSnippet) {
                            detail = textSnippet;
                        }
                    }

                    // Compose the label: "agentName" as primary, detail as sublabel
                    var displayLabel = agentName || turnLabel;
                    var displaySub = detail || (turnLabel ? 'Thinking...' : '');
                    createRipple(color, displayLabel, displaySub, busEvent.time);

                } else if (busEvent.type === 'agent-switch') {
                    var switchColor = getAgentColor(busEvent.agent);
                    if (liveAgentEl) liveAgentEl.textContent = busEvent.agent;
                    var agentDesc = AGENT_DESCRIPTIONS[busEvent.agent] || 'Starting...';
                    createRipple(switchColor, busEvent.agent, agentDesc, busEvent.time);

                } else if (busEvent.type === 'workflow-done') {
                    var doneColor = busEvent.status === 'completed' ? '#4ADE80' : '#EF4444';
                    var doneMsg = busEvent.status === 'completed' ? 'Scan finished successfully' : 'Scan ' + busEvent.status;
                    createRipple(doneColor, 'Done', doneMsg, busEvent.time);
                    if (liveStatusEl) {
                        liveStatusEl.textContent = busEvent.status;
                        liveStatusEl.className = 'viz-live-status viz-status-' + busEvent.status;
                    }
                    if (liveDot) liveDot.classList.remove('pulse');
                }
            }

            // ── Listen to viz bus ──
            window.__vizBus.on(triggerLiveRipple);

            // ── Catchup: fast-forward replay of recent history, then go live ──
            function startCatchup() {
                // Filter events from the last ~5 minutes
                var now = Date.now();
                var CATCHUP_WINDOW_MS = 5 * 60 * 1000;
                var recentEvents = filterHistoryEvents(vizEvents).filter(function(ev) {
                    try {
                        var t = new Date(ev.eventTime).getTime();
                        return (now - t) < CATCHUP_WINDOW_MS;
                    } catch(e) { return false; }
                });

                // If no recent events or very few, just go straight to live
                if (recentEvents.length < 3) {
                    finishCatchup();
                    return;
                }

                isCatchingUp = true;
                catchupQueue = [];
                if (catchupBar) catchupBar.style.display = 'flex';

                // Calculate replay speed: replay all events in ~4 seconds
                var totalReplayMs = 4000;
                var interval = Math.max(50, Math.floor(totalReplayMs / recentEvents.length));
                var idx = 0;

                catchupTimer = setInterval(function() {
                    if (idx >= recentEvents.length) {
                        clearInterval(catchupTimer);
                        catchupTimer = null;
                        // Small pause before going live
                        setTimeout(finishCatchup, 600);
                        return;
                    }
                    triggerHistoryRipple(recentEvents[idx]);
                    // Update progress bar
                    if (catchupFill) {
                        var pct = Math.round(((idx + 1) / recentEvents.length) * 100);
                        catchupFill.style.width = pct + '%';
                    }
                    idx++;
                }, interval);
            }

            function finishCatchup() {
                isCatchingUp = false;
                if (catchupBar) {
                    catchupBar.style.opacity = '0';
                    setTimeout(function() {
                        catchupBar.style.display = 'none';
                        catchupBar.style.opacity = '';
                    }, 400);
                }
                // Flush any queued live events
                for (var i = 0; i < catchupQueue.length; i++) {
                    triggerLiveRipple(catchupQueue[i]);
                }
                catchupQueue = [];
            }

            // ── Mode switching ──
            function setMode(mode) {
                vizMode = mode;
                var historyControls = document.getElementById('vizHistoryControls');
                var livePanel = document.getElementById('vizLivePanel');

                if (mode === 'live') {
                    isLiveActive = true;
                    if (historyControls) historyControls.style.display = 'none';
                    if (livePanel) livePanel.style.display = 'flex';
                    if (modeToggle) {
                        modeToggle.querySelector('[data-mode="live"]')?.classList.add('active');
                        modeToggle.querySelector('[data-mode="history"]')?.classList.remove('active');
                    }
                    // Stop history playback
                    stopPlaying();
                    // Clear existing ripples
                    for (var r of [...activeRipples]) removeRipple(r);
                    zoneLastUsed.fill(0);
                } else {
                    isLiveActive = false;
                    // Cancel any catchup in progress
                    if (catchupTimer) { clearInterval(catchupTimer); catchupTimer = null; }
                    isCatchingUp = false;
                    if (catchupBar) catchupBar.style.display = 'none';
                    catchupQueue = [];
                    if (historyControls) historyControls.style.display = 'flex';
                    if (livePanel) livePanel.style.display = 'none';
                    if (modeToggle) {
                        modeToggle.querySelector('[data-mode="history"]')?.classList.add('active');
                        modeToggle.querySelector('[data-mode="live"]')?.classList.remove('active');
                    }
                    // Clear live ripples
                    for (var r of [...activeRipples]) removeRipple(r);
                    zoneLastUsed.fill(0);
                }
            }

            // Mode toggle buttons
            if (modeToggle) {
                modeToggle.querySelectorAll('button').forEach(function(btn) {
                    btn.addEventListener('click', function() {
                        setMode(btn.dataset.mode);
                        // Trigger catchup when switching to live
                        if (btn.dataset.mode === 'live') {
                            startCatchup();
                        }
                    });
                });
            }

            // ── History playback ──
            function getSpeed() {
                return parseInt(speedSlider?.value || '5', 10);
            }

            function getInterval() {
                var speed = getSpeed();
                return Math.max(30, 1100 - speed * 55);
            }

            function playStep() {
                if (eventIndex >= filteredVizEvents.length) {
                    stopPlaying();
                    if (playBtn) playBtn.textContent = '↺ Replay';
                    eventIndex = 0;
                    return;
                }
                triggerHistoryRipple(filteredVizEvents[eventIndex]);
                eventIndex++;
            }

            // Pre-filter history events for manual playback
            var filteredVizEvents = filterHistoryEvents(vizEvents);

            function startPlaying() {
                if (isPlaying) return;
                isPlaying = true;
                if (playBtn) playBtn.textContent = '⏸ Pause';
                playStep();
                playTimer = setInterval(function() {
                    playStep();
                }, getInterval());
            }

            function stopPlaying() {
                isPlaying = false;
                if (playBtn) playBtn.textContent = '▶ Play';
                if (playTimer) {
                    clearInterval(playTimer);
                    playTimer = null;
                }
            }

            function resetViz() {
                stopPlaying();
                if (catchupTimer) { clearInterval(catchupTimer); catchupTimer = null; }
                isCatchingUp = false;
                if (catchupBar) catchupBar.style.display = 'none';
                catchupQueue = [];
                eventIndex = 0;
                liveEventCount = 0;
                if (liveCountEl) liveCountEl.textContent = '0';
                for (var r of [...activeRipples]) removeRipple(r);
                zoneLastUsed.fill(0);
                if (playBtn) playBtn.textContent = '▶ Play';
            }

            if (playBtn) {
                playBtn.addEventListener('click', function() {
                    if (isPlaying) stopPlaying();
                    else startPlaying();
                });
            }
            if (resetBtn) resetBtn.addEventListener('click', resetViz);
            if (resetBtnLive) resetBtnLive.addEventListener('click', resetViz);
            if (speedSlider) {
                speedSlider.addEventListener('input', function() {
                    if (isPlaying) {
                        clearInterval(playTimer);
                        playTimer = setInterval(playStep, getInterval());
                    }
                });
            }

            // ── Auto-detect: if workflow is running, default to live mode with catchup ──
            var isRunning = !!document.getElementById('liveLogsViewer');
            if (isRunning && modeToggle) {
                setMode('live');
                // Start catchup replay automatically
                startCatchup();
            }
        })();

        // ── Query runner ──────────────────────────
        document.getElementById('runQueryBtn')?.addEventListener('click', async () => {
            const btn = document.getElementById('runQueryBtn');
            const queryType = document.getElementById('queryType').value;
            const resultEl = document.querySelector('#queryResult code');
            resultEl.textContent = 'Running query...';

            try {
                const res = await fetch('/api/workflow/' + btn.dataset.runId + '?query=' + encodeURIComponent(queryType));
                const data = await res.json();
                if (data.progress) {
                    resultEl.textContent = JSON.stringify(data.progress, null, 2);
                } else {
                    resultEl.textContent = JSON.stringify(data, null, 2);
                }
            } catch (err) {
                resultEl.textContent = 'Error: ' + err.message;
            }
        });
    </script>
</Base>

