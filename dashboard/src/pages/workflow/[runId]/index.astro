        border-radius: 4px;
    }

    .event-type-badge.start { color: var(--info); background: var(--info-bg); }
    .event-type-badge.success { color: var(--success); background: var(--success-bg); }
    .event-type-badge.error { color: var(--error); background: var(--error-bg); }
    .event-type-badge.scheduled { color: var(--warning); background: var(--warning-bg); }
    .event-type-badge.activity { color: var(--purple-light); background: var(--purple-subtle); }
    .event-type-badge.default { color: var(--text-muted); background: rgba(255, 255, 255, 0.04); }

    /* ── Auto Refresh Toggle ────────────────── */
    .auto-refresh-toggle {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        font-size: 0.78rem;
        color: var(--text-dim);
    }

    .auto-refresh-toggle input {
        display: none;
    }

    .toggle-slider {
        width: 32px;
        height: 18px;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 9px;
        position: relative;
        transition: background 0.2s;
    }

    .toggle-slider::after {
        content: '';
        position: absolute;
        width: 14px;
        height: 14px;
        background: var(--text-dim);
        border-radius: 50%;
        top: 2px;
        left: 2px;
        transition: all 0.2s;
    }

    .auto-refresh-toggle input:checked + .toggle-slider,
    .auto-scroll-toggle input:checked + .toggle-slider {
        background: var(--purple);
    }

    .auto-refresh-toggle input:checked + .toggle-slider::after,
    .auto-scroll-toggle input:checked + .toggle-slider::after {
        left: 16px;
        background: var(--white);
    }

    .toggle-label {
        user-select: none;
    }

    /* ── Relationship Card ────────────────── */
    .relationship-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1.25rem 1.5rem;
    }

    .relationship-item {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        margin-bottom: 0.75rem;
    }

    .relationship-item:last-child {
        margin-bottom: 0;
    }

    /* ── Progress Card ────────────────── */
    .progress-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1.25rem 1.5rem;
    }

    .progress-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--white);
    }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        margin-top: 1rem;
    }

    .summary-item {
        background: var(--bg-card);
        padding: 1rem 1.25rem;
        text-align: center;
    }

    .summary-label {
        display: block;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-faint);
        font-weight: 600;
        margin-bottom: 0.35rem;
    }

    .summary-value {
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--white);
        font-family: var(--font-mono);
    }

    /* ── JSON Viewer ────────────────── */
    .json-section {
        margin-bottom: 1.5rem;
    }

    .json-section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .json-section h3 {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-faint);
        font-weight: 600;
        margin-bottom: 0;
    }

    .json-section-header + .json-viewer {
        margin-top: 0;
    }

    .json-viewer {
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1rem 1.25rem;
        overflow-x: auto;
        max-height: 400px;
        overflow-y: auto;
    }

    .json-viewer code {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        color: var(--text);
        line-height: 1.6;
        white-space: pre;
    }

    /* ── Query Panel ────────────────── */
    .query-panel {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    .query-form {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .query-label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-muted);
        margin-bottom: 0.35rem;
    }

    .query-select,
    .query-input {
        width: 100%;
        padding: 0.5rem 0.75rem;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        color: var(--text);
        font-size: 0.82rem;
        font-family: var(--font);
        outline: none;
        transition: border-color 0.2s;
    }

    .query-select:focus,
    .query-input:focus {
        border-color: var(--border-active);
    }

    .query-input {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        resize: vertical;
    }

    .query-result h3 {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-faint);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    /* ── Buttons ────────────────── */
    .btn-danger {
        background: var(--error-bg);
        color: var(--error);
        border: 1px solid var(--error-border);
    }

    .btn-danger:hover {
        background: rgba(248, 113, 113, 0.15);
    }

    /* ── Error Card ────────────────── */
    .error-card {
        margin: 1.5rem 2rem;
    }

    .error-card h3 {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--error);
        font-weight: 600;
        margin-bottom: 0.5rem;
    }

    .error-pre {
        background: rgba(248, 113, 113, 0.05);
        border: 1px solid var(--error-border);
        border-radius: var(--radius);
        padding: 1rem;
        color: var(--error);
        font-family: var(--font-mono);
        font-size: 0.78rem;
        white-space: pre-wrap;
        word-break: break-all;
        line-height: 1.5;
    }

    /* ── Failure Summary ────────────────── */
    .failure-summary {
        margin: 0 2rem 1.5rem;
        background: rgba(248, 113, 113, 0.04);
        border: 1px solid var(--error-border);
        border-radius: var(--radius);
        padding: 1.25rem 1.5rem;
    }
    .failure-summary-header {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }
    .failure-summary-icon { font-size: 1.25rem; line-height: 1; margin-top: 0.1rem; }
    .failure-summary-header h3 { font-size: 0.95rem; color: var(--error); font-weight: 700; margin: 0; }
    .failure-summary-subtitle { font-size: 0.8rem; color: var(--text-muted); margin: 0.2rem 0 0; }
    .failure-agents { display: flex; flex-direction: column; gap: 0.75rem; }
    .failure-agent-card {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid var(--border);
        border-left: 3px solid var(--error);
        border-radius: var(--radius);
        padding: 0.75rem 1rem;
    }
    .failure-agent-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.5rem;
    }
    .failure-agent-name { font-weight: 700; font-size: 0.85rem; color: var(--white); font-family: var(--font-mono); }
    .failure-meta-tag {
        font-size: 0.7rem;
        padding: 0.15rem 0.5rem;
        border-radius: 3px;
        background: rgba(255, 255, 255, 0.06);
        color: var(--text-dim);
        font-family: var(--font-mono);
    }
    .failure-error-text {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(248, 113, 113, 0.15);
        border-radius: 4px;
        padding: 0.6rem 0.75rem;
        color: #f8a0a0;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        white-space: pre-wrap;
        word-break: break-word;
        line-height: 1.5;
        margin: 0;
    }
    .failure-error-text.small { font-size: 0.7rem; padding: 0.4rem 0.6rem; }
    .failure-attempts-details { margin-top: 0.5rem; }
    .failure-attempts-details summary {
        font-size: 0.75rem;
        color: var(--text-muted);
        cursor: pointer;
        user-select: none;
        padding: 0.25rem 0;
    }
    .failure-attempts-details summary:hover { color: var(--text-dim); }
    .failure-attempts-list {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        margin-top: 0.5rem;
        padding-left: 0.5rem;
        border-left: 2px solid var(--border);
    }
    .failure-attempt-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 0.72rem;
        color: var(--text-muted);
        margin-bottom: 0.25rem;
    }
    .failure-attempt-time, .failure-attempt-duration {
        font-family: var(--font-mono);
        color: var(--text-dim);
    }
    .failure-phases {
        margin-top: 1.25rem;
        padding-top: 1rem;
        border-top: 1px solid var(--border);
    }
    .failure-phases h4 {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-muted);
        font-weight: 600;
        margin: 0 0 0.75rem;
    }
    .phase-bar-container {
        display: flex;
        height: 24px;
        border-radius: 4px;
        overflow: hidden;
        gap: 2px;
    }
    .phase-bar-segment {
        display: flex;
        align-items: center;
        justify-content: center;
        min-width: 30px;
        cursor: default;
    }
    .phase-bar-segment:nth-child(1) { background: rgba(99, 102, 241, 0.35); }
    .phase-bar-segment:nth-child(2) { background: rgba(34, 197, 94, 0.3); }
    .phase-bar-segment:nth-child(3) { background: rgba(234, 179, 8, 0.3); }
    .phase-bar-segment:nth-child(4) { background: rgba(248, 113, 113, 0.3); }
    .phase-bar-label {
        font-size: 0.65rem;
        color: var(--white);
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        padding: 0 4px;
    }
    .phase-legend { display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem; margin-top: 0.5rem; }
    .phase-legend-item { display: flex; align-items: center; gap: 0.4rem; font-size: 0.72rem; }
    .phase-legend-dot { width: 8px; height: 8px; border-radius: 2px; }
    .phase-legend-item:nth-child(1) .phase-legend-dot { background: rgba(99, 102, 241, 0.6); }
    .phase-legend-item:nth-child(2) .phase-legend-dot { background: rgba(34, 197, 94, 0.5); }
    .phase-legend-item:nth-child(3) .phase-legend-dot { background: rgba(234, 179, 8, 0.5); }
    .phase-legend-item:nth-child(4) .phase-legend-dot { background: rgba(248, 113, 113, 0.5); }
    .phase-legend-name { color: var(--text-dim); font-weight: 500; }
    .phase-legend-stats { color: var(--text-muted); font-family: var(--font-mono); }

    /* Inline error details in table */
    .cell-error { max-width: 350px; font-size: 0.75rem; color: var(--error); }
    .inline-error-details { cursor: pointer; }
    .inline-error-summary {
        color: var(--error);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 300px;
        display: block;
    }
    .inline-error-summary:hover { color: #f8a0a0; }
    .inline-error-full {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(248, 113, 113, 0.15);
        border-radius: 4px;
        padding: 0.5rem;
        color: #f8a0a0;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        white-space: pre-wrap;
        word-break: break-word;
        line-height: 1.4;
        margin-top: 0.35rem;
        max-height: 200px;
        overflow-y: auto;
    }
    .row-failed { background: rgba(248, 113, 113, 0.03); }
    .row-failed:hover { background: rgba(248, 113, 113, 0.06) !important; }
    .attempts-badge { font-size: 0.72rem; color: var(--text-dim); }
    .attempts-badge.has-failures { color: var(--error); }

    .banner {
        padding: 0.75rem 1rem;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .banner-error {
        background: var(--error-bg);
        border-bottom: 1px solid var(--error-border);
        color: var(--error);
    }

    /* ── Live Logs ────────────────────────── */
    .live-badge {
        background: rgba(52, 211, 153, 0.15) !important;
        color: #34d399 !important;
        animation: badge-pulse 2s ease-in-out infinite;
    }

    @keyframes badge-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .live-logs-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .live-logs-status {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.82rem;
    }

    .live-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #34d399;
        flex-shrink: 0;
    }

    .live-dot.pulse {
        animation: dot-pulse 1.5s ease-in-out infinite;
    }

    @keyframes dot-pulse {
        0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(52, 211, 153, 0.4); }
        50% { opacity: 0.6; box-shadow: 0 0 0 4px rgba(52, 211, 153, 0); }
    }

    .live-label {
        color: var(--text-muted);
        font-size: 0.78rem;
    }

    .live-agent {
        font-weight: 600;
        color: #67e8f9;
        font-family: var(--font-mono);
        font-size: 0.78rem;
    }

    .live-logs-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .live-elapsed {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: var(--text-faint);
    }

    .live-phase {
        font-size: 0.72rem;
        color: var(--purple-light);
        font-weight: 500;
    }

    .auto-scroll-toggle {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        font-size: 0.78rem;
        color: var(--text-dim);
    }

    .auto-scroll-toggle input {
        display: none;
    }

    /* Pipeline progress bar */
    .live-pipeline-progress {
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 0.75rem;
        padding: 0.6rem 1rem;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow-x: auto;
    }

    .pipeline-stage {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        flex-shrink: 0;
    }

    .pipeline-stage .stage-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.1);
        border: 2px solid rgba(255, 255, 255, 0.15);
        transition: all 0.3s;
    }

    .pipeline-stage .stage-label {
        font-size: 0.7rem;
        color: var(--text-faint);
        font-weight: 500;
        transition: color 0.3s;
    }

    .pipeline-stage.completed .stage-dot {
        background: #34d399;
        border-color: #34d399;
        box-shadow: 0 0 6px rgba(52, 211, 153, 0.4);
    }

    .pipeline-stage.completed .stage-label {
        color: #34d399;
    }

    .pipeline-stage.active .stage-dot {
        background: #67e8f9;
        border-color: #67e8f9;
        animation: dot-pulse 1.5s ease-in-out infinite;
    }

    .pipeline-stage.active .stage-label {
        color: #67e8f9;
        font-weight: 600;
    }

    .pipeline-connector {
        flex: 1;
        height: 2px;
        min-width: 12px;
        background: rgba(255, 255, 255, 0.08);
        margin: 0 0.3rem;
    }

    .pipeline-stage.completed + .pipeline-connector,
    .pipeline-connector:has(+ .pipeline-stage.completed),
    .pipeline-connector:has(+ .pipeline-stage.active) {
        background: rgba(52, 211, 153, 0.3);
    }

    /* Live metrics bar */
    .live-metrics-bar {
        display: flex;
        gap: 1.5rem;
        margin-bottom: 0.75rem;
        padding: 0.5rem 1rem;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border);
        border-radius: var(--radius);
    }

    .live-metric {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .live-metric-label {
        font-size: 0.68rem;
        color: var(--text-faint);
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .live-metric-value {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        font-weight: 600;
        color: #d1d5db;
    }

    .live-logs-viewer {
        background: #0a0e14;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 0.5rem 0;
        height: 600px;
        overflow-y: auto;
        font-family: var(--font-mono);
        font-size: 0.8rem;
        line-height: 1.5;
    }

    .live-logs-viewer::-webkit-scrollbar {
        width: 6px;
    }

    .live-logs-viewer::-webkit-scrollbar-track {
        background: transparent;
    }

    .live-logs-viewer::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 3px;
    }

    .live-logs-viewer::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.2);
    }

    .live-logs-empty {
        color: var(--text-faint);
        font-style: italic;
        text-align: center;
        padding: 3rem 0;
    }

    .live-log-line {
        padding: 0.5rem 0.75rem;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.04);
        transition: background 0.15s;
    }

    .live-log-line:hover {
        background: rgba(255, 255, 255, 0.02);
    }

    .live-log-line.turn-line {
        color: #d1d5db;
    }

    /* Timestamp - hidden by default, shown when toggle is on */
    .turn-timestamp {
        display: none;
        color: #6b7280;
        font-size: 0.72rem;
        min-width: 70px;
        flex-shrink: 0;
        font-variant-numeric: tabular-nums;
    }

    .live-logs-viewer.show-timestamps .turn-timestamp {
        display: inline;
    }

    .turn-number {
        color: #34d399;
        font-weight: 700;
        min-width: 36px;
        flex-shrink: 0;
    }

    .turn-agent {
        color: #67e8f9;
        font-weight: 600;
        min-width: 100px;
        flex-shrink: 0;
    }

    .turn-content {
        color: #d1d5db;
        flex: 1;
        min-width: 0;
        line-height: 1.6;
        word-break: break-word;
    }

    .turn-tool {
        display: inline;
    }

    .turn-tool-name {
        color: #c084fc;
        font-weight: 600;
    }

    .turn-tool-param {
        color: #9ca3af;
        word-break: break-all;
    }

    .agent-transition {
        padding: 0.4rem 0;
        margin: 0.3rem 0;
        border-bottom: 1px solid rgba(103, 232, 249, 0.1);
        border-top: 1px solid rgba(103, 232, 249, 0.1);
    }

    .transition-arrow {
        color: #67e8f9;
        font-size: 0.85rem;
    }

    .transition-text {
        color: var(--text-muted);
        font-size: 0.75rem;
    }

    .transition-text strong {
        color: #67e8f9;
    }

    .live-log-done {
        color: #34d399;
        text-align: center;
        padding: 1rem 0;
        font-weight: 600;
        border-top: 1px solid rgba(52, 211, 153, 0.2);
        margin-top: 0.5rem;
    }

    .turn-text {
        color: #d1d5db;
    }

    .turn-sep {
        color: #4b5563;
        margin: 0 0.15rem;
    }

    .live-log-done {
        color: var(--text-faint);
        text-align: center;
        padding: 0.75rem 0;
        border-top: 1px solid var(--border);
        margin-top: 0.5rem;
        font-style: italic;
    }

    /* ── Findings Panel ────────────────────── */
    .findings-panel {
        margin: 0 2rem 0;
        padding: 1.25rem 0;
        border-bottom: 1px solid var(--border);
    }

    .findings-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 0.75rem;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .findings-header-left {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .findings-title {
        font-size: 0.9rem;
        font-weight: 700;
        color: var(--white);
        margin: 0;
    }

    .findings-badges {
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

    .findings-total {
        font-size: 0.7rem;
        color: var(--text-faint);
        margin-left: 0.25rem;
    }

    .finding-count-badge {
        font-size: 0.65rem;
        font-weight: 700;
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
        letter-spacing: 0.02em;
    }

    .finding-count-badge.severity-critical {
        background: rgba(220, 38, 38, 0.2);
        color: #fca5a5;
    }

