---
import Base from '../../layouts/Base.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getTemporalClient, getWorkflowProgress, type PipelineProgress } from '../../lib/temporal.js';
import { resolveEventTypeName, getEventCategory, extractEventDetails } from '../../lib/event-types.js';

const { runId } = Astro.params;

interface WorkflowDetail {
    workflowId: string;
    runId: string;
    status: string;
    type: string;
    taskQueue: string;
    startTime: string;
    closeTime: string | null;
    executionTime: string | null;
    historyLength: number;
    historySize: number;
    memo: Record<string, unknown>;
    searchAttributes: Record<string, unknown>;
    parentExecution: { workflowId: string; runId: string } | null;
    input: unknown;
    result: unknown;
    pendingActivities: number;
}

interface HistoryEvent {
    eventId: number;
    eventType: string;
    eventTime: string | null;
    details: Record<string, string>;
    category: string;
}

let wf: WorkflowDetail | null = null;
let progress: PipelineProgress | null = null;
let events: HistoryEvent[] = [];
let loadError: string | null = null;

try {
    const client = await getTemporalClient();

    // Find workflow by runId
    let workflowId: string | null = null;
    for await (const w of client.workflow.list({ query: `RunId = "${runId}"` })) {
        workflowId = w.workflowId;
        break;
    }

    if (workflowId) {
        const handle = client.workflow.getHandle(workflowId, runId);
        const desc = await handle.describe();

        // Extract search attributes
        const searchAttrs: Record<string, unknown> = {};
        if (desc.searchAttributes) {
            const sa = desc.searchAttributes as any;
            if (sa.indexed) {
                for (const [key, val] of Object.entries(sa.indexed)) {
                    searchAttrs[key] = val;
                }
            }
        }

        wf = {
            workflowId: desc.workflowId,
            runId: desc.runId,
            status: desc.status.name.toLowerCase(),
            type: desc.type,
            taskQueue: desc.taskQueue,
            startTime: desc.startTime?.toISOString() || '',
            closeTime: desc.closeTime?.toISOString() || null,
            executionTime: desc.executionTime?.toISOString() || null,
            historyLength: desc.historyLength,
            historySize: 0,
            memo: (desc.memo as Record<string, unknown>) || {},
            searchAttributes: searchAttrs,
            parentExecution: desc.parentExecution || null,
            input: null,
            result: null,
            pendingActivities: 0,
        };

        // Get progress for running workflows
        if (wf.status === 'running') {
            try {
                progress = await handle.query<PipelineProgress>('getProgress');
            } catch { /* query unavailable */ }
        }

        // Fetch result for completed workflows
        if (wf.status === 'completed') {
            try {
                wf.result = await handle.result();
            } catch { /* no result */ }
        }

        // Fetch history events
        try {
            const history = await handle.fetchHistory();
            const rawEvents = history?.events || [];
            wf.historySize = rawEvents.length;

            // Count pending activities
            const scheduledActivities = new Set<string>();
            const completedActivities = new Set<string>();

            for (const ev of rawEvents) {
                const typeName = resolveEventTypeName(ev.eventType);
                const details = extractEventDetails(ev);
                const category = getEventCategory(typeName);

                // Track pending activities
                const typeStr = String(ev.eventType);
                if (typeStr.includes('ACTIVITY_TASK_SCHEDULED') || typeName.toLowerCase().includes('activity task scheduled')) {
                    scheduledActivities.add(String(ev.eventId));
                }
                if (typeStr.includes('ACTIVITY_TASK_COMPLETED') || typeStr.includes('ACTIVITY_TASK_FAILED') ||
                    typeName.toLowerCase().includes('activity task completed') || typeName.toLowerCase().includes('activity task failed')) {
                    const schedId = details['Scheduled Event']?.replace('#', '');
                    if (schedId) completedActivities.add(schedId);
                }

                // Extract input from WorkflowExecutionStarted
                if (typeName.toLowerCase().includes('workflow execution started')) {
                    const attrs = ev.workflowExecutionStartedEventAttributes;
                    if (attrs?.input?.payloads) {
                        try {
                            const payload = attrs.input.payloads[0];
                            if (payload?.data) {
                                const decoded = Buffer.from(payload.data).toString('utf-8');
                                wf.input = JSON.parse(decoded);
                            }
                        } catch { /* can't decode */ }
                    }
                }

                events.push({
                    eventId: Number(ev.eventId || 0),
                    eventType: typeName,
                    eventTime: ev.eventTime
                        ? new Date(Number(ev.eventTime.seconds) * 1000 + Number(ev.eventTime.nanos || 0) / 1e6).toISOString()
                        : null,
                    details,
                    category,
                });
            }

            // Calculate pending activities
            for (const id of scheduledActivities) {
                if (!completedActivities.has(id)) {
                    wf.pendingActivities++;
                }
            }
        } catch { /* history unavailable */ }
    }
} catch (err) {
    loadError = err instanceof Error ? err.message : 'Failed to load workflow';
}

// Helpers
function formatDateTime(iso: string | null) {
    if (!iso) return '—';
    return new Date(iso).toLocaleString('en-US', {
        month: 'short', day: 'numeric', year: 'numeric',
        hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false,
    });
}

function getElapsed(start: string, end: string | null) {
    const s = new Date(start).getTime();
    const e = end ? new Date(end).getTime() : Date.now();
    const ms = e - s;
    const seconds = Math.floor(ms / 1000);
    const minutes = Math.floor(seconds / 60);
    const hours = Math.floor(minutes / 60);
    if (hours > 0) return `${hours}h ${minutes % 60}m ${seconds % 60}s`;
    if (minutes > 0) return `${minutes}m ${seconds % 60}s`;
    return `${seconds}s`;
}

function formatEventTime(iso: string | null) {
    if (!iso) return '';
    return new Date(iso).toLocaleTimeString('en-US', {
        hour: '2-digit', minute: '2-digit', second: '2-digit',
        fractionalSecondDigits: 2, hour12: false,
    });
}

const agents = progress?.agentMetrics
    ? Object.entries(progress.agentMetrics).map(([name, m]) => ({
        agentName: name,
        model: m.model || '—',
        durationMs: m.durationMs,
        costUsd: m.costUsd ?? 0,
        turns: m.numTurns ?? 0,
        success: progress.completedAgents?.includes(name) ?? false,
        error: progress.failedAgent === name ? progress.error : undefined,
    }))
    : [];
---

<Base title={`${wf?.workflowId || 'Workflow'} — Donna`}>
    <div class="app-shell">
        <Sidebar activePage="workflows" />

        <header class="topbar">
            <div class="topbar-left">
                <div class="topbar-breadcrumb">
                    <a href="/">Workflows</a>
                    <span class="topbar-breadcrumb-sep">/</span>
                    <span style="color: var(--white); font-weight: 600; font-family: var(--font-mono); font-size: 0.8rem;">
                        {wf?.workflowId || runId?.slice(0, 12) + '…'}
                    </span>
                </div>
            </div>
            <div class="topbar-right">
                <button class="btn-icon" title="Refresh" onclick="location.reload()">↻</button>
            </div>
        </header>

        <main class="main-content">
            <div class="wf-detail-container">
                {loadError && (
                    <div class="banner banner-error">⚠ {loadError}</div>
                )}

                {!wf ? (
                    <div class="table-container" style="margin: 2rem;">
                        <div class="empty-state">
                            <div class="empty-state-icon">🔍</div>
                            <h3>Workflow not found</h3>
                            <p>No workflow with run ID <code>{runId}</code></p>
                            <a href="/" class="btn btn-secondary" style="margin-top: 1rem;">← Back</a>
                        </div>
                    </div>
                ) : (
                    <div>
                        {/* ── Workflow Header ─────────────────────────── */}
                        <div class="wf-header">
                            <div class="wf-header-top">
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <a href="/" class="wf-back">← Back to Workflows</a>
                                </div>
                                <div class="wf-header-actions">
                                    {wf.status === 'running' && (
                                        <button class="btn btn-danger" id="cancelBtn"
                                            data-workflow-id={wf.workflowId}
                                            data-run-id={wf.runId}>
                                            Request Cancellation
                                        </button>
                                    )}
                                    <div class="dropdown" id="moreActionsDropdown">
                                        <button class="btn btn-secondary" id="moreActionsBtn">
                                            More Actions ▾
                                        </button>
                                        <div class="dropdown-menu" id="moreActionsMenu">
                                            <button class="dropdown-item" data-action="terminate"
                                                data-workflow-id={wf.workflowId} data-run-id={wf.runId}>
                                                <span class="dropdown-item-icon">⛔</span>
                                                Terminate
                                            </button>
                                            <button class="dropdown-item" data-action="signal"
                                                data-workflow-id={wf.workflowId} data-run-id={wf.runId}>
                                                <span class="dropdown-item-icon">📡</span>
                                                Send Signal
                                            </button>
                                            <div class="dropdown-divider"></div>
                                            <a class="dropdown-item" href={`http://localhost:8233/namespaces/default/workflows/${encodeURIComponent(wf.workflowId)}/${wf.runId}/history`} target="_blank">
                                                <span class="dropdown-item-icon">🔗</span>
                                                Open in Temporal UI
                                            </a>
                                            <button class="dropdown-item" data-action="copy-id"
                                                data-copy-value={wf.workflowId}>
                                                <span class="dropdown-item-icon">📋</span>
                                                Copy Workflow ID
                                            </button>
                                            <button class="dropdown-item" data-action="copy-runid"
                                                data-copy-value={wf.runId}>
                                                <span class="dropdown-item-icon">📋</span>
                                                Copy Run ID
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="wf-header-title">
                                <span class={`status-pill ${wf.status}`}>
                                    <span class={`status-dot ${wf.status === 'running' ? 'pulse' : ''}`}></span>
                                    {wf.status.charAt(0).toUpperCase() + wf.status.slice(1)}
                                </span>
                                <h1>{wf.workflowId}</h1>
                            </div>

                            {/* Info row like Temporal */}
                            <div class="wf-info-row">
                                <div class="wf-info-item">
                                    <span class="wf-info-label">Start</span>
                                    <span class="wf-info-value">{formatDateTime(wf.startTime)}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">End</span>
                                    <span class="wf-info-value">{formatDateTime(wf.closeTime)}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">Duration</span>
                                    <span class="wf-info-value">{getElapsed(wf.startTime, wf.closeTime)}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">Run ID</span>
                                    <span class="wf-info-value mono copyable" data-copy={wf.runId}>
                                        {wf.runId}
                                        <button class="copy-btn" title="Copy">📋</button>
                                    </span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">Workflow Type</span>
                                    <span class="wf-info-value link">{wf.type}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">Task Queue</span>
                                    <span class="wf-info-value link">{wf.taskQueue}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">History Events</span>
                                    <span class="wf-info-value">{wf.historySize}</span>
                                </div>
                                <div class="wf-info-item">
                                    <span class="wf-info-label">State Transitions</span>
                                    <span class="wf-info-value">{wf.historyLength}</span>
                                </div>
                            </div>
                        </div>

                        {/* ── Tab Navigation ─────────────────────────── */}
                        <div class="wf-tabs">
                            <button class="wf-tab active" data-tab="history">
                                History <span class="wf-tab-badge">{wf.historySize}</span>
                            </button>
                            {wf.parentExecution && (
                                <button class="wf-tab" data-tab="relationships">
                                    Relationships
                                </button>
                            )}
                            {progress && (
                                <button class="wf-tab" data-tab="progress">
                                    Progress <span class="wf-tab-badge">{agents.length}</span>
                                </button>
                            )}
                            {wf.status === 'running' && (
                                <button class="wf-tab" data-tab="live-logs">
                                    Live Logs <span class="wf-tab-badge live-badge">LIVE</span>
                                </button>
                            )}
                            {wf.pendingActivities > 0 && (
                                <button class="wf-tab" data-tab="pending">
                                    Pending Activities <span class="wf-tab-badge">{wf.pendingActivities}</span>
                                </button>
                            )}
                            <button class="wf-tab" data-tab="input">Input / Result</button>
                            <button class="wf-tab" data-tab="query">Queries</button>
                            <button class="wf-tab" data-tab="search-attrs">Search Attributes</button>
                            <button class="wf-tab" data-tab="memo">Memo</button>
                        </div>

                        {/* ── Tab: History ─────────────────────────── */}
                        <div class="wf-tab-content active" id="tab-history">
                            <div class="history-toolbar">
                                <div style="display: flex; align-items: center; gap: 0.75rem;">
                                    <span style="font-size: 0.78rem; color: var(--text-dim);">
                                        {events.length} events
                                    </span>
                                    {wf.status === 'running' && (
                                        <label class="auto-refresh-toggle">
                                            <input type="checkbox" id="autoRefreshToggle" />
                                            <span class="toggle-slider"></span>
                                            <span class="toggle-label">Auto Refresh</span>
                                        </label>
                                    )}
                                </div>
                                <div style="display: flex; align-items: center; gap: 0.5rem;">
                                    <button class="btn btn-ghost btn-sm active" id="toggleCompact" data-view="compact">Compact</button>
                                    <button class="btn btn-ghost btn-sm" id="toggleTable" data-view="table">Table</button>
                                    <button class="btn btn-ghost btn-sm" id="toggleJson" data-view="json">JSON</button>
                                    <div class="toolbar-divider" style="height: 18px;"></div>
                                    <button class="btn btn-ghost btn-sm" id="sortAsc" title="Ascending">↑ Asc</button>
                                    <button class="btn btn-ghost btn-sm active" id="sortDesc" title="Descending">↓ Desc</button>
                                    <div class="toolbar-divider" style="height: 18px;"></div>
                                    <button class="btn btn-ghost btn-sm" id="downloadHistory" title="Download history">⬇ Download</button>
                                </div>
                            </div>

                            {/* Compact timeline view (default) */}
                            <div class="history-timeline" id="historyCompact">
                                {events.map((ev) => (
                                    <div class={`history-event ${ev.category}`} data-event-id={ev.eventId}>
                                        <div class="history-event-marker">
                                            <div class={`history-event-dot ${ev.category}`}></div>
                                            {ev.eventId < events.length && <div class="history-event-line"></div>}
                                        </div>
                                        <div class="history-event-content">
                                            <div class="history-event-header">
                                                <span class="history-event-id">#{ev.eventId}</span>
                                                <span class={`history-event-type ${ev.category}`}>{ev.eventType}</span>
                                                {Object.entries(ev.details).length > 0 && (
                                                    <span class="history-event-details">
                                                        {Object.entries(ev.details).map(([k, v]) => (
                                                            <span class="history-detail-tag">
                                                                <span class="detail-key">{k}:</span> {v}
                                                            </span>
                                                        ))}
                                                    </span>
                                                )}
                                                <span class="history-event-time">{formatEventTime(ev.eventTime)}</span>
                                            </div>
                                        </div>
                                    </div>
                                ))}
                            </div>

                            {/* Table view */}
                            <div class="history-table-view" id="historyTable" style="display: none;">
                                <div class="table-container">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th style="width: 60px;">Event ID</th>
                                                <th>Timestamp</th>
                                                <th>Event Type</th>
                                                <th>Details</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {events.map((ev) => (
                                                <tr>
                                                    <td class="cell-duration">#{ev.eventId}</td>
                                                    <td class="cell-time">{formatEventTime(ev.eventTime)}</td>
                                                    <td>
                                                        <span class={`event-type-badge ${ev.category}`}>
                                                            {ev.eventType}
                                                        </span>
                                                    </td>
                                                    <td class="cell-type">
                                                        {Object.entries(ev.details).map(([k, v]) => (
                                                            <span class="history-detail-tag">
                                                                <span class="detail-key">{k}:</span> {v}
                                                            </span>
                                                        ))}
                                                    </td>
                                                </tr>
                                            ))}
                                        </tbody>
                                    </table>
                                </div>
                            </div>

                            {/* JSON view */}
                            <div id="historyJson" style="display: none;">
                                <pre class="json-viewer"><code>{JSON.stringify(events, null, 2)}</code></pre>
                            </div>

                            {events.length === 0 && (
                                <div class="empty-state" style="padding: 3rem;">
                                    <div class="empty-state-icon">📜</div>
                                    <h3>No history events</h3>
                                    <p>History events will appear here as the workflow executes.</p>
                                </div>
                            )}
                        </div>

                        {/* ── Tab: Relationships ─────────────────────── */}
                        {wf.parentExecution && (
                            <div class="wf-tab-content" id="tab-relationships">
                                <div class="json-section">
                                    <h3>Parent Workflow</h3>
                                    <div class="relationship-card">
                                        <div class="relationship-item">
                                            <span class="wf-info-label">Workflow ID</span>
                                            <a href={`/workflow/${wf.parentExecution.runId}`} class="wf-info-value link">
                                                {wf.parentExecution.workflowId}
                                            </a>
                                        </div>
                                        <div class="relationship-item">
                                            <span class="wf-info-label">Run ID</span>
                                            <span class="wf-info-value mono">{wf.parentExecution.runId}</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        )}

                        {/* ── Tab: Progress (Agent Metrics) ─────────── */}
                        {progress && (
                            <div class="wf-tab-content" id="tab-progress">
                                {/* Progress bar */}
                                <div class="progress-card">
                                    <div class="progress-card-header">
                                        <span>Pipeline Progress</span>
                                        <span class="mono" style="color: var(--text-muted);">
                                            {progress.completedAgents?.length || 0} / 13 agents
                                        </span>
                                    </div>
                                    <div class="progress-bar" style="height: 8px; margin: 0.75rem 0;">
                                        <div class="progress-bar-fill" style={`width: ${((progress.completedAgents?.length || 0) / 13) * 100}%`}></div>
                                    </div>
                                    <div style="display: flex; gap: 1.5rem; font-size: 0.8rem;">
                                        {progress.currentPhase && (
                                            <span style="color: var(--text-dim);">
                                                Phase: <strong style="color: var(--info);">{progress.currentPhase}</strong>
                                            </span>
                                        )}
                                        {progress.currentAgent && (
                                            <span style="color: var(--text-dim);">
                                                Agent: <strong style="color: var(--info);">{progress.currentAgent}</strong>
                                            </span>
                                        )}
                                    </div>
                                </div>

                                {/* Agent table */}
                                {agents.length > 0 && (
                                    <div class="table-container" style="margin-top: 1rem;">
                                        <table class="data-table">
                                            <thead>
                                                <tr>
                                                    <th>Status</th>
                                                    <th>Agent</th>
                                                    <th>Model</th>
                                                    <th>Turns</th>
                                                    <th>Cost</th>
                                                    <th>Duration</th>
                                                    <th>Error</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {agents.map((a) => (
                                                    <tr>
                                                        <td>
                                                            <span class={`status-pill ${a.success ? 'completed' : 'failed'}`}>
                                                                <span class="status-dot"></span>
                                                                {a.success ? 'Done' : 'Failed'}
                                                            </span>
                                                        </td>
                                                        <td style="font-weight: 600; color: var(--white);">{a.agentName}</td>
                                                        <td class="cell-type">{a.model}</td>
                                                        <td class="cell-duration">{a.turns}</td>
                                                        <td class="cell-cost">${a.costUsd.toFixed(3)}</td>
                                                        <td class="cell-duration">{Math.round(a.durationMs / 1000)}s</td>
                                                        <td style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.75rem; color: var(--error);">
                                                            {a.error || '—'}
                                                        </td>
                                                    </tr>
                                                ))}
                                            </tbody>
                                        </table>
                                    </div>
                                )}

                                {/* Summary */}
                                {progress.summary && (
                                    <div class="summary-grid">
                                        <div class="summary-item">
                                            <span class="summary-label">Total Cost</span>
                                            <span class="summary-value">${progress.summary.totalCostUsd.toFixed(2)}</span>
                                        </div>
                                        <div class="summary-item">
                                            <span class="summary-label">Total Duration</span>
                                            <span class="summary-value">{Math.round(progress.summary.totalDurationMs / 1000)}s</span>
                                        </div>
                                        <div class="summary-item">
                                            <span class="summary-label">Total Turns</span>
                                            <span class="summary-value">{progress.summary.totalTurns}</span>
                                        </div>
                                        <div class="summary-item">
                                            <span class="summary-label">Agent Count</span>
                                            <span class="summary-value">{progress.summary.agentCount}</span>
                                        </div>
                                    </div>
                                )}
                            </div>
                        )}

                        {/* ── Tab: Pending Activities ─────────────────── */}
                        {wf.pendingActivities > 0 && (
                            <div class="wf-tab-content" id="tab-pending">
                                <div class="table-container">
                                    <table class="data-table">
                                        <thead>
                                            <tr>
                                                <th>Activity Type</th>
                                                <th>Event ID</th>
                                                <th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {events
                                                .filter(ev => ev.eventType.toLowerCase().includes('activity task scheduled'))
                                                .map(ev => (
                                                    <tr>
                                                        <td style="font-weight: 500; color: var(--white);">
                                                            {ev.details['Activity Type'] || 'Unknown'}
                                                        </td>
                                                        <td class="cell-duration">#{ev.eventId}</td>
                                                        <td>
                                                            {events.some(e =>
                                                                (e.eventType.toLowerCase().includes('activity task completed') ||
                                                                 e.eventType.toLowerCase().includes('activity task failed')) &&
                                                                e.details['Scheduled Event'] === `#${ev.eventId}`
                                                            ) ? (
                                                                <span class="status-pill completed"><span class="status-dot"></span> Done</span>
                                                            ) : (
                                                                <span class="status-pill running"><span class="status-dot pulse"></span> Pending</span>
                                                            )}
                                                        </td>
                                                    </tr>
                                                ))
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        )}

                        {/* ── Tab: Live Logs ────────────────────────── */}
                        {wf.status === 'running' && (
                            <div class="wf-tab-content" id="tab-live-logs">
                                <div class="live-logs-header">
                                    <div class="live-logs-status">
                                        <span class="live-dot pulse"></span>
                                        <span class="live-label">Streaming agent turns</span>
                                        <span class="live-agent" id="liveAgent">—</span>
                                    </div>
                                    <div class="live-logs-controls">
                                        <span class="live-elapsed" id="liveElapsed">—</span>
                                        <label class="auto-scroll-toggle">
                                            <input type="checkbox" id="autoScrollToggle" checked />
                                            <span class="toggle-slider"></span>
                                            <span class="toggle-label">Auto-scroll</span>
                                        </label>
                                    </div>
                                </div>
                                <div class="live-logs-viewer" id="liveLogsViewer">
                                    <div class="live-logs-empty" id="liveLogsEmpty">
                                        Waiting for agent turn data...
                                    </div>
                                </div>
                            </div>
                        )}

                        {/* ── Tab: Input / Result ─────────────────────── */}
                        <div class="wf-tab-content" id="tab-input">
                            <div class="json-section">
                                <div class="json-section-header">
                                    <h3>Input</h3>
                                    {wf.input && (
                                        <button class="btn btn-ghost btn-sm copy-json-btn" data-json={JSON.stringify(wf.input, null, 2)}>
                                            📋 Copy
                                        </button>
                                    )}
                                </div>
                                <pre class="json-viewer"><code>{wf.input ? JSON.stringify(wf.input, null, 2) : '(no input captured)'}</code></pre>
                            </div>
                            <div class="json-section">
                                <div class="json-section-header">
                                    <h3>Result</h3>
                                    {wf.result && (
                                        <button class="btn btn-ghost btn-sm copy-json-btn" data-json={JSON.stringify(wf.result, null, 2)}>
                                            📋 Copy
                                        </button>
                                    )}
                                </div>
                                <pre class="json-viewer"><code>{wf.result ? JSON.stringify(wf.result, null, 2) : wf.status === 'running' ? '(workflow still running)' : '(no result)'}</code></pre>
                            </div>
                        </div>

                        {/* ── Tab: Queries ─────────────────────────── */}
                        <div class="wf-tab-content" id="tab-query">
                            <div class="query-panel">
                                <div class="query-form">
                                    <div>
                                        <label class="query-label">Query Type</label>
                                        <select class="query-select" id="queryType">
                                            <option value="getProgress">getProgress</option>
                                            <option value="__stack_trace">__stack_trace</option>
                                        </select>
                                    </div>
                                    <div>
                                        <label class="query-label">Query Arg</label>
                                        <textarea class="query-input" id="queryArg" rows="3" placeholder="(only single JSON payload supported)"></textarea>
                                    </div>
                                    <button class="btn btn-primary" id="runQueryBtn" data-workflow-id={wf.workflowId} data-run-id={wf.runId}>
                                        Run Query
                                    </button>
                                </div>
                                <div class="query-result">
                                    <h3>Result</h3>
                                    <pre class="json-viewer" id="queryResult"><code>Run a query to see results</code></pre>
                                </div>
                            </div>
                        </div>

                        {/* ── Tab: Search Attributes ─────────────────── */}
                        <div class="wf-tab-content" id="tab-search-attrs">
                            <div class="json-section">
                                <h3>Search Attributes</h3>
                                <pre class="json-viewer"><code>{Object.keys(wf.searchAttributes || {}).length > 0 ? JSON.stringify(wf.searchAttributes, null, 2) : '(no search attributes set)'}</code></pre>
                            </div>
                        </div>

                        {/* ── Tab: Memo ─────────────────────────── */}
                        <div class="wf-tab-content" id="tab-memo">
                            <div class="json-section">
                                <h3>Memo</h3>
                                <pre class="json-viewer"><code>{Object.keys(wf.memo || {}).length > 0 ? JSON.stringify(wf.memo, null, 2) : '(no memo set)'}</code></pre>
                            </div>
                        </div>

                        {/* Error for failed workflows */}
                        {progress?.error && (
                            <div class="error-card">
                                <h3>Error</h3>
                                <pre class="error-pre">{progress.error}</pre>
                            </div>
                        )}
                    </div>
                )}
            </div>
        </main>
    </div>

    {/* Tab switching + Query runner + More Actions + History views */}
    <script is:inline>
        // ── Tab switching ──────────────────────────
        document.querySelectorAll('.wf-tab').forEach(tab => {
            tab.addEventListener('click', () => {
                document.querySelectorAll('.wf-tab').forEach(t => t.classList.remove('active'));
                document.querySelectorAll('.wf-tab-content').forEach(c => c.classList.remove('active'));
                tab.classList.add('active');
                const target = tab.dataset.tab;
                document.getElementById('tab-' + target)?.classList.add('active');
            });
        });

        // ── Copy buttons ──────────────────────────
        document.querySelectorAll('.copyable').forEach(el => {
            el.querySelector('.copy-btn')?.addEventListener('click', (e) => {
                e.stopPropagation();
                const text = el.dataset.copy || el.textContent;
                navigator.clipboard.writeText(text).then(() => {
                    const btn = el.querySelector('.copy-btn');
                    if (btn) { btn.textContent = '✓'; setTimeout(() => btn.textContent = '📋', 1500); }
                });
            });
        });

        // ── Copy JSON buttons ──────────────────────
        document.querySelectorAll('.copy-json-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const json = btn.dataset.json;
                if (json) {
                    navigator.clipboard.writeText(json).then(() => {
                        btn.textContent = '✓ Copied';
                        setTimeout(() => { btn.textContent = '📋 Copy'; }, 1500);
                    });
                }
            });
        });

        // ── More Actions dropdown ──────────────────
        const moreBtn = document.getElementById('moreActionsBtn');
        const moreMenu = document.getElementById('moreActionsMenu');
        if (moreBtn && moreMenu) {
            moreBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                moreMenu.classList.toggle('open');
            });

            // Close on click outside
            document.addEventListener('click', () => {
                moreMenu.classList.remove('open');
            });

            moreMenu.addEventListener('click', (e) => {
                e.stopPropagation();
            });

            // Handle dropdown actions
            moreMenu.querySelectorAll('.dropdown-item').forEach(item => {
                item.addEventListener('click', async () => {
                    const action = item.dataset.action;
                    moreMenu.classList.remove('open');

                    if (action === 'copy-id' || action === 'copy-runid') {
                        const val = item.dataset.copyValue;
                        if (val) {
                            await navigator.clipboard.writeText(val);
                            const origText = item.innerHTML;
                            item.innerHTML = '<span class="dropdown-item-icon">✓</span> Copied!';
                            setTimeout(() => { item.innerHTML = origText; }, 1500);
                        }
                    } else if (action === 'terminate') {
                        if (confirm('Are you sure you want to terminate this workflow? This cannot be undone.')) {
                            try {
                                const runId = item.dataset.runId;
                                const res = await fetch('/api/workflow/' + runId + '?action=terminate', { method: 'POST' });
                                if (res.ok) {
                                    alert('Workflow terminated. Refreshing...');
                                    location.reload();
                                } else {
                                    alert('Failed to terminate: ' + (await res.text()));
                                }
                            } catch (err) {
                                alert('Error: ' + err.message);
                            }
                        }
                    } else if (action === 'signal') {
                        const signalName = prompt('Signal name:');
                        if (signalName) {
                            alert('Signal sending not yet implemented. Use Temporal CLI:\ntctl workflow signal --workflow-id ' + item.dataset.workflowId + ' --name ' + signalName);
                        }
                    }
                });
            });
        }

        // ── Request Cancellation button ──────────────
        const cancelBtn = document.getElementById('cancelBtn');
        if (cancelBtn) {
            cancelBtn.addEventListener('click', async () => {
                if (!confirm('Are you sure you want to cancel this workflow?')) return;
                try {
                    const runId = cancelBtn.dataset.runId;
                    const res = await fetch('/api/workflow/' + runId + '?action=cancel', { method: 'POST' });
                    if (res.ok) {
                        alert('Cancellation requested. Refreshing...');
                        location.reload();
                    } else {
                        alert('Failed to cancel: ' + (await res.text()));
                    }
                } catch (err) {
                    alert('Error: ' + err.message);
                }
            });
        }

        // ── History view switching ──────────────────
        const viewBtns = document.querySelectorAll('[data-view]');
        viewBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                viewBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                const view = btn.dataset.view;
                document.getElementById('historyCompact').style.display = view === 'compact' ? '' : 'none';
                document.getElementById('historyTable').style.display = view === 'table' ? '' : 'none';
                document.getElementById('historyJson').style.display = view === 'json' ? '' : 'none';
            });
        });

        // ── Sort direction ──────────────────────────
        const sortAsc = document.getElementById('sortAsc');
        const sortDesc = document.getElementById('sortDesc');
        const timeline = document.getElementById('historyCompact');
        const tableBody = document.querySelector('#historyTable tbody');

        function reverseChildren(parent) {
            if (!parent) return;
            const children = Array.from(parent.children);
            children.reverse().forEach(c => parent.appendChild(c));
        }

        if (sortAsc && sortDesc) {
            sortAsc.addEventListener('click', () => {
                sortAsc.classList.add('active');
                sortDesc.classList.remove('active');
                reverseChildren(timeline);
                reverseChildren(tableBody);
            });
            sortDesc.addEventListener('click', () => {
                sortDesc.classList.add('active');
                sortAsc.classList.remove('active');
                reverseChildren(timeline);
                reverseChildren(tableBody);
            });
        }

        // ── Download history ──────────────────────
        document.getElementById('downloadHistory')?.addEventListener('click', () => {
            const jsonCode = document.querySelector('#historyJson code');
            if (jsonCode) {
                const blob = new Blob([jsonCode.textContent], { type: 'application/json' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'workflow-history.json';
                a.click();
                URL.revokeObjectURL(url);
            }
        });

        // ── Auto refresh ──────────────────────────
        let autoRefreshInterval = null;
        const autoRefreshToggle = document.getElementById('autoRefreshToggle');
        if (autoRefreshToggle) {
            autoRefreshToggle.addEventListener('change', () => {
                if (autoRefreshToggle.checked) {
                    autoRefreshInterval = setInterval(() => location.reload(), 5000);
                } else {
                    clearInterval(autoRefreshInterval);
                    autoRefreshInterval = null;
                }
            });
        }

        // ── Live Logs Polling ──────────────────────
        (function initLiveLogs() {
            const viewer = document.getElementById('liveLogsViewer');
            const emptyMsg = document.getElementById('liveLogsEmpty');
            const agentLabel = document.getElementById('liveAgent');
            const elapsedLabel = document.getElementById('liveElapsed');
            const autoScrollToggle = document.getElementById('autoScrollToggle');

            if (!viewer) return; // Not a running workflow

            const POLL_INTERVAL = 3000;
            let pollTimer = null;
            let seenLines = new Set();
            let isPolling = false;

            function formatElapsed(seconds) {
                const m = Math.floor(seconds / 60);
                const s = seconds % 60;
                if (m > 0) return m + 'm ' + s + 's';
                return s + 's';
            }

            function appendLine(text) {
                if (seenLines.has(text)) return;
                seenLines.add(text);

                if (emptyMsg && emptyMsg.parentNode) {
                    emptyMsg.remove();
                }

                const line = document.createElement('div');
                line.className = 'live-log-line';

                // Color code based on content
                if (text.includes('Turn ')) {
                    line.classList.add('turn-line');
                }

                // Extract turn number for styling
                const turnMatch = text.match(/^Turn (\d+)/);
                if (turnMatch) {
                    const num = document.createElement('span');
                    num.className = 'turn-number';
                    num.textContent = 'T' + turnMatch[1];
                    line.appendChild(num);

                    const rest = text.slice(text.indexOf('):') + 2).trim() || text.slice(turnMatch[0].length);
                    const agentMatch = text.match(/\(([^)]+)\)/);

                    if (agentMatch) {
                        const agentSpan = document.createElement('span');
                        agentSpan.className = 'turn-agent';
                        agentSpan.textContent = agentMatch[1];
                        line.appendChild(agentSpan);
                    }

                    const content = document.createElement('span');
                    content.className = 'turn-content';
                    content.textContent = rest;
                    line.appendChild(content);
                } else {
                    line.textContent = text;
                }

                viewer.appendChild(line);

                // Auto-scroll
                if (autoScrollToggle && autoScrollToggle.checked) {
                    viewer.scrollTop = viewer.scrollHeight;
                }
            }

            async function poll() {
                if (isPolling) return;
                isPolling = true;

                try {
                    const runId = window.location.pathname.split('/').pop();
                    const res = await fetch('/api/workflow/' + runId);
                    if (!res.ok) return;

                    const data = await res.json();

                    // Check if workflow is still running
                    if (data.status !== 'running') {
                        stopPolling();
                        const done = document.createElement('div');
                        done.className = 'live-log-line live-log-done';
                        done.textContent = '--- Workflow ' + data.status + ' ---';
                        viewer.appendChild(done);
                        // Hide the live dot
                        const dot = document.querySelector('.live-dot');
                        if (dot) dot.classList.remove('pulse');
                        return;
                    }

                    // Update agent and elapsed from heartbeats
                    if (data.heartbeats && data.heartbeats.length > 0) {
                        for (const hb of data.heartbeats) {
                            if (hb.agent && agentLabel) {
                                agentLabel.textContent = hb.agent;
                            }
                            if (hb.elapsedSeconds && elapsedLabel) {
                                elapsedLabel.textContent = formatElapsed(hb.elapsedSeconds);
                            }
                            // Append turn lines
                            if (Array.isArray(hb.recentTurns)) {
                                for (const turn of hb.recentTurns) {
                                    appendLine(turn);
                                }
                            }
                        }
                    }

                    // Also extract info from progress query
                    if (data.progress) {
                        if (data.progress.currentAgent && agentLabel) {
                            agentLabel.textContent = data.progress.currentAgent;
                        }
                    }
                } catch (e) {
                    // Silently ignore poll errors
                } finally {
                    isPolling = false;
                }
            }

            function startPolling() {
                if (pollTimer) return;
                poll(); // Initial fetch
                pollTimer = setInterval(poll, POLL_INTERVAL);
            }

            function stopPolling() {
                if (pollTimer) {
                    clearInterval(pollTimer);
                    pollTimer = null;
                }
            }

            // Start polling when tab is visible
            startPolling();

            // Pause when page is hidden
            document.addEventListener('visibilitychange', function() {
                if (document.hidden) {
                    stopPolling();
                } else {
                    startPolling();
                }
            });
        })();

        // ── Query runner ──────────────────────────
        document.getElementById('runQueryBtn')?.addEventListener('click', async () => {
            const btn = document.getElementById('runQueryBtn');
            const queryType = document.getElementById('queryType').value;
            const resultEl = document.querySelector('#queryResult code');
            resultEl.textContent = 'Running query...';

            try {
                const res = await fetch('/api/workflow/' + btn.dataset.runId + '?query=' + encodeURIComponent(queryType));
                const data = await res.json();
                if (data.progress) {
                    resultEl.textContent = JSON.stringify(data.progress, null, 2);
                } else {
                    resultEl.textContent = JSON.stringify(data, null, 2);
                }
            } catch (err) {
                resultEl.textContent = 'Error: ' + err.message;
            }
        });
    </script>
</Base>

<style is:global>
