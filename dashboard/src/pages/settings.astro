import Base from '../layouts/Base.astro';
import Sidebar from '../components/Sidebar.astro';
import { getVersion } from '../lib/version';

const donnaVersion = getVersion();

const session = (Astro.locals as any).session;
const user = session?.user;
---

<Base title="Settings — Donna Dashboard">
    <div class="app-shell">
        <Sidebar activePage="settings" />

        <header class="topbar">
            <div class="topbar-left">
                <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Open menu">☰</button>
                <div class="topbar-breadcrumb">
                    <span style="color: var(--text-dim);">default</span>
                    <span class="topbar-breadcrumb-sep">/</span>
                    <span style="color: var(--white); font-weight: 600;">Settings</span>
                </div>
            </div>
            <div class="topbar-right">
                <span class="version-badge">v{donnaVersion}</span>
            </div>
        </header>

        <main class="main-content">
            <div class="page-container">
                <div class="page-header">
                    <div class="page-header-left">
                        <div>
                            <h1 class="page-title">
                                <span class="gradient-text">Settings</span>
                            </h1>
                            <p class="page-subtitle">Manage your account and LLM providers</p>
                        </div>
                    </div>
                </div>

                <!-- Account Info -->
                <div class="settings-section">
                    <h2 class="settings-section-title">Account</h2>
                    <div class="settings-card">
                        <div class="settings-row">
                            <span class="settings-label">Email</span>
                            <span class="settings-value">{user?.email || '—'}</span>
                        </div>
                        <div class="settings-row">
                            <span class="settings-label">Name</span>
                            <span class="settings-value">{user?.name || '—'}</span>
                        </div>
                    </div>
                </div>

                <!-- LLM Providers -->
                <div class="settings-section">
                    <h2 class="settings-section-title">LLM Providers</h2>
                    <p class="settings-section-desc">Configure local or custom LLM endpoints for scanning. These providers appear in the model selector when starting a scan.</p>

                    <div class="settings-card llm-provider-card">
                        <div class="llm-provider-header">
                            <div class="llm-provider-title">
                                <span class="model-badge model-qwen">qwen</span>
                                <span class="llm-provider-name">Qwen Local (vLLM / OpenAI-compatible)</span>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" id="qwenEnabled" />
                                <span class="toggle-slider"></span>
                            </label>
                        </div>

                        <div class="llm-provider-fields" id="qwenFields">
                            <div class="form-group">
                                <label class="form-label" for="qwenBaseUrl">Base URL</label>
                                <input type="url" id="qwenBaseUrl" class="form-input" placeholder="http://host.docker.internal:8000" />
                                <small class="form-hint">OpenAI-compatible API endpoint (vLLM, Ollama, TGI, etc.)</small>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="qwenApiKey">API Key <span style="color: var(--text-muted); font-weight: normal;">(optional)</span></label>
                                <input type="password" id="qwenApiKey" class="form-input" placeholder="Leave empty if not required" autocomplete="off" />
                                <small class="form-hint">API key for the endpoint. Often not required for local models.</small>
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="qwenModel">Model Name</label>
                                <input type="text" id="qwenModel" class="form-input" placeholder="Qwen/Qwen3.5-35B-A3B-FP8" />
                                <small class="form-hint">Model ID as served by your endpoint. Used for all tiers (small/medium/large).</small>
                            </div>
                            <div class="llm-provider-actions">
                                <button class="btn btn-sm btn-secondary" id="qwenTestBtn">
                                    <span id="qwenTestLabel">Test Connection</span>
                                    <span id="qwenTestSpinner" style="display: none;">Testing...</span>
                                </button>
                                <span id="qwenTestResult" class="llm-test-result"></span>
                            </div>
                        </div>

                        <div id="llmError" class="settings-error" style="display: none;"></div>
                        <div id="llmSuccess" class="settings-success" style="display: none;"></div>

                        <div class="llm-provider-footer">
                            <button class="btn btn-primary" id="llmSaveBtn">
                                <span id="llmSaveLabel">Save LLM Settings</span>
                                <span id="llmSaveSpinner" style="display: none;">Saving...</span>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Change Password -->
                <div class="settings-section">
                    <h2 class="settings-section-title">Change Password</h2>
                    <div class="settings-card">
                        <form id="passwordForm" class="password-form">
                            <div class="form-group">
                                <label class="form-label" for="currentPassword">Current Password</label>
                                <input type="password" id="currentPassword" class="form-input" required autocomplete="current-password" />
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="newPassword">New Password</label>
                                <input type="password" id="newPassword" class="form-input" required minlength="6" autocomplete="new-password" />
                            </div>
                            <div class="form-group">
                                <label class="form-label" for="confirmPassword">Confirm New Password</label>
                                <input type="password" id="confirmPassword" class="form-input" required minlength="6" autocomplete="new-password" />
                            </div>
                            <div id="pwError" class="settings-error" style="display: none;"></div>
                            <div id="pwSuccess" class="settings-success" style="display: none;"></div>
                            <button type="submit" class="btn btn-primary" id="pwSubmit">
                                <span id="pwLabel">Update Password</span>
                                <span id="pwSpinner" style="display: none;">Updating…</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script is:inline>
        // ── LLM Provider Settings ──────────────────
        (async function initLlmSettings() {
            const enabledCb = document.getElementById('qwenEnabled');
            const fieldsEl = document.getElementById('qwenFields');
            const baseUrlEl = document.getElementById('qwenBaseUrl');
            const apiKeyEl = document.getElementById('qwenApiKey');
            const modelEl = document.getElementById('qwenModel');
            const saveBtn = document.getElementById('llmSaveBtn');
            const testBtn = document.getElementById('qwenTestBtn');
            const llmError = document.getElementById('llmError');
            const llmSuccess = document.getElementById('llmSuccess');
            const testResult = document.getElementById('qwenTestResult');

            // Toggle field visibility
            function updateFieldsVisibility() {
                fieldsEl.style.opacity = enabledCb.checked ? '1' : '0.4';
                fieldsEl.style.pointerEvents = enabledCb.checked ? '' : 'none';
            }
            enabledCb.addEventListener('change', updateFieldsVisibility);

            // Load current settings
            try {
                const res = await fetch('/api/settings/llm');
                if (res.ok) {
                    const settings = await res.json();
                    const qwen = settings.providers?.['qwen-local'];
                    if (qwen) {
                        enabledCb.checked = qwen.enabled || false;
                        baseUrlEl.value = qwen.baseUrl || '';
                        apiKeyEl.value = qwen.apiKey || '';
                        modelEl.value = qwen.model || '';
                    }
                }
            } catch (e) {
                console.error('Failed to load LLM settings:', e);
            }
            updateFieldsVisibility();

            // Save settings
            saveBtn.addEventListener('click', async () => {
                llmError.style.display = 'none';
                llmSuccess.style.display = 'none';
                saveBtn.disabled = true;
                document.getElementById('llmSaveLabel').style.display = 'none';
                document.getElementById('llmSaveSpinner').style.display = '';

                try {
                    const payload = {
                        providers: {
                            'qwen-local': {
                                enabled: enabledCb.checked,
                                baseUrl: baseUrlEl.value.trim(),
                                apiKey: apiKeyEl.value,
                                model: modelEl.value.trim(),
                            },
                        },
                    };

                    const res = await fetch('/api/settings/llm', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(payload),
                    });

                    if (!res.ok) {
                        const data = await res.json().catch(() => ({}));
                        throw new Error(data.error || 'Failed to save settings');
                    }

                    llmSuccess.textContent = 'LLM settings saved successfully!';
                    llmSuccess.style.display = 'block';
                } catch (err) {
                    llmError.textContent = err.message || 'Failed to save settings';
                    llmError.style.display = 'block';
                } finally {
                    saveBtn.disabled = false;
                    document.getElementById('llmSaveLabel').style.display = '';
                    document.getElementById('llmSaveSpinner').style.display = 'none';
                }
            });

            // Test connection
            testBtn.addEventListener('click', async () => {
                testResult.textContent = '';
                testResult.className = 'llm-test-result';
                testBtn.disabled = true;
                document.getElementById('qwenTestLabel').style.display = 'none';
                document.getElementById('qwenTestSpinner').style.display = '';

                const baseUrl = baseUrlEl.value.trim().replace(/\/+$/, '');
                const apiKey = apiKeyEl.value;

                if (!baseUrl) {
                    testResult.textContent = 'Enter a base URL first';
                    testResult.classList.add('test-error');
                    testBtn.disabled = false;
                    document.getElementById('qwenTestLabel').style.display = '';
                    document.getElementById('qwenTestSpinner').style.display = 'none';
                    return;
                }

                try {
                    // Test via server-side proxy (browser can't reach server-local URLs)
                    const res = await fetch('/api/settings/llm', {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ baseUrl, apiKey }),
                    });

                    const data = await res.json();

                    if (res.ok && data.ok) {
                        const modelNames = (data.models || []).join(', ');
                        testResult.textContent = `Connected! ${data.modelCount} model(s): ${modelNames}`;
                        testResult.classList.add('test-success');
                    } else {
                        testResult.textContent = `Connection failed: ${data.error || 'Unknown error'}`;
                        testResult.classList.add('test-error');
                    }
                } catch (err) {
                    testResult.textContent = `Connection failed: ${err.message || 'Network error'}`;
                    testResult.classList.add('test-error');
                } finally {
                    testBtn.disabled = false;
                    document.getElementById('qwenTestLabel').style.display = '';
                    document.getElementById('qwenTestSpinner').style.display = 'none';
                }
            });
        })();

        // ── Password Form ──────────────────────────
        const form = document.getElementById('passwordForm');
        const errorEl = document.getElementById('pwError');
        const successEl = document.getElementById('pwSuccess');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            errorEl.style.display = 'none';
            successEl.style.display = 'none';

            const currentPassword = document.getElementById('currentPassword').value;
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;

            if (newPassword !== confirmPassword) {
                errorEl.textContent = 'New passwords do not match.';
                errorEl.style.display = 'block';
                return;
            }

            if (newPassword.length < 6) {
                errorEl.textContent = 'Password must be at least 6 characters.';
                errorEl.style.display = 'block';
                return;
            }

            const btn = document.getElementById('pwSubmit');
            const label = document.getElementById('pwLabel');
            const spinner = document.getElementById('pwSpinner');
            btn.disabled = true;
            label.style.display = 'none';
            spinner.style.display = '';

            try {
                const res = await fetch('/api/auth/change-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ currentPassword, newPassword }),
                });

                if (!res.ok) {
                    const data = await res.json().catch(() => ({}));
                    throw new Error(data.message || 'Failed to update password');
                }

                successEl.textContent = 'Password updated successfully!';
                successEl.style.display = 'block';
                form.reset();
            } catch (err) {
                errorEl.textContent = err.message || 'Failed to update password';
                errorEl.style.display = 'block';
            } finally {
                btn.disabled = false;
                label.style.display = '';
                spinner.style.display = 'none';
            }
        });
    </script>
</Base>

<style is:global>
    .settings-section {
        margin-bottom: 2rem;
    }

    .settings-section-title {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--white);
        margin-bottom: 0.75rem;
    }

    .settings-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
    }

    .settings-row {
        display: flex;
        align-items: center;
        padding: 0.5rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    }

    .settings-row:last-child {
        border-bottom: none;
    }

    .settings-label {
        font-size: 0.8rem;
        color: var(--text-dim);
        width: 120px;
        flex-shrink: 0;
    }

    .settings-value {
        font-size: 0.8rem;
        color: var(--text);
        font-family: var(--font-mono);
    }

    .password-form {
        max-width: 400px;
    }

    .password-form .form-group {
        margin-bottom: 1rem;
    }

    .settings-error {
        background: var(--error-bg);
        border: 1px solid var(--error-border);
        color: var(--error);
        font-size: 0.8rem;
        padding: 0.6rem 0.85rem;
        border-radius: var(--radius);
        margin-bottom: 1rem;
    }

    .settings-success {
        background: var(--success-bg);
        border: 1px solid var(--success-border);
        color: var(--success);
        font-size: 0.8rem;
        padding: 0.6rem 0.85rem;
        border-radius: var(--radius);
        margin-bottom: 1rem;
    }

    .settings-section-desc {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 1rem;
        line-height: 1.5;
    }

    .llm-provider-card {
        position: relative;
    }

    .llm-provider-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.25rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .llm-provider-title {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .llm-provider-name {
        font-size: 0.85rem;
        color: var(--text);
        font-weight: 500;
    }

    /* Toggle switch */
    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 40px;
        height: 22px;
        cursor: pointer;
    }

    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .toggle-slider {
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, 0.1);
        border-radius: 22px;
        transition: background 0.2s;
    }

    .toggle-slider::before {
        content: '';
        position: absolute;
        left: 3px;
        top: 3px;
        width: 16px;
        height: 16px;
        background: var(--text-dim);
        border-radius: 50%;
        transition: transform 0.2s, background 0.2s;
    }

    .toggle-switch input:checked + .toggle-slider {
        background: var(--primary);
    }

    .toggle-switch input:checked + .toggle-slider::before {
        transform: translateX(18px);
        background: var(--white);
    }

    .llm-provider-fields {
        transition: opacity 0.2s;
    }

    .llm-provider-fields .form-group {
        margin-bottom: 1rem;
        max-width: 500px;
    }

    .form-hint {
        display: block;
        font-size: 0.72rem;
        color: var(--text-muted);
        margin-top: 0.35rem;
        line-height: 1.4;
    }

    .llm-provider-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-top: 0.5rem;
        margin-bottom: 1rem;
    }

    .btn-sm {
        padding: 0.35rem 0.75rem;
        font-size: 0.75rem;
    }

    .llm-test-result {
        font-size: 0.78rem;
        font-family: var(--font-mono);
    }

    .llm-test-result.test-success {
        color: var(--success);
    }

    .llm-test-result.test-error {
        color: var(--error);
    }

    .llm-provider-footer {
        margin-top: 1.25rem;
        padding-top: 1rem;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .model-badge {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 0.15rem 0.45rem;
        border-radius: 4px;
        text-transform: uppercase;
        letter-spacing: 0.03em;
    }

    .model-badge.model-qwen {
        background: rgba(139, 92, 246, 0.15);
        color: rgb(167, 139, 250);
        border: 1px solid rgba(139, 92, 246, 0.3);
    }

    @media (max-width: 768px) {
        .settings-card {
            padding: 1rem;
        }

        .settings-row {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.25rem;
        }

        .settings-label {
            width: auto;
        }

        .password-form {
            max-width: none;
        }
    }
</style>
