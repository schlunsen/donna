---
// Donna - Continuous AI Pentesting Platform
//
// This program is free software: you can redistribute it and/or modify
// it under the terms of the GNU Affero General Public License version 3
// as published by the Free Software Foundation.

// Presentation page — no auth required (public route)
// Prerender as static HTML for GitHub Pages deployment
export const prerender = true;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Donna — AI-Powered Pentesting Presentation</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/presentation-styles.css" />
    <script is:inline src="/three.min.js"></script>
</head>
<body>

  <!-- Three.js background canvas -->
  <canvas id="bg-canvas"></canvas>

  <div class="presentation" id="presentation">
    <!-- Slide Counter -->
    <div class="slide-counter" id="slide-counter">1 / 10</div>

    <!-- Audio Controls -->
    <div class="audio-controls" id="audio-controls">
      <!-- Narration toggle -->
      <button class="audio-toggle" id="audio-toggle" aria-label="Toggle narration audio" title="Toggle narration (A)">
        <svg class="audio-icon audio-on" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
          <path d="M15.54 8.46a5 5 0 0 1 0 7.07" />
          <path d="M19.07 4.93a10 10 0 0 1 0 14.14" />
        </svg>
        <svg class="audio-icon audio-off" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="display:none">
          <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5" />
          <line x1="23" y1="9" x2="17" y2="15" />
          <line x1="17" y1="9" x2="23" y2="15" />
        </svg>
      </button>
      <input type="range" class="volume-slider" id="volume-slider" min="0" max="100" value="80" aria-label="Narration volume" title="Narration volume" />
      <div class="audio-progress" id="audio-progress">
        <div class="audio-progress-bar" id="audio-progress-bar"></div>
      </div>

      <span class="audio-divider"></span>

      <!-- Background music toggle -->
      <button class="audio-toggle" id="music-toggle" aria-label="Toggle background music" title="Toggle music (M)">
        <svg class="audio-icon audio-on" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M9 18V5l12-2v13" />
          <circle cx="6" cy="18" r="3" />
          <circle cx="18" cy="16" r="3" />
        </svg>
        <svg class="audio-icon audio-off" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="display:none">
          <path d="M9 18V5l12-2v13" />
          <circle cx="6" cy="18" r="3" />
          <circle cx="18" cy="16" r="3" />
          <line x1="1" y1="1" x2="23" y2="23" stroke-width="2.5" />
        </svg>
      </button>
      <input type="range" class="volume-slider" id="music-volume-slider" min="0" max="100" value="50" aria-label="Music volume" title="Music volume" />
    </div>

    <!-- Play Overlay -->
    <div class="play-overlay" id="play-overlay">
      <button class="play-overlay-btn" id="play-overlay-btn" aria-label="Start presentation">
        <svg viewBox="0 0 80 80" width="80" height="80" fill="none">
          <circle cx="40" cy="40" r="38" stroke="#7B2D8E" stroke-width="2" opacity="0.6" />
          <polygon points="32,22 32,58 60,40" fill="#7B2D8E" opacity="0.9" />
        </svg>
        <span>Start Presentation</span>
      </button>
    </div>

    <!-- Progress Dots -->
    <div class="progress-dots" id="progress-dots">
      <button class="dot active" data-slide="0" aria-label="Go to slide 1"></button>
      <button class="dot" data-slide="1" aria-label="Go to slide 2"></button>
      <button class="dot" data-slide="2" aria-label="Go to slide 3"></button>
      <button class="dot" data-slide="3" aria-label="Go to slide 4"></button>
      <button class="dot" data-slide="4" aria-label="Go to slide 5"></button>
      <button class="dot" data-slide="5" aria-label="Go to slide 6"></button>
      <button class="dot" data-slide="6" aria-label="Go to slide 7"></button>
      <button class="dot" data-slide="7" aria-label="Go to slide 8"></button>
      <button class="dot" data-slide="8" aria-label="Go to slide 9"></button>
      <button class="dot" data-slide="9" aria-label="Go to slide 10"></button>
    </div>

    <!-- Navigation Arrows -->
    <button class="nav-arrow nav-prev" id="nav-prev" aria-label="Previous slide">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M15 18l-6-6 6-6" />
      </svg>
    </button>
    <button class="nav-arrow nav-next" id="nav-next" aria-label="Next slide">
      <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <path d="M9 18l6-6-6-6" />
      </svg>
    </button>

    <!-- ============ SLIDE 1: Title ============ -->
    <section class="slide slide-active" data-index="0">
      <div class="slide-content slide-title-layout">
        <div class="title-icon" aria-hidden="true">
          <img src="/presentation-images/slide-01-title.svg" alt="" width="220" height="220" />
        </div>
        <p class="slide-eyebrow">Autonomous Security Testing</p>
        <h1 class="slide-main-title">Donna</h1>
        <p class="slide-subtitle-big">AI-Powered Pentesting</p>
        <p class="slide-tagline">13 AI agents. One mission. Find every vulnerability before attackers do.</p>
        <p class="slide-date">2026</p>
      </div>
    </section>

    <!-- ============ SLIDE 2: The Why ============ -->
    <section class="slide" data-index="1">
      <div class="philosophy-bg-img" aria-hidden="true">
        <img src="/presentation-images/slide-02-why.png" alt="" />
      </div>
      <div class="slide-content slide-center-layout slide-philosophy">
        <p class="slide-eyebrow">The Question</p>
        <h2 class="slide-heading slide-heading-big philosophy-heading">What if security testing<br/>never sleeps?</h2>
        <div class="philosophy-points">
          <div class="philosophy-point" data-delay="0">
            <span class="philosophy-icon">
              <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="#F87171" stroke-width="1.5">
                <circle cx="16" cy="16" r="13" /><path d="M16 8v8l5 5" />
              </svg>
            </span>
            <div>
              <h3>Attackers don't wait</h3>
              <p>Automated bots scan the internet 24/7. New CVEs are weaponized within hours. Your security assessment from last quarter is already obsolete.</p>
            </div>
          </div>
          <div class="philosophy-point" data-delay="1">
            <span class="philosophy-icon">
              <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="#FBBF24" stroke-width="1.5">
                <path d="M4 28 L16 4 L28 28 Z" /><line x1="16" y1="14" x2="16" y2="20" /><circle cx="16" cy="24" r="1" fill="#FBBF24"/>
              </svg>
            </span>
            <div>
              <h3>The talent gap is real</h3>
              <p>3.5 million unfilled cybersecurity positions globally. The few experts available are overwhelmed, overworked, and expensive.</p>
            </div>
          </div>
          <div class="philosophy-point" data-delay="2">
            <span class="philosophy-icon">
              <svg viewBox="0 0 32 32" width="28" height="28" fill="none" stroke="#4ADE80" stroke-width="1.5">
                <path d="M6 16 C6 6, 26 6, 26 16 C26 26, 6 26, 6 16" /><path d="M16 10 v6 h4" />
                <circle cx="16" cy="16" r="2" fill="#4ADE80"/>
              </svg>
            </span>
            <div>
              <h3>AI changes the equation</h3>
              <p>Large language models can reason about code, craft payloads, and chain vulnerabilities — the same creative thinking that makes great pentesters, now available on demand.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 3: The Problem ============ -->
    <section class="slide" data-index="2">
      <div class="slide-content slide-two-col">
        <div class="slide-text-side">
          <h2 class="slide-heading">The Problem with Pentesting</h2>
          <blockquote class="slide-blockquote">
            "Traditional penetration testing is slow, expensive, and inconsistent. A single engagement can take weeks, cost tens of thousands, and still miss critical vulnerabilities."
          </blockquote>
          <div class="problem-stats">
            <div class="problem-stat">
              <span class="stat-number">21</span>
              <span class="stat-label">avg days per engagement</span>
            </div>
            <div class="problem-stat">
              <span class="stat-number">$25k+</span>
              <span class="stat-label">typical cost per test</span>
            </div>
            <div class="problem-stat">
              <span class="stat-number">60%</span>
              <span class="stat-label">of vulns missed by manual testing</span>
            </div>
          </div>
        </div>
        <div class="slide-visual-side">
          <img src="/presentation-images/slide-02-problem.svg" alt="Broken shield illustration" class="slide-illustration" />
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 4: Meet Donna ============ -->
    <section class="slide" data-index="3">
      <div class="slide-content slide-center-layout">
        <h2 class="slide-heading">Meet Donna</h2>
        <p class="slide-body slide-body-subtitle">13 specialized AI agents, orchestrated to think like a hacker.</p>

        <div class="agent-constellation">
          <!-- SVG connection lines drawn behind the nodes -->
          <svg class="constellation-lines" viewBox="0 0 1100 520" preserveAspectRatio="xMidYMid meet">
            <!-- Lines from center hub to each orbital -->
            <line class="conn-line" x1="550" y1="260" x2="120" y2="130" />
            <line class="conn-line" x1="550" y1="260" x2="350" y2="55" />
            <line class="conn-line" x1="550" y1="260" x2="750" y2="55" />
            <line class="conn-line" x1="550" y1="260" x2="980" y2="130" />
            <line class="conn-line" x1="550" y1="260" x2="980" y2="390" />
            <line class="conn-line" x1="550" y1="260" x2="750" y2="465" />
            <line class="conn-line" x1="550" y1="260" x2="350" y2="465" />
            <line class="conn-line" x1="550" y1="260" x2="120" y2="390" />
            <!-- Outer ring connections -->
            <line class="conn-line conn-outer" x1="120" y1="130" x2="350" y2="55" />
            <line class="conn-line conn-outer" x1="350" y1="55" x2="750" y2="55" />
            <line class="conn-line conn-outer" x1="750" y1="55" x2="980" y2="130" />
            <line class="conn-line conn-outer" x1="980" y1="130" x2="980" y2="390" />
            <line class="conn-line conn-outer" x1="980" y1="390" x2="750" y2="465" />
            <line class="conn-line conn-outer" x1="750" y1="465" x2="350" y2="465" />
            <line class="conn-line conn-outer" x1="350" y1="465" x2="120" y2="390" />
            <line class="conn-line conn-outer" x1="120" y1="390" x2="120" y2="130" />
            <!-- Animated pulse dots traveling along lines -->
            <circle class="pulse-dot" r="3.5">
              <animateMotion dur="3s" repeatCount="indefinite" path="M550,260 L120,130" />
            </circle>
            <circle class="pulse-dot" r="3.5">
              <animateMotion dur="2.5s" repeatCount="indefinite" path="M550,260 L980,130" />
            </circle>
            <circle class="pulse-dot" r="3.5">
              <animateMotion dur="3.5s" repeatCount="indefinite" path="M550,260 L750,465" />
            </circle>
            <circle class="pulse-dot" r="3.5">
              <animateMotion dur="2.8s" repeatCount="indefinite" path="M550,260 L120,390" />
            </circle>
          </svg>

          <!-- Central hub -->
          <div class="agent-hub">
            <div class="hub-ring hub-ring-1"></div>
            <div class="hub-ring hub-ring-2"></div>
            <div class="hub-core">
              <svg viewBox="0 0 48 48" width="40" height="40" fill="none">
                <path d="M24 4 L24 44 M4 24 L44 24 M10 10 L38 38 M38 10 L10 38" stroke="rgba(123,45,142,0.6)" stroke-width="1"/>
                <circle cx="24" cy="24" r="8" stroke="#7B2D8E" stroke-width="2" fill="rgba(123,45,142,0.15)"/>
                <circle cx="24" cy="24" r="3" fill="#C090C0"/>
              </svg>
            </div>
            <span class="hub-label">Donna</span>
          </div>

          <!-- Orbital agent nodes -->
          <div class="agent-orbital recon-orbital" data-delay="0">
            <div class="orbital-glow" style="--glow-color: #60A5FA"></div>
            <div class="orbital-icon">
              <svg viewBox="0 0 48 48" width="44" height="44" fill="none" stroke="#60A5FA" stroke-width="2">
                <circle cx="20" cy="20" r="12" /><line x1="29" y1="29" x2="42" y2="42" stroke-width="3" stroke-linecap="round"/>
                <circle cx="20" cy="20" r="4" fill="rgba(96,165,250,0.3)"/>
              </svg>
            </div>
            <div class="orbital-info">
              <h3>Recon</h3>
              <span class="orbital-count">5 agents</span>
            </div>
          </div>

          <div class="agent-orbital analysis-orbital" data-delay="1">
            <div class="orbital-glow" style="--glow-color: #FBBF24"></div>
            <div class="orbital-icon">
              <svg viewBox="0 0 48 48" width="44" height="44" fill="none" stroke="#FBBF24" stroke-width="2">
                <path d="M6 38 L16 14 L28 28 L42 8" stroke-linecap="round" stroke-linejoin="round"/>
                <circle cx="16" cy="14" r="3" fill="rgba(251,191,36,0.3)"/>
                <circle cx="28" cy="28" r="3" fill="rgba(251,191,36,0.3)"/>
                <circle cx="42" cy="8" r="3" fill="rgba(251,191,36,0.3)"/>
              </svg>
            </div>
            <div class="orbital-info">
              <h3>Analysis</h3>
              <span class="orbital-count">4 agents</span>
            </div>
          </div>

          <div class="agent-orbital exploit-orbital" data-delay="2">
            <div class="orbital-glow" style="--glow-color: #F87171"></div>
            <div class="orbital-icon">
              <svg viewBox="0 0 48 48" width="44" height="44" fill="none" stroke="#F87171" stroke-width="2">
                <circle cx="24" cy="24" r="16" stroke-dasharray="4 3"/>
                <path d="M24 8 L24 40 M8 24 L40 24" stroke-linecap="round"/>
                <circle cx="24" cy="24" r="6" fill="rgba(248,113,113,0.2)" stroke="#F87171"/>
              </svg>
            </div>
            <div class="orbital-info">
              <h3>Exploit</h3>
              <span class="orbital-count">3 agents</span>
            </div>
          </div>

          <div class="agent-orbital report-orbital" data-delay="3">
            <div class="orbital-glow" style="--glow-color: #4ADE80"></div>
            <div class="orbital-icon">
              <svg viewBox="0 0 48 48" width="44" height="44" fill="none" stroke="#4ADE80" stroke-width="2">
                <rect x="8" y="4" width="32" height="40" rx="4"/>
                <path d="M16 16h16 M16 24h12 M16 32h14" opacity="0.5" stroke-linecap="round"/>
                <path d="M14 10 L20 16 L34 4" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"/>
              </svg>
            </div>
            <div class="orbital-info">
              <h3>Report</h3>
              <span class="orbital-count">1 agent</span>
            </div>
          </div>

          <!-- Extra mini agent dots for "13 agents" feel -->
          <div class="mini-agent" style="--x: 22%; --y: 45%; --delay: 0.5s; --color: #60A5FA"></div>
          <div class="mini-agent" style="--x: 18%; --y: 55%; --delay: 0.8s; --color: #60A5FA"></div>
          <div class="mini-agent" style="--x: 35%; --y: 18%; --delay: 1.1s; --color: #60A5FA"></div>
          <div class="mini-agent" style="--x: 60%; --y: 15%; --delay: 0.6s; --color: #FBBF24"></div>
          <div class="mini-agent" style="--x: 70%; --y: 20%; --delay: 0.9s; --color: #FBBF24"></div>
          <div class="mini-agent" style="--x: 80%; --y: 50%; --delay: 1.2s; --color: #F87171"></div>
          <div class="mini-agent" style="--x: 75%; --y: 65%; --delay: 0.7s; --color: #F87171"></div>
          <div class="mini-agent" style="--x: 55%; --y: 82%; --delay: 1.0s; --color: #4ADE80"></div>
          <div class="mini-agent" style="--x: 30%; --y: 80%; --delay: 1.3s; --color: #FBBF24"></div>
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 5: The Pipeline ============ -->
    <section class="slide" data-index="4">
      <div class="slide-content slide-center-layout">
        <h2 class="slide-heading">The Pentesting Pipeline</h2>
        <p class="slide-body slide-body-subtitle">Four phases. Fully automated. Durable execution.</p>
        <div class="pipeline-flow">
          <div class="pipeline-phase" data-delay="0">
            <div class="phase-number">1</div>
            <div class="phase-content">
              <h3>Reconnaissance</h3>
              <p>Target enumeration, port scanning, technology detection, OSINT gathering</p>
            </div>
          </div>
          <div class="pipeline-connector"></div>
          <div class="pipeline-phase" data-delay="1">
            <div class="phase-number">2</div>
            <div class="phase-content">
              <h3>Analysis</h3>
              <p>Vulnerability scanning, attack surface mapping, weakness identification</p>
            </div>
          </div>
          <div class="pipeline-connector"></div>
          <div class="pipeline-phase" data-delay="2">
            <div class="phase-number">3</div>
            <div class="phase-content">
              <h3>Exploitation</h3>
              <p>Proof-of-concept validation, payload testing, privilege escalation</p>
            </div>
          </div>
          <div class="pipeline-connector"></div>
          <div class="pipeline-phase" data-delay="3">
            <div class="phase-number">4</div>
            <div class="phase-content">
              <h3>Reporting</h3>
              <p>Structured findings, severity ratings, remediation guidance, executive summary</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 6: How Agents Work ============ -->
    <section class="slide" data-index="5">
      <div class="slide-content slide-two-col">
        <div class="slide-text-side">
          <h2 class="slide-heading">How Agents Think</h2>
          <div class="agent-loop-nodes">
            <div class="loop-node" data-delay="0">
              <span class="loop-node-num">1</span>
              <span class="loop-node-label">Observe</span>
            </div>
            <div class="loop-connector-h"></div>
            <div class="loop-node" data-delay="1">
              <span class="loop-node-num">2</span>
              <span class="loop-node-label">Plan</span>
            </div>
            <div class="loop-connector-h"></div>
            <div class="loop-node" data-delay="2">
              <span class="loop-node-num">3</span>
              <span class="loop-node-label">Execute</span>
            </div>
            <div class="loop-connector-h"></div>
            <div class="loop-node" data-delay="3">
              <span class="loop-node-num">4</span>
              <span class="loop-node-label">Verify</span>
            </div>
            <div class="loop-connector-h loop-connector-return"></div>
            <div class="loop-repeat">Repeat</div>
          </div>
          <blockquote class="slide-blockquote slide-blockquote-compact">
            "Each agent runs Claude in a sandboxed Docker container with controlled tools. No hallucinated findings — every vulnerability is verified."
          </blockquote>
        </div>
        <div class="slide-visual-side">
          <div class="docker-stack">
            <div class="docker-container" data-delay="0">
              <span class="docker-label">Container</span>
              <span class="docker-agent">Nmap Scanner</span>
            </div>
            <div class="docker-container" data-delay="1">
              <span class="docker-label">Container</span>
              <span class="docker-agent">Web Crawler</span>
            </div>
            <div class="docker-container" data-delay="2">
              <span class="docker-label">Container</span>
              <span class="docker-agent">SQL Injection</span>
            </div>
            <div class="docker-container" data-delay="3">
              <span class="docker-label">Container</span>
              <span class="docker-agent">XSS Tester</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 7: Temporal Orchestration ============ -->
    <section class="slide" data-index="6">
      <div class="slide-content slide-two-col slide-two-col-reverse">
        <div class="slide-visual-side">
          <img src="/presentation-images/slide-06-temporal.svg" alt="Temporal workflow illustration" class="slide-illustration" />
        </div>
        <div class="slide-text-side">
          <h2 class="slide-heading">Durable Execution</h2>
          <p class="slide-body">Powered by <strong>Temporal</strong> — workflows survive crashes, network failures, and restarts. Every step is checkpointed.</p>
          <div class="feature-pills">
            <span class="feature-pill">Auto-retry on failure</span>
            <span class="feature-pill">Resume from checkpoint</span>
            <span class="feature-pill">Full audit trail</span>
            <span class="feature-pill">Real-time observability</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SLIDE 8: Dashboard ============ -->
    <section class="slide" data-index="7">
      <div class="slide-content slide-center-layout">
        <h2 class="slide-heading">Real-Time Dashboard</h2>
        <p class="slide-body slide-body-subtitle">Monitor every workflow. Track every finding. All in one place.</p>
        <div class="dashboard-preview">
          <div class="dash-topbar">
            <div class="dash-brand">
              <span class="dash-icon">🛡</span>
              <span>Donna</span>
            </div>
            <div class="dash-stats-row">
              <div class="dash-stat">
                <span class="dash-stat-value purple">3</span>
                <span class="dash-stat-label">Running</span>
              </div>
              <div class="dash-stat">
                <span class="dash-stat-value green">47</span>
                <span class="dash-stat-label">Completed</span>
              </div>
              <div class="dash-stat">
                <span class="dash-stat-value red">12</span>
                <span class="dash-stat-label">Critical</span>
              </div>
            </div>
          </div>
          <div class="dash-table">
            <div class="dash-row header">
              <span>Target</span><span>Status</span><span>Findings</span><span>Duration</span>
            </div>
            <div class="dash-row" data-delay="0">
              <span class="mono">api.example.com</span>
              <span class="status-running">Running</span>
              <span class="findings-badge crit">3 Critical</span>
              <span class="mono">12m 47s</span>
            </div>
            <div class="dash-row" data-delay="1">
              <span class="mono">staging.app.io</span>
              <span class="status-completed">Completed</span>
              <span class="findings-badge high">5 High</span>
              <span class="mono">34m 12s</span>
            </div>
            <div class="dash-row" data-delay="2">
