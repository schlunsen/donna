// it under the terms of the GNU Affero General Public License version 3
// as published by the Free Software Foundation.

import Base from '../layouts/Base.astro';
import Sidebar from '../components/Sidebar.astro';
import { getVersion } from '../lib/version';

const donnaVersion = getVersion();
import { listWorkflowsWithProgress, type WorkflowInfo, type FindingSummary } from '../lib/temporal.js';

// ── Data fetching ──────────────────────────────────────────────────────────────

interface WorkflowRow {
    id: string;
    runId: string;
    status: string;
    type: string;
    target: string;
    targetUrl: string | null;
    start: string;
    end: string | null;
    phase: string | null;
    agent: string | null;
    completedAgents: number;
    totalAgents: number;
    costUsd: number;
    findingSummary: FindingSummary | null;
    modelProfile: string;
}

let workflows: WorkflowRow[] = [];
let temporalError: string | null = null;

// Read URL params for filtering
const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get('status');
const periodFilter = url.searchParams.get('period');

try {
    const raw = await listWorkflowsWithProgress(statusFilter ? { status: statusFilter } : undefined);

    workflows = raw.map((wf: WorkflowInfo): WorkflowRow => {
        // Use actual webUrl from workflow input if available, fall back to parsing workflow ID
        let target = '—';
        let targetUrl: string | null = null;
        if (wf.webUrl) {
            try {
                const parsed = new URL(wf.webUrl);
                target = parsed.hostname;
                targetUrl = wf.webUrl;
            } catch {
                target = wf.webUrl;
                targetUrl = wf.webUrl;
            }
        } else {
            // Fallback: extract hostname from workflow ID
            const fallback = wf.workflowId.split('_donna')[0]?.replace(/_/g, '.') || '—';
            target = fallback;
        }
        return {
            id: wf.workflowId,
            runId: wf.runId,
            status: wf.status,
            type: wf.type,
            target,
            targetUrl,
            start: wf.startTime,
            end: wf.closeTime,
            phase: wf.progress?.currentPhase || null,
            agent: wf.progress?.currentAgent || null,
            completedAgents: wf.progress?.completedAgents?.length || 0,
            totalAgents: wf.progress?.summary?.agentCount || 13,
            costUsd: wf.progress?.summary?.totalCostUsd || 0,
            findingSummary: wf.progress?.findingSummary || null,
            modelProfile: wf.modelProfile || 'claude',
        };
    });

    // Client-side period filter
    if (periodFilter) {
        const now = Date.now();
        const cutoff = periodFilter === 'hour' ? now - 3600000 : now - 86400000;
        workflows = workflows.filter(w => new Date(w.start).getTime() >= cutoff);
    }
} catch (err) {
    temporalError = err instanceof Error ? err.message : 'Failed to connect to Temporal';
}

const runningCount = workflows.filter(w => w.status === 'running').length;
const failedCount = workflows.filter(w => w.status === 'failed').length;
const completedCount = workflows.filter(w => w.status === 'completed').length;
const totalCost = workflows.reduce((sum, w) => sum + w.costUsd, 0);
const now = new Date();
const dateStr = now.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });

function formatTime(iso: string | null) {
    if (!iso) return '—';
    const d = new Date(iso);
    return d.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false });
}

function formatDateTime(iso: string | null) {
    if (!iso) return '—';
    const d = new Date(iso);
    return d.toLocaleString('en-US', {
        month: 'short', day: 'numeric', year: 'numeric',
        hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false
    });
}

function getElapsed(start: string, end: string | null) {
    const s = new Date(start).getTime();
    const e = end ? new Date(end).getTime() : Date.now();
    const ms = e - s;
    const seconds = Math.floor(ms / 1000);
    const minutes = Math.floor(seconds / 60);
    const hours = Math.floor(minutes / 60);
    if (hours > 0) return `${hours}h ${minutes % 60}m`;
    if (minutes > 0) return `${minutes}m ${seconds % 60}s`;
    return `${seconds}s`;
}

function truncateId(id: string) {
    if (id.length <= 38) return id;
    return id.slice(0, 35) + '…';
}

// Active filter label
let activeFilterLabel = 'All';
if (statusFilter) activeFilterLabel = statusFilter.charAt(0).toUpperCase() + statusFilter.slice(1);
if (periodFilter === 'today') activeFilterLabel = 'Today';
if (periodFilter === 'hour') activeFilterLabel = 'Last Hour';
---

<Base title="Workflows — Donna Dashboard">
    <div class="app-shell">
        <Sidebar activePage="workflows" runningCount={runningCount} failedCount={failedCount} />

        <header class="topbar">
            <div class="topbar-left">
                <button class="mobile-menu-btn" id="mobileMenuBtn" aria-label="Open menu">☰</button>
                <div class="topbar-breadcrumb">
                    <span style="color: var(--text-dim);">default</span>
                    <span class="topbar-breadcrumb-sep">/</span>
                    <span style="color: var(--white); font-weight: 600;">Workflows</span>
                </div>
            </div>
            <div class="topbar-right">
                <span class="version-badge">v{donnaVersion}</span>
                <button class="btn-icon" title="Refresh" id="refreshBtn">↻</button>
                <button class="btn-icon" title="Settings">⚙</button>
            </div>
        </header>

        <main class="main-content">
            <div class="page-container">
                <!-- Page Header -->
                <div class="page-header">
                    <div class="page-header-left">
                        <div>
                            <h1 class="page-title">
                                {workflows.length} <span class="gradient-text">Workflows</span>
                            </h1>
                            <p class="page-subtitle">
                                {dateStr} · last refreshed just now
                                {statusFilter && <span class="active-filter-badge">Filtered: {activeFilterLabel}</span>}
                                {periodFilter && <span class="active-filter-badge">Period: {activeFilterLabel}</span>}
                                {temporalError && <span style="color: var(--warning); margin-left: 0.5rem;">⚠ {temporalError}</span>}
                            </p>
                        </div>
                        <div class="page-header-stats">
                            {runningCount > 0 && <span class="status-pill running"><span class="status-dot pulse"></span> {runningCount} Running</span>}
                            {failedCount > 0 && <span class="status-pill failed"><span class="status-dot"></span> {failedCount} Failed</span>}
                            {completedCount > 0 && <span class="status-pill completed"><span class="status-dot"></span> {completedCount} Completed</span>}
                        </div>
                    </div>
                    <div>
                        <button class="btn btn-primary" id="startWorkflowBtn">
                            <span>⚡</span> Start Workflow
                        </button>
                    </div>
                </div>

                <!-- Stats Overview Cards -->
                <div class="stats-row">
                    <div class="stat-card purple" data-glow>
                        <div class="stat-card-label">Total Workflows</div>
                        <div class="stat-card-value">{workflows.length}</div>
                        <div class="stat-card-meta">all time</div>
                    </div>
                    <div class="stat-card blue" data-glow>
                        <div class="stat-card-label">Running</div>
                        <div class="stat-card-value">{runningCount}</div>
                        <div class="stat-card-meta">active now</div>
                    </div>
                    <div class="stat-card red" data-glow>
                        <div class="stat-card-label">Failed</div>
                        <div class="stat-card-value">{failedCount}</div>
                        <div class="stat-card-meta">need attention</div>
                    </div>
                    <div class="stat-card green" data-glow>
                        <div class="stat-card-label">Total Cost</div>
                        <div class="stat-card-value">${totalCost.toFixed(2)}</div>
                        <div class="stat-card-meta">across all runs</div>
                    </div>
                </div>

                <!-- Toolbar / Search & Filter -->
                <div class="toolbar">
                    <div class="toolbar-search">
                        <span class="toolbar-search-icon">🔍</span>
                        <input type="text" placeholder="Search workflows by ID, target, or type..." id="searchInput" />
                    </div>
                    <div class="toolbar-divider"></div>

                    <!-- Filter Dropdown -->
                    <div class="dropdown" id="filterDropdown">
                        <button class="btn btn-ghost" id="filterBtn">
                            <span>☰</span> Filter
                            {statusFilter && <span class="btn-badge">{activeFilterLabel}</span>}
                        </button>
                        <div class="dropdown-menu" id="filterMenu">
                            <a class="dropdown-item {!statusFilter && !periodFilter ? 'active-item' : ''}" href="/">
                                <span class="dropdown-item-icon">◎</span> All Workflows
                            </a>
                            <div class="dropdown-divider"></div>
                            <div class="dropdown-section-label">By Status</div>
                            <a class="dropdown-item {statusFilter === 'running' ? 'active-item' : ''}" href="/?status=running">
                                <span class="dropdown-item-icon">◉</span> Running
                                {runningCount > 0 && <span class="dropdown-badge info">{runningCount}</span>}
                            </a>
                            <a class="dropdown-item {statusFilter === 'completed' ? 'active-item' : ''}" href="/?status=completed">
                                <span class="dropdown-item-icon">✓</span> Completed
                                {completedCount > 0 && <span class="dropdown-badge success">{completedCount}</span>}
                            </a>
                            <a class="dropdown-item {statusFilter === 'failed' ? 'active-item' : ''}" href="/?status=failed">
                                <span class="dropdown-item-icon">✗</span> Failed
                                {failedCount > 0 && <span class="dropdown-badge error">{failedCount}</span>}
                            </a>
                            <div class="dropdown-divider"></div>
                            <div class="dropdown-section-label">By Time</div>
                            <a class="dropdown-item {periodFilter === 'today' ? 'active-item' : ''}" href="/?period=today">
                                <span class="dropdown-item-icon">◔</span> Today
                            </a>
                            <a class="dropdown-item {periodFilter === 'hour' ? 'active-item' : ''}" href="/?period=hour">
                                <span class="dropdown-item-icon">◕</span> Last Hour
                            </a>
                        </div>
                    </div>

                    <!-- Sort Dropdown -->
                    <div class="dropdown" id="sortDropdown">
                        <button class="btn btn-ghost" id="sortBtn">
                            <span>↕</span> Sort
                        </button>
                        <div class="dropdown-menu" id="sortMenu">
                            <button class="dropdown-item" data-sort="start" data-dir="desc">
                                <span class="dropdown-item-icon">↓</span> Newest First
                            </button>
                            <button class="dropdown-item" data-sort="start" data-dir="asc">
                                <span class="dropdown-item-icon">↑</span> Oldest First
                            </button>
                            <div class="dropdown-divider"></div>
                            <button class="dropdown-item" data-sort="status" data-dir="asc">
                                <span class="dropdown-item-icon">◉</span> Status
                            </button>
                            <button class="dropdown-item" data-sort="id" data-dir="asc">
                                <span class="dropdown-item-icon">⇅</span> Workflow ID
                            </button>
                            <button class="dropdown-item" data-sort="duration" data-dir="desc">
                                <span class="dropdown-item-icon">⏱</span> Duration (longest)
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Workflow Data Table -->
                <div class="table-container">
                  <div class="table-scroll-wrapper">
                    <table class="data-table" id="workflowTable">
                        <thead>
                            <tr>
                                <th style="width: 36px; padding-left: 0.75rem;">
                                    <input type="checkbox" class="row-checkbox" id="selectAll" />
                                </th>
                                <th>Status</th>
                                <th class="sortable sorted" data-sort="id">Workflow ID ↓</th>
                                <th>Run ID</th>
                                <th>Model</th>
                                <th>Target</th>
                                <th>Findings</th>
                                <th>Start</th>
                                <th>End</th>
                                <th>Duration</th>
                            </tr>
                        </thead>
                        <tbody>
                            {workflows.map((wf) => (
                                <tr data-workflow-id={wf.id} data-target={wf.target} data-status={wf.status}
                                    data-start={wf.start} data-type={wf.type}>
                                    <td style="padding-left: 0.75rem;">
                                        <input type="checkbox" class="row-checkbox" />
                                    </td>
                                    <td>
                                        <span class={`status-pill ${wf.status}`}>
                                            <span class={`status-dot ${wf.status === 'running' ? 'pulse' : ''}`}></span>
                                            {wf.status === 'running' ? 'Running' :
                                             wf.status === 'failed' ? 'Failed' :
                                             wf.status === 'terminated' ? 'Terminated' :
                                             wf.status === 'cancelled' ? 'Cancelled' : 'Completed'}
                                        </span>
                                    </td>
                                    <td>
                                        <a href={`/workflow/${wf.runId}`} class="cell-id" title={wf.id}>{truncateId(wf.id)}</a>
                                    </td>
                                    <td>
                                        <span class="cell-runid" title={wf.runId}>{wf.runId.slice(0, 8)}…</span>
                                    </td>
                                    <td class="cell-type">
                                        <span class={`model-badge ${wf.modelProfile === 'claude' ? 'model-claude' : wf.modelProfile === 'hybrid' ? 'model-hybrid' : 'model-custom'}`}>
                                            {wf.modelProfile}
                                        </span>
                                    </td>
                                    <td class="cell-type">
                                        {wf.targetUrl ? (
                                            <a href={wf.targetUrl} target="_blank" rel="noopener noreferrer" class="target-link">
                                                {wf.target}<span class="target-link-icon">↗</span>
                                            </a>
                                        ) : (
                                            wf.target
                                        )}
                                    </td>
                                    <td class="cell-findings">
                                        {wf.findingSummary && wf.findingSummary.total > 0 ? (
                                            <span class="findings-badges">
                                                {wf.findingSummary.critical > 0 && <span class="finding-badge critical">{wf.findingSummary.critical}C</span>}
                                                {wf.findingSummary.high > 0 && <span class="finding-badge high">{wf.findingSummary.high}H</span>}
                                                {wf.findingSummary.medium > 0 && <span class="finding-badge medium">{wf.findingSummary.medium}M</span>}
                                                {wf.findingSummary.low > 0 && <span class="finding-badge low">{wf.findingSummary.low}L</span>}
                                                {wf.findingSummary.informational > 0 && <span class="finding-badge info">{wf.findingSummary.informational}I</span>}
                                            </span>
                                        ) : wf.status === 'completed' ? (
                                            <span class="findings-none">0 findings</span>
                                        ) : (
                                            <span class="findings-none">—</span>
                                        )}
                                    </td>
                                    <td class="cell-time" title={formatDateTime(wf.start)}>
                                        {formatDateTime(wf.start)}
                                    </td>
                                    <td class="cell-time" title={formatDateTime(wf.end)}>
                                        {formatDateTime(wf.end)}
                                    </td>
                                    <td class="cell-duration">{getElapsed(wf.start, wf.end)}</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>

                  </div><!-- .table-scroll-wrapper -->

                    {workflows.length === 0 && (
                        <div class="empty-state">
                            <div class="empty-state-icon">⚡</div>
                            <h3>No workflows found</h3>
                            <p>
                                {statusFilter
                                    ? `No ${statusFilter} workflows. Try a different filter.`
                                    : 'Start a workflow to see it here.'}
                            </p>
                            {statusFilter && (
                                <a href="/" class="btn btn-secondary" style="margin-top: 0.5rem;">Clear filters</a>
                            )}
                        </div>
                    )}

                    <div class="table-footer">
                        <div class="table-footer-left">
                            <span>Showing</span>
                            <select id="pageSize">
                                <option>20</option>
                                <option>50</option>
                                <option selected>100</option>
                            </select>
                            <span>per page</span>
                        </div>
                        <div class="pagination">
                            <button class="pagination-btn" disabled>←</button>
                            <span class="pagination-info">1–{workflows.length} of {workflows.length}</span>
                            <button class="pagination-btn" disabled>→</button>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Start Scan Modal -->
    <div class="modal-overlay" id="startWorkflowModal">
        <div class="modal">
            <div class="modal-header">
                <h2>Start Scan</h2>
                <button class="btn-icon modal-close" id="closeModal">✕</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label class="form-label">Target URL</label>
                    <input type="url" class="form-input" id="workflowTarget" placeholder="https://example.com" required />
                </div>
                <div class="form-group">
                    <label class="form-label">Repository Path</label>
                    <input type="text" class="form-input" id="workflowRepoPath" placeholder="/repos/my-app" required />
                    <small style="color: var(--text-muted); font-size: 0.75rem;">
                        Path to the target's source code repository on the worker
                    </small>
                </div>
                <div class="form-group" style="display: flex; align-items: center; gap: 0.5rem;">
                    <input type="checkbox" id="workflowTestingMode" />
                    <label class="form-label" for="workflowTestingMode" style="margin: 0;">
                        Pipeline testing mode
                    </label>
                    <small style="color: var(--text-muted); font-size: 0.75rem;">(minimal prompts, faster)</small>
                </div>
                <div id="startError" style="display: none; color: var(--error); font-size: 0.85rem; margin-top: 0.5rem; padding: 0.5rem; background: rgba(255,0,0,0.08); border-radius: 6px;"></div>
                <div id="startSuccess" style="display: none; color: var(--success); font-size: 0.85rem; margin-top: 0.5rem; padding: 0.5rem; background: rgba(0,255,0,0.08); border-radius: 6px;"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" id="cancelModal">Cancel</button>
                <button class="btn btn-primary" id="submitWorkflow">
                    <span id="submitLabel">⚡ Start Scan</span>
                    <span id="submitSpinner" style="display: none;">Starting…</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Interactive scripts -->
    <script is:inline>
        // Glow effect on cards
        document.querySelectorAll('[data-glow]').forEach(card => {
            card.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                card.style.setProperty('--glow-x', (e.clientX - rect.left) + 'px');
                card.style.setProperty('--glow-y', (e.clientY - rect.top) + 'px');
            });
        });

        // Refresh button
        document.getElementById('refreshBtn')?.addEventListener('click', () => {
            window.location.reload();
        });

        // Search filter
        document.getElementById('searchInput')?.addEventListener('input', (e) => {
            const query = e.target.value.toLowerCase();
            document.querySelectorAll('#workflowTable tbody tr').forEach(row => {
                const id = row.dataset.workflowId?.toLowerCase() || '';
                const target = row.dataset.target?.toLowerCase() || '';
                const type = row.dataset.type?.toLowerCase() || '';
                const status = row.dataset.status?.toLowerCase() || '';
                const match = !query || id.includes(query) || target.includes(query) || type.includes(query) || status.includes(query);
                row.style.display = match ? '' : 'none';
            });
        });

        // Select all checkbox
        document.getElementById('selectAll')?.addEventListener('change', (e) => {
            const checked = e.target.checked;
            document.querySelectorAll('#workflowTable tbody .row-checkbox').forEach(cb => {
                cb.checked = checked;
            });
        });

        // ── Dropdown toggles ──────────────────────
        function setupDropdown(btnId, menuId) {
            const btn = document.getElementById(btnId);
            const menu = document.getElementById(menuId);
            if (!btn || !menu) return;

            btn.addEventListener('click', (e) => {
                e.stopPropagation();
                // Close all other menus
                document.querySelectorAll('.dropdown-menu.open').forEach(m => {
                    if (m !== menu) m.classList.remove('open');
                });
                menu.classList.toggle('open');
            });
        }

        setupDropdown('filterBtn', 'filterMenu');
        setupDropdown('sortBtn', 'sortMenu');

        // Close menus on outside click
        document.addEventListener('click', () => {
            document.querySelectorAll('.dropdown-menu.open').forEach(m => m.classList.remove('open'));
        });

        // Prevent menu clicks from closing
        document.querySelectorAll('.dropdown-menu').forEach(m => {
            m.addEventListener('click', (e) => e.stopPropagation());
        });

        // ── Sort functionality ──────────────────────
        document.querySelectorAll('#sortMenu .dropdown-item').forEach(item => {
            item.addEventListener('click', () => {
                const sortBy = item.dataset.sort;
                const dir = item.dataset.dir;
                const tbody = document.querySelector('#workflowTable tbody');
                if (!tbody) return;

                const rows = Array.from(tbody.querySelectorAll('tr'));
                rows.sort((a, b) => {
                    let va, vb;
                    if (sortBy === 'start') {
                        va = a.dataset.start || '';
                        vb = b.dataset.start || '';
                    } else if (sortBy === 'status') {
                        va = a.dataset.status || '';
                        vb = b.dataset.status || '';
                    } else if (sortBy === 'id') {
                        va = a.dataset.workflowId || '';
                        vb = b.dataset.workflowId || '';
                    } else if (sortBy === 'duration') {
                        const startA = new Date(a.dataset.start || 0).getTime();
                        const startB = new Date(b.dataset.start || 0).getTime();
                        va = String(Date.now() - startA);
                        vb = String(Date.now() - startB);
                    }
                    const cmp = (va || '').localeCompare(vb || '', undefined, { numeric: true });
                    return dir === 'desc' ? -cmp : cmp;
                });

                rows.forEach(r => tbody.appendChild(r));
                document.getElementById('sortMenu')?.classList.remove('open');
            });
        });

        // ── Start Scan modal ──────────────────
        const modal = document.getElementById('startWorkflowModal');
        const startError = document.getElementById('startError');
        const startSuccess = document.getElementById('startSuccess');

        function resetModalState() {
            if (startError) { startError.style.display = 'none'; startError.textContent = ''; }
            if (startSuccess) { startSuccess.style.display = 'none'; startSuccess.textContent = ''; }
            document.getElementById('submitLabel').style.display = '';
            document.getElementById('submitSpinner').style.display = 'none';
            document.getElementById('submitWorkflow').disabled = false;
        }

        document.getElementById('startWorkflowBtn')?.addEventListener('click', () => {
            resetModalState();
            modal?.classList.add('open');
        });
        document.getElementById('closeModal')?.addEventListener('click', () => {
            modal?.classList.remove('open');
        });
        document.getElementById('cancelModal')?.addEventListener('click', () => {
            modal?.classList.remove('open');
        });
        modal?.addEventListener('click', (e) => {
            if (e.target === modal) modal.classList.remove('open');
        });

        // Submit scan
        document.getElementById('submitWorkflow')?.addEventListener('click', async () => {
            const webUrl = document.getElementById('workflowTarget')?.value?.trim();
            const repoPath = document.getElementById('workflowRepoPath')?.value?.trim();
            const pipelineTestingMode = document.getElementById('workflowTestingMode')?.checked || false;

            if (!webUrl || !repoPath) {
                startError.textContent = 'Target URL and Repository Path are required.';
                startError.style.display = 'block';
                return;
            }

            // Show loading state
            startError.style.display = 'none';
            startSuccess.style.display = 'none';
            document.getElementById('submitLabel').style.display = 'none';
            document.getElementById('submitSpinner').style.display = '';
            document.getElementById('submitWorkflow').disabled = true;

            try {
                const res = await fetch('/api/workflows', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ webUrl, repoPath, pipelineTestingMode }),
                });
                const data = await res.json();

                if (!res.ok) {
                    throw new Error(data.error || `HTTP ${res.status}`);
                }

                startSuccess.innerHTML = `Scan started! Workflow: <strong>${data.workflowId}</strong>. Redirecting…`;
                startSuccess.style.display = 'block';

                // Redirect to the workflow detail page after a short delay
                setTimeout(() => {
                    window.location.href = `/workflow/${data.runId}`;
                }, 1500);
            } catch (err) {
                startError.textContent = err.message || 'Failed to start scan.';
                startError.style.display = 'block';
                document.getElementById('submitLabel').style.display = '';
                document.getElementById('submitSpinner').style.display = 'none';
                document.getElementById('submitWorkflow').disabled = false;
            }
        });

        // ── Column header sort ──────────────────
        document.querySelectorAll('.sortable').forEach(th => {
            th.addEventListener('click', () => {
                const col = th.dataset.sort;
                // Toggle sort direction
                const currentDir = th.dataset.dir || 'desc';
                const newDir = currentDir === 'desc' ? 'asc' : 'desc';
                th.dataset.dir = newDir;

                // Update visual
                document.querySelectorAll('.data-table th').forEach(h => h.classList.remove('sorted'));
                th.classList.add('sorted');
                th.textContent = th.textContent.replace(/[↑↓]/, '') + (newDir === 'asc' ? ' ↑' : ' ↓');

                const tbody = document.querySelector('#workflowTable tbody');
                const rows = Array.from(tbody.querySelectorAll('tr'));
                rows.sort((a, b) => {
                    const va = a.dataset.workflowId || '';
                    const vb = b.dataset.workflowId || '';
                    const cmp = va.localeCompare(vb, undefined, { numeric: true });
                    return newDir === 'desc' ? -cmp : cmp;
                });
                rows.forEach(r => tbody.appendChild(r));
            });
        });
    </script>
</Base>

