{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/pentest-config-schema.json",
  "title": "Penetration Testing Configuration Schema",
  "description": "Schema for YAML configuration files used in the penetration testing agent",
  "type": "object",
  "properties": {
    "authentication": {
      "type": "object",
      "description": "Authentication configuration for the target application",
      "properties": {
        "login_type": {
          "type": "string",
          "enum": ["form", "sso", "api", "basic"],
          "description": "Type of authentication mechanism"
        },
        "login_url": {
          "type": "string",
          "format": "uri",
          "description": "URL for the login page or endpoint"
        },
        "credentials": {
          "type": "object",
          "description": "Login credentials",
          "properties": {
            "username": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255,
              "description": "Username or email for authentication"
            },
            "password": {
              "type": "string",
              "minLength": 1,
              "maxLength": 255,
              "description": "Password for authentication"
            },
            "totp_secret": {
              "type": "string",
              "pattern": "^[A-Za-z2-7]+=*$",
              "description": "TOTP secret for two-factor authentication (Base32 encoded, case insensitive)"
            }
          },
          "required": ["username", "password"],
          "additionalProperties": false
        },
        "login_flow": {
          "type": "array",
          "description": "Step-by-step instructions for the login process",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 500
          },
          "minItems": 1,
          "maxItems": 20
        },
        "success_condition": {
          "type": "object",
          "description": "Condition that indicates successful authentication",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["url_contains", "element_present", "url_equals_exactly", "text_contains"],
              "description": "Type of success condition to check"
            },
            "value": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500,
              "description": "Value to match against the success condition"
            }
          },
          "required": ["type", "value"],
          "additionalProperties": false
        }
      },
      "required": ["login_type", "login_url", "credentials", "success_condition"],
      "additionalProperties": false
    },
    "pipeline": {
      "type": "object",
      "description": "Pipeline execution settings for retry behavior and concurrency",
      "properties": {
        "retry_preset": {
          "type": "string",
          "enum": ["default", "subscription"],
          "description": "Retry preset. 'subscription' extends timeouts for Anthropic subscription rate limit windows (5h+)."
        },
        "max_concurrent_pipelines": {
          "type": "string",
          "pattern": "^[1-9][0-9]?$",
          "description": "Max concurrent vulnerability pipelines (1-99, default: 5)"
        },
        "model_tiers": {
          "type": "object",
          "description": "Override default model tiers for specific agents. Keys are agent names, values are tier levels.",
          "patternProperties": {
            "^(pre-recon|recon|injection-vuln|xss-vuln|auth-vuln|ssrf-vuln|authz-vuln|injection-exploit|xss-exploit|auth-exploit|ssrf-exploit|authz-exploit|report)$": {
              "type": "string",
              "enum": ["small", "medium", "large"],
              "description": "Model tier: small (Haiku), medium (Sonnet), large (Opus)"
            }
          },
          "additionalProperties": false
        },
        "concurrency": {
          "type": "object",
          "description": "Fine-grained concurrency limits per resource type",
          "properties": {
            "pipelines": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "description": "Max concurrent vuln→exploit pipeline pairs (default: 5)"
            },
            "max_browsers": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "description": "Max concurrent Playwright browser instances (default: 3)"
            }
          },
          "additionalProperties": false
        },
        "model_profile": {
          "type": "string",
          "description": "Model profile to use for this scan (overrides models.default_profile)",
          "minLength": 1,
          "maxLength": 64
        }
      },
      "additionalProperties": false
    },
    "rules": {
      "type": "object",
      "description": "Testing rules that define what to focus on or avoid during penetration testing",
      "properties": {
        "avoid": {
          "type": "array",
          "description": "Rules defining areas to avoid during testing",
          "items": {
            "$ref": "#/$defs/rule"
          },
          "maxItems": 50
        },
        "focus": {
          "type": "array",
          "description": "Rules defining areas to focus on during testing",
          "items": {
            "$ref": "#/$defs/rule"
          },
          "maxItems": 50
        }
      },
      "additionalProperties": false
    },
    "models": {
      "type": "object",
      "description": "Model profiles for multi-provider LLM support. Define named profiles with different endpoints and model mappings.",
      "properties": {
        "profiles": {
          "type": "object",
          "description": "Named model profiles. Each profile maps tiers to model IDs and optionally specifies endpoint.",
          "patternProperties": {
            "^[a-zA-Z0-9][a-zA-Z0-9_-]*$": {
              "$ref": "#/$defs/model_profile"
            }
          },
          "additionalProperties": false,
          "minProperties": 1
        },
        "default_profile": {
          "type": "string",
          "description": "Default profile name to use when no --model-profile CLI flag is provided",
          "minLength": 1,
          "maxLength": 64
        }
      },
      "required": ["profiles"],
      "additionalProperties": false
    },
    "login": {
      "type": "object",
      "description": "Deprecated: Use 'authentication' section instead",
      "deprecated": true
    }
  },
  "anyOf": [
    {"required": ["authentication"]},
    {"required": ["rules"]},
    {"required": ["authentication", "rules"]},
    {"required": ["models"]}
  ],
  "additionalProperties": false,
  "$defs": {
    "model_profile": {
      "type": "object",
      "description": "A named model profile defining endpoint and model mappings per tier",
      "properties": {
        "base_url": {
          "type": "string",
          "format": "uri",
          "description": "API base URL. Omit to use default Anthropic API."
        },
        "api_key_env": {
          "type": "string",
          "pattern": "^[A-Z_][A-Z0-9_]*$",
          "description": "Environment variable name holding the API key (default: ANTHROPIC_API_KEY)"
        },
        "tiers": {
          "type": "object",
          "description": "Model ID for each capability tier",
          "properties": {
            "small": {
              "type": "string",
              "minLength": 1,
              "description": "Model for small tier (summarization, extraction)"
            },
            "medium": {
              "type": "string",
              "minLength": 1,
              "description": "Model for medium tier (tool use, general analysis)"
            },
            "large": {
              "type": "string",
              "minLength": 1,
              "description": "Model for large tier (deep reasoning, complex analysis)"
            }
          },
          "required": ["small", "medium", "large"],
          "additionalProperties": false
        },
        "tier_endpoints": {
          "type": "object",
          "description": "Per-tier endpoint overrides for hybrid profiles (different providers per tier)",
          "properties": {
            "small": { "$ref": "#/$defs/tier_endpoint" },
            "medium": { "$ref": "#/$defs/tier_endpoint" },
            "large": { "$ref": "#/$defs/tier_endpoint" }
          },
          "additionalProperties": false
        }
      },
      "required": ["tiers"],
      "additionalProperties": false
    },
    "tier_endpoint": {
      "type": "object",
      "description": "Endpoint override for a specific tier in a hybrid profile",
      "properties": {
        "base_url": {
          "type": "string",
          "format": "uri",
          "description": "API base URL for this tier"
        },
        "api_key_env": {
          "type": "string",
          "pattern": "^[A-Z_][A-Z0-9_]*$",
          "description": "Environment variable name holding the API key for this tier"
        }
      },
      "required": ["base_url"],
      "additionalProperties": false
    },
    "rule": {
      "type": "object",
      "description": "A single testing rule",
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200,
          "description": "Human-readable description of the rule"
        },
        "type": {
          "type": "string",
          "enum": ["path", "subdomain", "domain", "method", "header", "parameter"],
          "description": "Type of rule (what aspect of requests to match against)"
        },
        "url_path": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1000,
          "description": "URL path pattern or value to match"
        }
      },
      "required": ["description", "type", "url_path"],
      "additionalProperties": false
    }
  }
}